/*DS4UI_JSONL: match the DSML marker tolerantly — "DSM" plus one ASCII letter
 * (the literal typo "DSMI" was seen from cloud DeepSeek mid-call). */
static const char *agent_dsml_match_marker(const char *p) {
    if (p[0] != 'D' || p[1] != 'S' || p[2] != 'M') return NULL;
    char c = p[3];
    if (!((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z'))) return NULL;
    return p + 4;
}

static bool agent_dsml_open_tag_is(const char *tag, const char *name) {
    /*DS4UI_JSONL: accept a mangled leading/separating bar (dropped, colon,
      ASCII pipe, or a zero-width space) around the ｜DSML｜ marker, and a
      one-letter marker typo (DSMI).*/
    const char *p = tag;
    if (*p != '<') return false;
    p = agent_dsml_skip_sep(p + 1);
    p = agent_dsml_match_marker(p);
    if (!p) return false;
    p = agent_dsml_skip_sep(p);
