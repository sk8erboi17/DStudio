static bool agent_dsml_close_tag_at(const char *s, const char *name, size_t *tag_len) {
    char prefix[64];
    static const char dsml_bar[] = "｜";
    /*DS4UI_JSONL: tolerate the dropped leading fullwidth bar on close tags too.*/
    static const char *const pre[2] = { "</｜DSML｜", "</DSML｜" };
    size_t prefix_len = 0;
    int matched = 0;
    for (int v = 0; v < 2 && !matched; v++) {
        snprintf(prefix, sizeof(prefix), "%s%s", pre[v], name);
        prefix_len = strlen(prefix);
        if (strncmp(s, prefix, prefix_len) == 0) matched = 1;
    }
    if (!matched) return false;
