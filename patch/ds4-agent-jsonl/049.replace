    /*DS4UI_JSONL: cloud DeepSeek was ALSO seen rewriting the bars as an ASCII
     * colon (<DSML:write>) and typo-ing the marker itself (</DSMI:parameter>).
     * Without these needles the whole mangled call streams out as prose and
     * the turn ends silently — the stall the tolerant nets exist to prevent. */
    static const char fullwidth_marker[] = "｜DSML｜";
    static const char ascii_marker[] = "|DSML|";
    static const char missing_open[] = "<DSML｜";
    static const char missing_close[] = "</DSML｜";
    static const char colon_open[] = "<DSML:";
    static const char colon_close[] = "</DSML:";
    static const char typo_open[] = "<DSMI";
    static const char typo_close[] = "</DSMI";
    return agent_tail_matches(d->tail, d->len,
                              fullwidth_marker, sizeof(fullwidth_marker) - 1) ||
           agent_tail_matches(d->tail, d->len,
                              ascii_marker, sizeof(ascii_marker) - 1) ||
           agent_tail_matches(d->tail, d->len,
                              missing_open, sizeof(missing_open) - 1) ||
           agent_tail_matches(d->tail, d->len,
                              missing_close, sizeof(missing_close) - 1) ||
           agent_tail_matches(d->tail, d->len,
                              colon_open, sizeof(colon_open) - 1) ||
           agent_tail_matches(d->tail, d->len,
                              colon_close, sizeof(colon_close) - 1) ||
           agent_tail_matches(d->tail, d->len,
                              typo_open, sizeof(typo_open) - 1) ||
           agent_tail_matches(d->tail, d->len,
                              typo_close, sizeof(typo_close) - 1);
