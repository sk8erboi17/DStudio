/*DS4UI_REMOTE_AGENT*/
#if defined(_WIN32) || defined(__MSYS__) || defined(__CYGWIN__)
#ifndef WIN32_LEAN_AND_MEAN
#define WIN32_LEAN_AND_MEAN
#endif
#include <windows.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#endif

#if defined(_WIN32) || defined(__MSYS__) || defined(__CYGWIN__)
static bool ds4ui_win32_cdp_alive(int port) {
    int fd = socket(AF_INET, SOCK_STREAM, 0);
    if (fd < 0) return false;
    int old_flags = 0;
    set_nonblock(fd, true, &old_flags);
    struct sockaddr_in sa;
    memset(&sa, 0, sizeof(sa));
    sa.sin_family = AF_INET;
    sa.sin_port = htons((uint16_t)port);
    sa.sin_addr.s_addr = inet_addr("127.0.0.1");
    int rc = connect(fd, (struct sockaddr *)&sa, sizeof(sa));
    if (rc == 0) {
        close(fd);
        return true;
    }
    if (errno != EINPROGRESS) {
        close(fd);
        return false;
    }
    fd_set wfds;
    FD_ZERO(&wfds);
    FD_SET(fd, &wfds);
    struct timeval tv = {.tv_sec = 0, .tv_usec = 150000};
    rc = select(fd + 1, NULL, &wfds, NULL, &tv);
    if (rc <= 0) {
        close(fd);
        return false;
    }
    int err = 0;
    socklen_t err_len = sizeof(err);
    if (getsockopt(fd, SOL_SOCKET, SO_ERROR, (char *)&err, &err_len) != 0) err = errno;
    close(fd);
    return err == 0;
}

static bool ds4ui_win32_file_exists(const char *path) {
    DWORD attr = GetFileAttributesA(path);
    return attr != INVALID_FILE_ATTRIBUTES && !(attr & FILE_ATTRIBUTE_DIRECTORY);
}

static bool ds4ui_win32_chrome_candidate(char *out, size_t cap, const char *base, const char *suffix) {
    if (!base || !base[0] || !suffix || !suffix[0]) return false;
    int n = snprintf(out, cap, "%s\\%s", base, suffix);
    return n > 0 && (size_t)n < cap && ds4ui_win32_file_exists(out);
}

static void ds4ui_win32_ensure_chrome(int port) {
    if (ds4ui_win32_cdp_alive(port)) return;
    char chrome[1024] = {0};
    const char *env = getenv("DS4_CHROME");
    if (env && env[0] && ds4ui_win32_file_exists(env)) {
        snprintf(chrome, sizeof(chrome), "%s", env);
    } else {
        char base[768];
        DWORD n = GetEnvironmentVariableA("LOCALAPPDATA", base, sizeof(base));
        if (n > 0 && n < sizeof(base))
            ds4ui_win32_chrome_candidate(chrome, sizeof(chrome), base, "Google\\Chrome\\Application\\chrome.exe");
        if (!chrome[0]) {
            n = GetEnvironmentVariableA("PROGRAMFILES", base, sizeof(base));
            if (n > 0 && n < sizeof(base))
                ds4ui_win32_chrome_candidate(chrome, sizeof(chrome), base, "Google\\Chrome\\Application\\chrome.exe");
        }
        if (!chrome[0]) {
            n = GetEnvironmentVariableA("PROGRAMFILES(X86)", base, sizeof(base));
            if (n > 0 && n < sizeof(base))
                ds4ui_win32_chrome_candidate(chrome, sizeof(chrome), base, "Google\\Chrome\\Application\\chrome.exe");
        }
    }
    if (!chrome[0]) return;
    char profile[1024] = {0};
    DWORD pn = GetEnvironmentVariableA("LOCALAPPDATA", profile, sizeof(profile));
    if (pn <= 0 || pn >= sizeof(profile)) snprintf(profile, sizeof(profile), ".");
    size_t pl = strlen(profile);
    snprintf(profile + pl, sizeof(profile) - pl, "\\DStudio\\chrome-cdp");
    CreateDirectoryA(profile, NULL);

    char cmd[4096];
    snprintf(cmd, sizeof(cmd),
             "\"%s\" --remote-debugging-port=%d --user-data-dir=\"%s\" "
             "--no-first-run --no-default-browser-check about:blank",
             chrome, port, profile);
    STARTUPINFOA si;
    PROCESS_INFORMATION pi;
    memset(&si, 0, sizeof(si));
    memset(&pi, 0, sizeof(pi));
    si.cb = sizeof(si);
    if (CreateProcessA(NULL, cmd, NULL, NULL, FALSE, CREATE_NO_WINDOW, NULL, NULL, &si, &pi)) {
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        Sleep(250);
    }
}
#endif

static int ds4ui_remote_web_confirm(void *privdata, const char *message, char *err, size_t err_len) {
    (void)privdata;
    (void)message;
    if (err && err_len) err[0] = '\0';
    return 1;
}

static void ds4ui_remote_web_log(void *privdata, const char *message) {
    agent_worker *w = privdata;
    if (w && message && message[0]) agent_trace(w, "remote web: %s", message);
}

static bool ds4ui_remote_web_cancel(void *privdata) {
    return worker_should_interrupt(privdata);
}

static int ds4ui_remote_worker_init(agent_worker *w, agent_config *cfg) {
    memset(w, 0, sizeof(*w));
    w->engine = NULL;
    w->cfg = cfg;
    w->wake_fd[0] = -1;
    w->wake_fd[1] = -1;
    pthread_mutex_init(&w->mu, NULL);
    pthread_cond_init(&w->cond, NULL);
    w->status.state = AGENT_WORKER_IDLE;
    w->status.ctx_size = cfg->gen.ctx_size;
    w->initialized = true;
    w->next_bash_job_id = 1;
    if (pipe(w->wake_fd) != 0) return -1;
    int old_flags;
    set_nonblock(w->wake_fd[0], true, &old_flags);
    set_nonblock(w->wake_fd[1], true, &old_flags);
    ds4_web_config web_cfg = {
        .home_dir = getenv("HOME"),
        .port = 9333,
        .confirm = ds4ui_remote_web_confirm,
        .confirm_privdata = w,
        .log = ds4ui_remote_web_log,
        .log_privdata = w,
        .cancel = ds4ui_remote_web_cancel,
        .cancel_privdata = w,
    };
#if defined(_WIN32) || defined(__MSYS__) || defined(__CYGWIN__)
    ds4ui_win32_ensure_chrome(9333);
#endif
    w->web = ds4_web_create(&web_cfg);
    if (cfg->gen.trace_path && cfg->gen.trace_path[0])
        w->trace = fopen(cfg->gen.trace_path, "ab");
    return 0;
}

static void ds4ui_remote_worker_free(agent_worker *w) {
    if (!w) return;
    agent_bash_jobs_free(w);
    ds4_web_free(w->web);
    free(w->out);
    free(w->cache_dir);
    free(w->sysprompt_path);
    free(w->session_title);
    free(w->legacy_session_path_to_delete);
    free(w->queued_user_drain_text);
    free(w->cmd_text);
    if (w->wake_fd[0] >= 0) close(w->wake_fd[0]);
    if (w->wake_fd[1] >= 0) close(w->wake_fd[1]);
    if (w->trace) fclose(w->trace);
    pthread_mutex_destroy(&w->mu);
    pthread_cond_destroy(&w->cond);
    memset(w, 0, sizeof(*w));
}

static void ds4ui_remote_flush(agent_worker *w) {
    char *out = NULL;
    size_t out_len = 0;
    worker_consume(w, &out, &out_len, NULL);
    if (out && out_len) {
        write_all(STDOUT_FILENO, out, out_len);
        fflush(stdout);
    }
    free(out);
    if (w->wake_fd[0] >= 0) drain_wake_fd(w->wake_fd[0]);
}

static int ds4ui_remote_think_level(const agent_config *cfg) {
    if (!cfg || cfg->gen.think_mode == DS4_THINK_NONE) return 0;
    return cfg->gen.think_mode == DS4_THINK_MAX ? 2 : 1;
}

static bool ds4ui_remote_think_control_value(const char *value, ds4_think_mode *out) {
    if (!value || !out) return false;
    if (!strcmp(value, "off") || !strcmp(value, "none") || !strcmp(value, "nothink")) {
        *out = DS4_THINK_NONE;
        return true;
    }
    if (!strcmp(value, "max") || !strcmp(value, "think-max")) {
        *out = DS4_THINK_MAX;
        return true;
    }
    if (!strcmp(value, "high") || !strcmp(value, "normal") ||
        !strcmp(value, "think") || !strcmp(value, "on")) {
        *out = DS4_THINK_HIGH;
        return true;
    }
    return false;
}

static bool ds4ui_remote_apply_control(agent_config *cfg, char *line) {
    bool changed = false;
    if (!cfg || !line) return false;
    for (;;) {
        if ((unsigned char)line[0] != 0x1e) break;
        char *nl = strchr(line, '\n');
        if (!nl) break;
        size_t frame_len = (size_t)(nl - line - 1);
        char *frame = line + 1;
        if (frame_len > 1024 ||
            !strstr(frame, "\"type\":\"control\"") ||
            !strstr(frame, "\"name\":\"think\"")) {
            break;
        }
        char *v = strstr(frame, "\"value\":\"");
        if (v) {
            v += 9;
            char value[32];
            size_t n = 0;
            while (v[n] && v[n] != '"' && n + 1 < sizeof(value)) {
                value[n] = v[n];
                n++;
            }
            value[n] = '\0';
            ds4_think_mode m;
            if (ds4ui_remote_think_control_value(value, &m)) {
                cfg->gen.think_mode = m;
                changed = true;
            }
        }
        memmove(line, nl + 1, strlen(nl + 1) + 1);
    }
    return changed;
}

static char *ds4ui_remote_system_prompt(agent_config *cfg) {
    char *tools = agent_build_tools_prompt();
    agent_buf b = {0};
    agent_buf_puts(&b, tools);
    free(tools);
    if (cfg->gen.system && cfg->gen.system[0]) {
        agent_buf_puts(&b, "\n\nAdditional system instructions:\n");
        agent_buf_puts(&b, cfg->gen.system);
        agent_buf_puts(&b, "\n");
    }
    char *mem = ds4ui_memory_read_md();
    if (mem && mem[0]) {
        agent_buf_puts(&b, "\n\nPROJECT MEMORY (runtime summary from MEMORY.MD):\n\n");
        agent_buf_puts(&b, mem);
        agent_buf_puts(&b, "\n");
    }
    free(mem);
    agent_buf_puts(&b,
        "\n\nRuntime note: you are running in DStudio LAN client mode. "
        "The model is hosted remotely, but all tools, filesystem paths, bash commands, "
        "web browser state, Agent workspace, and Design workspace are local to this client. "
        "Never assume host filesystem paths are available here unless the user provides them.\n");
    return agent_buf_take(&b);
}

/* Structured remote transcript. Unlike the opaque JSON buffer the remote path
 * used before, this is the single source of truth so a long run can drop old
 * turns as it approaches the remote model's context window (the cloud/API path
 * has no KV-side compaction). msg[0] is always the system prompt and is never
 * dropped. */
typedef struct { char *role; char *content; } ds4ui_msg;
typedef struct { ds4ui_msg *v; int n, cap; size_t content_bytes; } ds4ui_msg_list;

/* Keep the system message plus at least this many of the most recent messages
 * intact, so compaction never eats the live tool/answer context. */
#define DS4UI_REMOTE_KEEP_RECENT 8
/* Byte budget for the transcript content, ~3 bytes/token of the configured
 * context, which leaves headroom for reasoning and the response. */
#define DS4UI_REMOTE_CTX_BUDGET_BYTES(ctx) ((size_t)((ctx) > 0 ? (ctx) : 8192) * 3u)

static void ds4ui_msg_list_free(ds4ui_msg_list *m) {
    if (!m) return;
    for (int i = 0; i < m->n; i++) { free(m->v[i].role); free(m->v[i].content); }
    free(m->v);
    m->v = NULL; m->n = 0; m->cap = 0; m->content_bytes = 0;
}

static void ds4ui_msg_list_add(ds4ui_msg_list *m, const char *role, const char *content) {
    if (!m) return;
    if (m->n == m->cap) {
        int ncap = m->cap ? m->cap * 2 : 16;
        ds4ui_msg *nv = realloc(m->v, (size_t)ncap * sizeof(*nv));
        if (!nv) return;
        m->v = nv; m->cap = ncap;
    }
    m->v[m->n].role = xstrdup(role && role[0] ? role : "user");
    m->v[m->n].content = xstrdup(content ? content : "");
    m->content_bytes += strlen(m->v[m->n].content);
    m->n++;
}

static char *ds4ui_msg_list_snapshot(const ds4ui_msg_list *m) {
    dstudio_remote_buf out = {0};
    dstudio_remote_buf_puts(&out, "[");
    for (int i = 0; m && i < m->n; i++) {
        if (i) dstudio_remote_buf_puts(&out, ",");
        dstudio_remote_buf_puts(&out, "{\"role\":");
        dstudio_remote_json_string(&out, m->v[i].role);
        dstudio_remote_buf_puts(&out, ",\"content\":");
        dstudio_remote_json_string(&out, m->v[i].content);
        dstudio_remote_buf_puts(&out, "}");
    }
    dstudio_remote_buf_puts(&out, "]");
    return dstudio_remote_buf_take(&out);
}

/* Drop the oldest non-system messages until the transcript fits budget_bytes,
 * always keeping msg[0] and the last DS4UI_REMOTE_KEEP_RECENT messages. Pass
 * budget_bytes 0 to force a compaction down to that floor. */
static void ds4ui_msg_list_compact(ds4ui_msg_list *m, size_t budget_bytes, agent_worker *w) {
    if (!m) return;
    int dropped = 0;
    size_t freed = 0;
    while (m->content_bytes > budget_bytes && m->n > 1 + DS4UI_REMOTE_KEEP_RECENT) {
        size_t vlen = strlen(m->v[1].content);
        free(m->v[1].role);
        free(m->v[1].content);
        memmove(&m->v[1], &m->v[2], (size_t)(m->n - 2) * sizeof(*m->v));
        m->n--;
        m->content_bytes -= vlen;
        freed += vlen;
        dropped++;
    }
    if (dropped > 0)
        agent_publishf(w,
            "\n[context compaction: dropped %d old message(s), ~%zu bytes, "
            "to stay within the remote context window]\n",
            dropped, freed);
}

static void ds4ui_remote_messages_reset(ds4ui_msg_list *m, agent_config *cfg) {
    ds4ui_msg_list_free(m);
    char *sys = ds4ui_remote_system_prompt(cfg);
    ds4ui_msg_list_add(m, "system", sys);
    free(sys);
}

typedef struct {
    agent_worker *worker;
    agent_stream_renderer *stream;
    dstudio_remote_buf *raw;
    bool reasoning_open;
    double started_at;
    int generated;
} ds4ui_remote_stream_ctx;

#define DS4UI_REMOTE_AUTO_CONTINUES 3
/* Cap on consecutive INVALID tool calls in a single turn. The remote agent has
 * no context compaction, so an unbounded malformed-tool loop both spins forever
 * and grows the message list until the API rejects it. After this many invalid
 * tool calls we ask once for a plain-text answer, then stop. */
#define DS4UI_REMOTE_MAX_TOOL_ERRORS 4

static bool ds4ui_remote_retryable_model_error(const char *err) {
    if (!err || !err[0]) return false;
    return strstr(err, "stream ended before completion") ||
           strstr(err, "ended before data: [DONE]") ||
           strstr(err, "internal model stream ended before completion") ||
           strstr(err, "Connection interrupted") ||
           strstr(err, "connection interrupted");
}

static char *ds4ui_remote_continue_prompt(const agent_dsml_parser *dsml,
                                          const char *err,
                                          int attempt,
                                          int max_attempts) {
    agent_buf b = {0};
    agent_buf_puts(&b,
        "DStudio transport recovery: the previous assistant response was interrupted before the model stream completed.\n");
    if (err && err[0]) {
        agent_buf_puts(&b, "Technical reason: ");
        agent_buf_puts(&b, err);
        agent_buf_puts(&b, "\n");
    }
    char nbuf[96];
    snprintf(nbuf, sizeof(nbuf), "Automatic continuation attempt %d of %d.\n", attempt, max_attempts);
    agent_buf_puts(&b, nbuf);
    if (dsml && (dsml->state == AGENT_DSML_STRUCTURAL ||
                 dsml->state == AGENT_DSML_PARAM_VALUE ||
                 dsml->state == AGENT_DSML_ERROR)) {
        agent_buf_puts(&b,
            "Your prior output was cut off while forming a DSML tool call. "
            "Do not continue the broken fragment. Re-emit the full intended DSML tool call from the beginning, "
            "with complete parameters and no extra prose before it.\n");
    } else {
        agent_buf_puts(&b,
            "Continue exactly where the previous assistant message stopped. "
            "Do not repeat completed text. If the previous message was already complete, add only the missing final sentence or final action, then stop.\n");
    }
    return agent_buf_take(&b);
}

static void ds4ui_remote_chunk(void *ud, const char *kind, const char *text, size_t len) {
    ds4ui_remote_stream_ctx *ctx = ud;
    if (!ctx || !text || !len) return;
    agent_worker *w = ctx->worker;
    if (kind && !strcmp(kind, "reasoning")) {
        if (!ctx->reasoning_open) {
            ds4ui_emit_event(w, "reasoning_start");
            ctx->reasoning_open = true;
        }
        agent_publish(w, text, len);
        ds4ui_remote_flush(w);
        return;
    }
    if (ctx->reasoning_open) {
        ds4ui_emit_event(w, "reasoning_end");
        ctx->reasoning_open = false;
    }
    if (ctx->stream && ctx->stream->in_think) {
        static const char close_think[] = "</think>\n\n";
        dstudio_remote_buf_append(ctx->raw, close_think, sizeof(close_think) - 1);
        agent_stream_text(ctx->stream, close_think, sizeof(close_think) - 1, false);
        ctx->stream->in_think = false;
        ctx->stream->dsml_in_think = false;
    }
    dstudio_remote_buf_append(ctx->raw, text, len);
    agent_stream_text(ctx->stream, text, len, false);
    ctx->generated++;
    double dt = now_sec() - ctx->started_at;
    pthread_mutex_lock(&w->mu);
    w->status.generated = ctx->generated;
    w->status.gen_tps = dt > 0.0 ? (double)ctx->generated / dt : 0.0;
    agent_wake_locked(w);
    pthread_mutex_unlock(&w->mu);
    ds4ui_remote_flush(w);
}

static char *ds4ui_remote_tool_result(agent_worker *w,
                                      agent_stream_renderer *stream,
                                      agent_dsml_parser *dsml) {
    if (stream->tool_preflight_error) {
        agent_buf b = {0};
        agent_buf_puts(&b, "Tool error: ");
        agent_buf_puts(&b, stream->tool_preflight_error_msg[0] ?
                       stream->tool_preflight_error_msg :
                       "tool preflight failed");
        agent_buf_puts(&b, "\n");
        return agent_buf_take(&b);
    }
    if (stream->dsml_in_think) {
        agent_buf b = {0};
        agent_buf_puts(&b, "Tool error: invalid DSML tool call: tool calling is not allowed inside <think></think>\n");
        agent_buf_puts(&b, agent_dsml_syntax_reminder);
        return agent_buf_take(&b);
    }
    if (dsml->state == AGENT_DSML_ERROR) {
        agent_buf b = {0};
        agent_buf_puts(&b, "Tool error: invalid DSML tool call: ");
        agent_buf_puts(&b, dsml->error[0] ? dsml->error : "parse error");
        agent_buf_puts(&b, "\n");
        agent_buf_puts(&b, agent_dsml_syntax_reminder);
        return agent_buf_take(&b);
    }
    if (dsml->state == AGENT_DSML_STRUCTURAL || dsml->state == AGENT_DSML_PARAM_VALUE) {
        agent_buf b = {0};
        agent_buf_puts(&b, "Tool error: invalid DSML tool call: incomplete DSML tool call\n");
        agent_buf_puts(&b, agent_dsml_syntax_reminder);
        return agent_buf_take(&b);
    }
    if (dsml->state == AGENT_DSML_DONE) return agent_execute_tool_calls(w, &dsml->calls);
    return NULL;
}

static int ds4ui_remote_run_turn(agent_worker *w,
                                 ds4ui_msg_list *msgs,
                                 const char *user_text) {
    agent_config *cfg = w->cfg;
    ds4ui_msg_list_add(msgs, "user", user_text ? user_text : "");
    if (!w->session_title) {
        w->session_title = agent_session_title_from_prompt(user_text, 0);
        w->session_created_at = (uint64_t)time(NULL);
        agent_session_identity_sha(w->session_title, w->session_created_at,
                                   w->session_sha);
    }
    pthread_mutex_lock(&w->mu);
    w->user_activity = true;
    w->status.error[0] = '\0';
    agent_wake_locked(w);
    pthread_mutex_unlock(&w->mu);

    int auto_continues = 0;
    int tool_error_streak = 0;
    bool forced_plain = false;
    for (;;) {
        bool think_enabled = cfg->gen.think_mode != DS4_THINK_NONE;
        bool use_color = isatty(STDOUT_FILENO) != 0;
        agent_token_renderer renderer = {
            .engine = NULL,
            .worker = w,
            .format_thinking = think_enabled,
            .format_markdown = use_color,
            .in_think = false,
            .use_color = use_color,
            .last_output_newline = true,
        };
        agent_dsml_parser dsml = {.state = AGENT_DSML_SEARCH};
        agent_stream_renderer stream = {
            .renderer = &renderer,
            .parser = &dsml,
            .in_think = false,
        };
        dstudio_remote_buf raw = {0};
        ds4ui_remote_stream_ctx sctx = {
            .worker = w,
            .stream = &stream,
            .raw = &raw,
            .started_at = now_sec(),
        };
        ds4ui_msg_list_compact(msgs, DS4UI_REMOTE_CTX_BUDGET_BYTES(cfg->gen.ctx_size), w);
        char *snapshot = ds4ui_msg_list_snapshot(msgs);
        char err[512] = {0};

        pthread_mutex_lock(&w->mu);
        w->status.state = AGENT_WORKER_GENERATING;
        w->status.generated = 0;
        w->status.gen_tps = 0.0;
        w->status.greedy_sampling = false;
        agent_wake_locked(w);
        pthread_mutex_unlock(&w->mu);

        int rc = dstudio_remote_chat_stream(
            cfg->remote_base_url,
            cfg->remote_model && cfg->remote_model[0] ? cfg->remote_model : "ds4",
            snapshot,
            ds4ui_remote_think_level(cfg),
            cfg->gen.temperature,
            cfg->gen.top_p,
            cfg->gen.min_p,
            cfg->gen.n_predict,
            ds4ui_remote_chunk,
            &sctx,
            err,
            sizeof(err));
        free(snapshot);
        if (sctx.reasoning_open) ds4ui_emit_event(w, "reasoning_end");
        agent_stream_text(&stream, NULL, 0, true);
        renderer_finish(&renderer);
        ds4ui_remote_flush(w);

        char *assistant_raw = dstudio_remote_buf_take(&raw);
        if (assistant_raw && assistant_raw[0])
            ds4ui_msg_list_add(msgs, "assistant", assistant_raw);

        if (rc != 0) {
            if (ds4ui_remote_retryable_model_error(err) &&
                auto_continues < DS4UI_REMOTE_AUTO_CONTINUES) {
                auto_continues++;
                char *cont = ds4ui_remote_continue_prompt(&dsml, err,
                    auto_continues, DS4UI_REMOTE_AUTO_CONTINUES);
                ds4ui_msg_list_add(msgs, "user", cont);
                free(cont);
                agent_publishf(w,
                    "\x1e{\"type\":\"model_retry\",\"attempt\":%d,\"max\":%d}\n",
                    auto_continues, DS4UI_REMOTE_AUTO_CONTINUES);
                free(assistant_raw);
                agent_dsml_parser_free(&dsml);
                ds4ui_remote_flush(w);
                continue;
            }
            agent_publishf(w, "\nRemote model failed after automatic recovery: %s\n", err[0] ? err : "request failed");
            free(assistant_raw);
            agent_dsml_parser_free(&dsml);
            agent_set_error(w, err[0] ? err : "remote model request failed");
            agent_set_status(w, AGENT_WORKER_IDLE);
            ds4ui_remote_flush(w);
            return 0;
        }

        char *tool_result = ds4ui_remote_tool_result(w, &stream, &dsml);
        free(assistant_raw);
        if (!tool_result) {
            agent_dsml_parser_free(&dsml);
            agent_set_status(w, AGENT_WORKER_IDLE);
            ds4ui_remote_flush(w);
            return 0;
        }
        /* A non-NULL result is either a real tool execution (state DONE) or a
         * tool error string; only the clean DONE path counts as success. */
        bool tool_errored = dsml.state != AGENT_DSML_DONE ||
                            stream.tool_preflight_error || stream.dsml_in_think;
        if (cfg->remote_base_url && strncmp(cfg->remote_base_url, "https://", 8) == 0) {
            /* Cloud OpenAI-compatible APIs require tool_call_id for role
             * "tool" messages, but ds4's tool protocol is textual: ship the
             * result as a plainly marked user message instead. */
            dstudio_remote_buf tr = {0};
            dstudio_remote_buf_puts(&tr, "[tool result]\n");
            dstudio_remote_buf_puts(&tr, tool_result);
            char *wrapped = dstudio_remote_buf_take(&tr);
            ds4ui_msg_list_add(msgs, "user", wrapped);
            free(wrapped);
        } else {
            ds4ui_msg_list_add(msgs, "tool", tool_result);
        }
        free(tool_result);

        if (tool_errored) {
            if (++tool_error_streak >= DS4UI_REMOTE_MAX_TOOL_ERRORS) {
                if (!forced_plain) {
                    /* One firm nudge: keep the transcript, drop the tool loop. */
                    forced_plain = true;
                    tool_error_streak = 0;
                    ds4ui_msg_list_add(msgs, "user",
                        "Stop calling tools: your last several tool calls were invalid. "
                        "Do not attempt any more tool calls. Give your final answer now as "
                        "plain text only.");
                    agent_publishf(w,
                        "\n[too many invalid tool calls \xE2\x80\x94 requesting a plain-text answer]\n");
                } else {
                    /* Still failing after the nudge: stop so the turn cannot spin
                     * or grow the message list past the remote context window. */
                    agent_publishf(w,
                        "\n[stopping this turn after repeated invalid tool calls]\n");
                    agent_dsml_parser_free(&dsml);
                    agent_set_status(w, AGENT_WORKER_IDLE);
                    ds4ui_remote_flush(w);
                    return 0;
                }
            }
        } else {
            tool_error_streak = 0;
        }
        agent_dsml_parser_free(&dsml);
    }
}

static bool ds4ui_remote_handle_slash(agent_worker *w,
                                      ds4ui_msg_list *msgs,
                                      const char *line) {
    char cmd[256];
    ds4ui_slash_trim(line, cmd, sizeof(cmd));
    if (cmd[0] != '/') return false;
    if (!strcmp(cmd, "/new")) {
        ds4ui_remote_messages_reset(msgs, w->cfg);
        free(w->session_title);
        w->session_title = NULL;
        w->session_sha[0] = '\0';
        printf("new remote-model session started (workspace stays local)\n");
    } else if (!strcmp(cmd, "/compact")) {
        ds4ui_msg_list_compact(msgs, 0, w);   /* force down to system + recent turns */
        printf("compacted remote transcript (kept the system prompt and the most recent turns)\n");
    } else if (!strcmp(cmd, "/help")) {
        printf("commands: /new /compact /help. KV session save/list/switch are host-side in LAN remote-model mode.\n");
    } else if (!strcmp(cmd, "/save") || !strcmp(cmd, "/list") ||
               agent_slash_command_with_args(cmd, "/switch") ||
               agent_slash_command_with_args(cmd, "/del")) {
        printf("remote-model mode keeps the live KV on the LAN host; this local agent does not manage host KV sessions. Use /new to reset this local transcript.\n");
    } else {
        return false;
    }
    fflush(stdout);
    return true;
}

static int ds4ui_run_remote_agent(agent_config *cfg) {
    if (!cfg->non_interactive) {
        fprintf(stderr, "ds4-agent: --remote-base-url requires --non-interactive\n");
        return 2;
    }
    agent_worker worker;
    if (ds4ui_remote_worker_init(&worker, cfg) != 0) {
        fprintf(stderr, "ds4-agent: failed to initialize remote worker\n");
        return 1;
    }
    ds4ui_msg_list messages = {0};
    ds4ui_remote_messages_reset(&messages, cfg);

    struct sigaction old_int;
    struct sigaction sa;
    memset(&sa, 0, sizeof(sa));
    sigemptyset(&sa.sa_mask);
    sa.sa_handler = agent_sigint_handler;
    bool sigint_installed = sigaction(SIGINT, &sa, &old_int) == 0;

    const bool one_shot = cfg->gen.prompt != NULL;
    int rc = 0;
    if (one_shot) {
        rc = ds4ui_remote_run_turn(&worker, &messages, cfg->gen.prompt);
    } else {
        bool stdin_eof = false;
        bool waiting_announced = false;
        bool stdin_nonblock = false;
        int old_stdin_flags = 0;
        agent_input_buf input = {0};
        double quiet_deadline = 0.0;
        if (set_nonblock(STDIN_FILENO, true, &old_stdin_flags) != 0) {
            perror("ds4-agent: nonblocking stdin");
            rc = 1;
        } else {
            stdin_nonblock = true;
        }
        while (rc == 0 && !stdin_eof) {
            if (agent_sigint) {
                agent_sigint = 0;
                worker_interrupt(&worker);
                agent_set_status(&worker, AGENT_WORKER_IDLE);
            }
            if (input.len == 0 && !waiting_announced) {
                agent_noninteractive_marker("+DWARFSTAR_WAITING");
                waiting_announced = true;
            }
            int timeout_ms = -1;
            if (input.len > 0) {
                double rem = quiet_deadline - now_sec();
                timeout_ms = rem <= 0.0 ? 0 : (int)(rem * 1000.0) + 1;
            }
            struct pollfd pfd = {.fd = STDIN_FILENO, .events = POLLIN};
            int prc = poll(&pfd, 1, timeout_ms);
            if (prc < 0) {
                if (errno == EINTR) continue;
                perror("ds4-agent: poll");
                rc = 1;
                break;
            }
            if (prc > 0 && (pfd.revents & (POLLIN | POLLHUP))) {
                size_t old_len = input.len;
                if (agent_read_stdin_available(&input, &stdin_eof) != 0) {
                    rc = 1;
                    break;
                }
                if (input.len != old_len) {
                    quiet_deadline = now_sec() + 0.200;
                    waiting_announced = false;
                }
            }
            if (input.len > 0 && (stdin_eof || now_sec() >= quiet_deadline)) {
                char *prompt = agent_input_buf_take(&input);
                ds4ui_remote_apply_control(cfg, prompt);
                if (prompt[0] && (!ds4ui_pipe_slash(prompt) ||
                    !ds4ui_remote_handle_slash(&worker, &messages, prompt)))
                    rc = ds4ui_remote_run_turn(&worker, &messages, prompt);
                free(prompt);
                waiting_announced = false;
            }
            ds4ui_remote_flush(&worker);
        }
        if (stdin_nonblock) fcntl(STDIN_FILENO, F_SETFL, old_stdin_flags);
        agent_input_buf_free(&input);
    }

    if (sigint_installed) sigaction(SIGINT, &old_int, NULL);
    ds4ui_msg_list_free(&messages);
    ds4ui_remote_worker_free(&worker);
    return rc;
}
