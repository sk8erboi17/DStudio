static void ds4ui_emit_question(agent_worker *w, const char *id, const char *title, const char *questions_json) {
    char iid[256], ttl[512];
    ds4ui_json_escape(id ? id : "question", iid, sizeof iid);
    ds4ui_json_escape(title ? title : "Question", ttl, sizeof ttl);
    const char *q = (questions_json && questions_json[0]) ? questions_json : "[]";
    size_t ql = strlen(q), cap = ql + 1024;
    char *line = (char *)malloc(cap);
    if (!line) return;
    int k = snprintf(line, cap, "\x1e{\"type\":\"question\",\"id\":\"%s\",\"title\":\"%s\",\"questions\":", iid, ttl);
    for (; *q && k + 2 < (int)cap; q++) {
        char c = *q;
        if (c == '\n' || c == '\r' || c == '\x1e') c = ' ';
        line[k++] = c;
    }
    k += snprintf(line + k, cap - (size_t)k, "}\n");
    agent_publish(w, line, (size_t)k);
    free(line);
}
