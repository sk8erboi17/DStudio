diff --git a/ds4_server.c b/ds4_server.c
--- a/ds4_server.c
+++ b/ds4_server.c
@@ -12286,6 +12286,46 @@ typedef struct {
     int fd;
 } client_arg;
 
+static bool client_peer_is_loopback(int fd) {
+    struct sockaddr_storage ss;
+    socklen_t n = sizeof ss;
+    memset(&ss, 0, sizeof ss);
+    if (getpeername(fd, (struct sockaddr *)&ss, &n) != 0) return false;
+    if (ss.ss_family == AF_INET) {
+        const struct sockaddr_in *a = (const struct sockaddr_in *)&ss;
+        return (ntohl(a->sin_addr.s_addr) >> 24) == 127;
+    }
+#ifdef AF_INET6
+    if (ss.ss_family == AF_INET6) {
+        const struct sockaddr_in6 *a = (const struct sockaddr_in6 *)&ss;
+        return IN6_IS_ADDR_LOOPBACK(&a->sin6_addr);
+    }
+#endif
+    return false;
+}
+
+static void send_memory_pressure(server *s, int fd, bool begin) {
+    uint64_t advised = 0;
+    int rc;
+    /* All backend work and residency changes must be between inference calls. */
+    pthread_mutex_lock(&s->inference_mu);
+    rc = begin ? ds4_engine_memory_pressure_begin(s->engine, &advised)
+               : ds4_engine_memory_pressure_end(s->engine);
+    unsigned depth = ds4_engine_memory_pressure_depth(s->engine);
+    pthread_mutex_unlock(&s->inference_mu);
+
+    buf b = {0};
+    buf_printf(&b,
+               "{\"ok\":%s,\"active\":%s,\"depth\":%u,"
+               "\"backend\":\"%s\",\"advisedBytes\":%llu}\n",
+               rc == 0 ? "true" : "false", depth ? "true" : "false",
+               depth, ds4_engine_backend_name(s->engine),
+               (unsigned long long)advised);
+    http_response(fd, s->enable_cors, rc == 0 ? 200 : 409,
+                  "application/json", b.ptr);
+    buf_free(&b);
+}
