+int ds4_gpu_memory_pressure_begin(void) {
+    if (!g_initialized && !ds4_gpu_init()) return 0;
+    if (!ds4_gpu_synchronize()) return 0;
+    ds4_gpu_model_residency_clear();
+    ds4_gpu_stream_expert_cache_clear_all(1);
+    fprintf(stderr, "ds4: Metal model residency suspended for Qwen\n");
+    return 1;
+}
+
+int ds4_gpu_memory_pressure_end(void) {
+    if (!g_initialized) return 1;
+    if (!ds4_gpu_model_residency_request_views()) return 0;
+    fprintf(stderr, "ds4: Metal model residency restored after Qwen\n");
+    return 1;
+}
