+static uint64_t ds4_model_memory_dontneed(ds4_model *m) {
+#if defined(POSIX_MADV_DONTNEED)
+    if (!m || !m->map || m->size == 0 || m->size > (uint64_t)SIZE_MAX) return 0;
+    const int rc = posix_madvise((void *)m->map, (size_t)m->size,
+                                 POSIX_MADV_DONTNEED);
+    return rc == 0 ? m->size : 0;
+#else
+    (void)m;
+    return 0;
+#endif
+}
+
+int ds4_engine_memory_pressure_begin(ds4_engine *e, uint64_t *advised_bytes) {
+    if (advised_bytes) *advised_bytes = 0;
+    if (!e) return 1;
+    if (e->memory_pressure_depth++ != 0) {
+        if (advised_bytes) *advised_bytes = e->memory_pressure_advised_bytes;
+        return 0;
+    }
+#ifndef DS4_NO_GPU
+    if (e->backend != DS4_BACKEND_CPU && !ds4_gpu_memory_pressure_begin()) {
+        e->memory_pressure_depth = 0;
+        return 1;
+    }
+#endif
+    uint64_t total = ds4_model_memory_dontneed(&e->model);
+    uint64_t support = ds4_model_memory_dontneed(&e->mtp_model);
+    total = UINT64_MAX - total < support ? UINT64_MAX : total + support;
+    e->memory_pressure_advised_bytes = total;
+    if (advised_bytes) *advised_bytes = total;
+    fprintf(stderr,
+            "ds4: temporary Qwen memory pressure active backend=%s advised=%.2f GiB configured_ssd_streaming=%s\n",
+            ds4_backend_name(e->backend), (double)total / 1073741824.0,
+            e->ssd_streaming ? "on" : "off");
+    return 0;
+}
+
+int ds4_engine_memory_pressure_end(ds4_engine *e) {
+    if (!e || e->memory_pressure_depth == 0) return 1;
+    if (--e->memory_pressure_depth != 0) return 0;
+#ifndef DS4_NO_GPU
+    if (e->backend != DS4_BACKEND_CPU && !ds4_gpu_memory_pressure_end()) return 1;
+#endif
+    e->memory_pressure_advised_bytes = 0;
+    fprintf(stderr,
+            "ds4: temporary Qwen memory pressure released backend=%s configured_ssd_streaming=%s\n",
+            ds4_backend_name(e->backend), e->ssd_streaming ? "on" : "off");
+    return 0;
+}
+
+unsigned ds4_engine_memory_pressure_depth(ds4_engine *e) {
+    return e ? e->memory_pressure_depth : 0;
+}
+
+const char *ds4_engine_backend_name(ds4_engine *e) {
+    return e ? ds4_backend_name(e->backend) : "unknown";
+}
+
 const char *ds4_engine_model_name(ds4_engine *e) {
     (void)e;
     return DS4_MODEL_SHAPE_NAME;
