{
  "service": "api-access-boundary",
  "routes": [
    {
      "path": "/api/api_access_boundary/summary",
      "auth": "session",
      "role_required": "viewer"
    },
    {
      "path": "/api/api_access_boundary/export",
      "auth": "session",
      "role_required": "admin"
