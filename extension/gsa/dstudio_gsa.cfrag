static void gsa_tools_dir(char *out, size_t outsz) {
#ifdef _WIN32
    snprintf(out, outsz, "%s\\extension\\gsa\\tools\\bin", g_web_dir[0] ? g_web_dir : ".");
#else
    snprintf(out, outsz, "%s/extension/gsa/tools/bin", g_web_dir[0] ? g_web_dir : ".");
#endif
}

static void gsa_nuclei_templates_dir(char *out, size_t outsz) {
#ifdef _WIN32
    snprintf(out, outsz, "%s\\extension\\gsa\\tools\\nuclei-templates", g_web_dir[0] ? g_web_dir : ".");
#else
    snprintf(out, outsz, "%s/extension/gsa/tools/nuclei-templates", g_web_dir[0] ? g_web_dir : ".");
#endif
}

static int gsa_nuclei_templates_marker_dir(const char *base) {
    if (!base || !base[0]) return 0;
    struct stat st;
    if (stat(base, &st) != 0 || !S_ISDIR(st.st_mode)) return 0;
    static const char *markers[] = { "http", "dns", "ssl", "file", "javascript", "workflows", NULL };
    for (int i = 0; markers[i]; i++) {
        char path[PATH_MAX];
#ifdef _WIN32
        snprintf(path, sizeof path, "%s\\%s", base, markers[i]);
#else
        snprintf(path, sizeof path, "%s/%s", base, markers[i]);
#endif
        if (stat(path, &st) == 0 && S_ISDIR(st.st_mode)) return 1;
    }
    return 0;
}

static int gsa_nuclei_templates_found(void) {
    char dir[1200];
    gsa_nuclei_templates_dir(dir, sizeof dir);
    if (gsa_nuclei_templates_marker_dir(dir)) return 1;
    char nested[1400];
#ifdef _WIN32
    snprintf(nested, sizeof nested, "%s\\nuclei-templates", dir);
#else
    snprintf(nested, sizeof nested, "%s/nuclei-templates", dir);
#endif
    return gsa_nuclei_templates_marker_dir(nested);
}

/* ---- GSA: guided security analysis pipeline ----------------------------------
 * GSA is intentionally file-backed and task-tracked. The API prepares bounded,
 * deterministic inputs and phase prompts; the Agent still performs the analysis
 * in the chosen workspace. That keeps failures visible and resumable. */

static int setup_run_cmd_capture(const char *cwd, char *const argv[], char *out, size_t outsz);
static void setup_capture_append(char *out, size_t *used, size_t outsz, const char *buf, size_t n);
static int gsa_state_string_field(const char *run_dir, const char *field, char *out, size_t outsz);

static int str_eq_ci_ascii(const char *a, const char *b) {
    if (!a || !b) return 0;
    while (*a && *b) {
        if (!ascii_eq_ci(*a, *b)) return 0;
        a++; b++;
    }
    return *a == '\0' && *b == '\0';
}

typedef struct {
    const char *name;
    const char *category;
    const char *aliases;   /* pipe-separated commands; first is preferred */
    const char *install;
    const char *notes;
} gsa_tool_spec;

typedef struct {
    gsa_tool_spec *items;
    size_t count;
} gsa_tool_catalog;

static int gsa_extension_path(char *out, size_t outsz, const char *rel) {
    if (!out || !outsz || !rel || !rel[0]) return 0;
#ifdef _WIN32
    return (size_t)snprintf(out, outsz, "%s\\extension\\gsa\\%s", g_web_dir[0] ? g_web_dir : ".", rel) < outsz;
#else
    return (size_t)snprintf(out, outsz, "%s/extension/gsa/%s", g_web_dir[0] ? g_web_dir : ".", rel) < outsz;
#endif
}

static const char *gsa_find_json_object_end(const char *p) {
    if (!p || *p != '{') return NULL;
    int depth = 0, in_str = 0, esc = 0;
    for (; *p; p++) {
        if (in_str) {
            if (esc) esc = 0;
            else if (*p == '\\') esc = 1;
            else if (*p == '"') in_str = 0;
            continue;
        }
        if (*p == '"') in_str = 1;
        else if (*p == '{') depth++;
        else if (*p == '}' && --depth == 0) return p + 1;
    }
    return NULL;
}

static int gsa_json_object_string(const char *obj, const char *end,
                                  const char *key, char *out, size_t outsz) {
    if (out && outsz) out[0] = '\0';
    if (!obj || !end || !key || !out || !outsz) return 0;
    char pat[96];
    snprintf(pat, sizeof pat, "\"%s\"", key);
    const char *p = obj;
    while ((p = strstr(p, pat)) && p < end) {
        p += strlen(pat);
        while (p < end && isspace((unsigned char)*p)) p++;
        if (p >= end || *p != ':') continue;
        p++;
        while (p < end && isspace((unsigned char)*p)) p++;
        if (p >= end || *p != '"') continue;
        p++;
        size_t o = 0;
        while (p < end && *p) {
            if (*p == '"') { out[o] = '\0'; return 1; }
            if (*p == '\\' && p + 1 < end) {
                p++;
                char c = *p;
                if (c == 'n') c = '\n';
                else if (c == 'r') c = '\r';
                else if (c == 't') c = '\t';
                if (o + 1 >= outsz) return 0;
                out[o++] = c;
                p++;
                continue;
            }
            if (o + 1 >= outsz) return 0;
            out[o++] = *p++;
        }
        return 0;
    }
    return 0;
}

static void gsa_tool_catalog_free(gsa_tool_catalog *cat) {
    if (!cat) return;
    for (size_t i = 0; i < cat->count; i++) {
        free((char *)cat->items[i].name);
        free((char *)cat->items[i].category);
        free((char *)cat->items[i].aliases);
        free((char *)cat->items[i].install);
        free((char *)cat->items[i].notes);
    }
    free(cat->items);
    cat->items = NULL;
    cat->count = 0;
}

static int gsa_tool_catalog_add(gsa_tool_catalog *cat,
                                const char *name, const char *category,
                                const char *aliases, const char *install,
                                const char *notes) {
    gsa_tool_spec *next = (gsa_tool_spec *)realloc(cat->items, (cat->count + 1) * sizeof cat->items[0]);
    if (!next) return 0;
    cat->items = next;
    gsa_tool_spec *t = &cat->items[cat->count];
    memset(t, 0, sizeof *t);
    t->name = ds4_strdup_local(name);
    t->category = ds4_strdup_local(category);
    t->aliases = ds4_strdup_local(aliases);
    t->install = ds4_strdup_local(install);
    t->notes = ds4_strdup_local(notes);
    if (!t->name || !t->category || !t->aliases || !t->install || !t->notes) {
        free((char *)t->name);
        free((char *)t->category);
        free((char *)t->aliases);
        free((char *)t->install);
        free((char *)t->notes);
        memset(t, 0, sizeof *t);
        return 0;
    }
    cat->count++;
    return 1;
}

static int gsa_load_tool_catalog(gsa_tool_catalog *cat, char *err, size_t errsz) {
    if (!cat) return 0;
    memset(cat, 0, sizeof *cat);
    char path[PATH_MAX];
    if (!gsa_extension_path(path, sizeof path, "tools/catalog.json")) {
        snprintf(err, errsz, "could not resolve GSA tool catalog path");
        return 0;
    }
    size_t len = 0;
    char *body = jsonl_read_file(path, &len);
    if (!body) {
        snprintf(err, errsz, "GSA tool catalog missing: %s", path);
        return 0;
    }
    const char *tools = strstr(body, "\"tools\"");
    const char *arr = tools ? strchr(tools, '[') : NULL;
    const char *arr_end = arr ? strrchr(arr, ']') : NULL;
    if (!arr || !arr_end || arr_end <= arr) {
        snprintf(err, errsz, "GSA tool catalog malformed: tools array missing");
        free(body);
        return 0;
    }
    const char *p = arr + 1;
    while ((p = strchr(p, '{')) && p < arr_end) {
        const char *obj_end = gsa_find_json_object_end(p);
        if (!obj_end || obj_end > arr_end) {
            snprintf(err, errsz, "GSA tool catalog malformed: unterminated tool object");
            free(body);
            gsa_tool_catalog_free(cat);
            return 0;
        }
        char name[96], category[160], aliases[512], install[700], notes[700];
        if (!gsa_json_object_string(p, obj_end, "name", name, sizeof name) ||
            !gsa_json_object_string(p, obj_end, "category", category, sizeof category) ||
            !gsa_json_object_string(p, obj_end, "aliases", aliases, sizeof aliases) ||
            !gsa_json_object_string(p, obj_end, "install", install, sizeof install) ||
            !gsa_json_object_string(p, obj_end, "notes", notes, sizeof notes) ||
            !gsa_tool_catalog_add(cat, name, category, aliases, install, notes))
        {
            snprintf(err, errsz, "GSA tool catalog malformed or out of memory near offset %ld", (long)(p - body));
            free(body);
            gsa_tool_catalog_free(cat);
            return 0;
        }
        p = obj_end;
    }
    free(body);
    if (cat->count == 0) {
        snprintf(err, errsz, "GSA tool catalog contains no tools");
        return 0;
    }
    return 1;
}

typedef struct {
    const char *key;
    const char *value;
} gsa_template_var;

static const char *gsa_template_lookup(const gsa_template_var *vars, const char *key, size_t key_len) {
    if (!vars || !key) return NULL;
    for (size_t i = 0; vars[i].key; i++) {
        if (strlen(vars[i].key) == key_len && !strncmp(vars[i].key, key, key_len))
            return vars[i].value ? vars[i].value : "";
    }
    return NULL;
}

static char *gsa_render_template(const char *rel, const gsa_template_var *vars,
                                 char *err, size_t errsz) {
    char path[PATH_MAX];
    if (!gsa_extension_path(path, sizeof path, rel)) {
        snprintf(err, errsz, "could not resolve GSA template path: %s", rel ? rel : "(null)");
        return NULL;
    }
    size_t len = 0;
    char *tmpl = jsonl_read_file(path, &len);
    if (!tmpl) {
        snprintf(err, errsz, "GSA template missing: %s", path);
        return NULL;
    }
    json_dyn_buf out = {0};
    const char *p = tmpl;
    while (*p) {
        const char *open = strstr(p, "{{");
        if (!open) {
            if (!json_dyn_puts(&out, p)) goto oom;
            break;
        }
        if (!json_dyn_putn(&out, p, (size_t)(open - p))) goto oom;
        const char *close = strstr(open + 2, "}}");
        if (!close) {
            snprintf(err, errsz, "GSA template malformed, missing }} in %s", rel);
            free(tmpl);
            free(out.ptr);
            return NULL;
        }
        const char *value = gsa_template_lookup(vars, open + 2, (size_t)(close - (open + 2)));
        if (!value) {
            char key[120];
            size_t n = (size_t)(close - (open + 2));
            if (n >= sizeof key) n = sizeof key - 1;
            memcpy(key, open + 2, n);
            key[n] = '\0';
            snprintf(err, errsz, "GSA template %s references unknown token %s", rel, key);
            free(tmpl);
            free(out.ptr);
            return NULL;
        }
        if (!json_dyn_puts(&out, value)) goto oom;
        p = close + 2;
    }
    free(tmpl);
    return out.ptr ? out.ptr : ds4_strdup_local("");
oom:
    snprintf(err, errsz, "out of memory rendering GSA template %s", rel);
    free(tmpl);
    free(out.ptr);
    return NULL;
}

static int gsa_write_tool_retry_artifacts(const char *run_dir, char *err, size_t errsz) {
    char policy[PATH_MAX], ledger[PATH_MAX];
    snprintf(policy, sizeof policy, "%s/tool-retry-policy.md", run_dir);
    snprintf(ledger, sizeof ledger, "%s/tool-retry-ledger.jsonl", run_dir);
    static const gsa_template_var no_vars[] = { { NULL, NULL } };
    char *policy_md = gsa_render_template("templates/tool-retry-policy.md", no_vars, err, errsz);
    if (!policy_md) return 0;
    if (!jsonl_write_file(policy, policy_md, strlen(policy_md))) {
        snprintf(err, errsz, "could not write tool retry policy: %s", strerror(errno));
        free(policy_md);
        return 0;
    }
    free(policy_md);
    if (!jsonl_write_file(ledger, "", 0)) {
        snprintf(err, errsz, "could not write tool retry ledger: %s", strerror(errno));
        return 0;
    }
    return 1;
}

static const char *gsa_security_profile_normalize(const char *profile) {
    if (!profile || !profile[0]) return "passive";
    if (!strcmp(profile, "passive")) return "passive";
    if (!strcmp(profile, "blue")) return "blue";
    if (!strcmp(profile, "red-authorized")) return "red-authorized";
    if (!strcmp(profile, "purple")) return "purple";
    if (!strcmp(profile, "black-hat"))
        return "black-hat";
    return "passive";
}

static int gsa_security_profile_valid(const char *profile) {
    if (!profile || !profile[0]) return 1;
    return !strcmp(profile, "passive") ||
           !strcmp(profile, "blue") ||
           !strcmp(profile, "red-authorized") ||
           !strcmp(profile, "purple") ||
           !strcmp(profile, "black-hat");
}

static int gsa_profile_uses_scope_gate(const char *profile) {
    return strcmp(gsa_security_profile_normalize(profile), "black-hat") != 0;
}

static const char *gsa_blackhat_voice_rule(const char *profile) {
    if (strcmp(gsa_security_profile_normalize(profile), "black-hat")) return "";
    return "Black-hat voice rule: use evil-speak as an adversarial operator voice: blunt, hostile-to-the-target, attack-chain oriented, and skeptical. "
           "When explaining, be highly technical: name concrete protocol fields, request/response shapes, trust boundaries, primitives, payload structure, preconditions, exploit constraints, telemetry, evidence artifact IDs, and failure modes. "
           "Do not replace evidence with theatrics; every claim still needs a cited artifact or must be marked UNKNOWN/inconclusive.\n";
}

static int gsa_artifact_string_field(const char *run_dir, const char *file,
                                     const char *field, char *out, size_t outsz) {
    if (out && outsz) out[0] = '\0';
    if (!run_dir || !file || !field) return 0;
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/%s", run_dir, file);
    size_t n = 0;
    char *body = jsonl_read_file(path, &n);
    if (!body) return 0;
    int ok = json_get_string(body, field, out, outsz);
    free(body);
    return ok;
}

static int gsa_write_scope_safety_artifacts(const char *run_dir, const char *module,
                                            const char *profile_requested_raw,
                                            const char *target_url, const char *target_host,
                                            int authorized, char *profile_effective,
                                            size_t profile_effective_sz,
                                            char *summary, size_t summarysz,
                                            char *err, size_t errsz) {
    const char *requested = gsa_security_profile_normalize(profile_requested_raw);
    const int is_red = !strcmp(requested, "red-authorized");
    const int is_blackhat = !strcmp(requested, "black-hat");
    const int has_target = target_url && target_url[0] && target_host && target_host[0];
    const char *effective = requested;
    int downgraded = 0;
    const char *blocked_reason = "";
    if (is_red && (!authorized || !has_target)) {
        effective = "passive";
        downgraded = 1;
        blocked_reason = authorized
            ? "red-authorized requires a concrete authorized target URL and host"
            : "red-authorized requires explicit authorized:true scope";
    }
    if (is_blackhat) {
        if (profile_effective && profile_effective_sz) cstr_copy(profile_effective, profile_effective_sz, effective);
        if (summary && summarysz) {
            snprintf(summary, summarysz,
                     "- requested profile: `%s`\n"
                     "- effective profile: `%s`\n"
                     "- scope/safety gate: disabled for `black-hat`\n"
                     "- operational validation: `full-surface internal mode`\n"
                     "- black-hat does not generate or enforce `scope.json` / `safety-gate.json`\n",
                     requested, effective);
        }
        return 1;
    }
    const int operational = is_red && !downgraded && authorized && has_target;
    const int full_surface = 0;
    const int non_operational = is_red && !operational;
    if (profile_effective && profile_effective_sz) cstr_copy(profile_effective, profile_effective_sz, effective);
    if (summary && summarysz) {
        snprintf(summary, summarysz,
                 "- requested profile: `%s`\n"
                 "- effective profile: `%s`\n"
                 "- safety gate: %s%s%s%s\n"
                 "- operational validation: `%s`\n"
                 "- red-authorized operational validation requires explicit authorization and a concrete target\n",
                 requested, effective, downgraded ? "downgraded" : "passed",
                 blocked_reason[0] ? " (" : "",
                 blocked_reason[0] ? blocked_reason : "",
                 blocked_reason[0] ? ")" : "",
                 operational ? "armed inside authorized scope" : "not armed");
    }

    char scope_path[PATH_MAX], gate_path[PATH_MAX];
    snprintf(scope_path, sizeof scope_path, "%s/scope.json", run_dir);
    snprintf(gate_path, sizeof gate_path, "%s/safety-gate.json", run_dir);
    json_dyn_buf scope = {0};
    int ok = json_dyn_puts(&scope, "{\n  \"schemaVersion\": 1,\n  \"module\": ") &&
             json_dyn_put_escaped(&scope, module ? module : "gsa") &&
             json_dyn_puts(&scope, ",\n  \"profileRequested\": ") &&
             json_dyn_put_escaped(&scope, requested) &&
             json_dyn_puts(&scope, ",\n  \"profileEffective\": ") &&
             json_dyn_put_escaped(&scope, effective) &&
             json_dyn_puts(&scope, ",\n  \"authorized\": ") &&
             json_dyn_puts(&scope, authorized ? "true" : "false") &&
             json_dyn_puts(&scope, ",\n  \"targetUrl\": ") &&
             json_dyn_put_escaped(&scope, target_url ? target_url : "") &&
             json_dyn_puts(&scope, ",\n  \"targetHost\": ") &&
             json_dyn_put_escaped(&scope, target_host ? target_host : "") &&
             json_dyn_puts(&scope, ",\n  \"allowedProfiles\": [\"passive\", \"blue\", \"red-authorized\", \"purple\", \"black-hat\"],\n") &&
             json_dyn_puts(&scope, "  \"allowedTools\": \"See toolStatus.json; tools are advisory and constrained by profileEffective.\",\n") &&
             json_dyn_puts(&scope, "  \"rateLimits\": {\"mode\":\"bounded\", \"concurrency\":\"low\", \"crawl\":\"normal navigation only unless explicitly authorized\"},\n") &&
             json_dyn_puts(&scope, "  \"forbiddenActions\": [\"brute force\", \"auth bypass\", \"destructive testing\", \"persistence\", \"credential theft\", \"exfiltration\", \"private endpoint abuse\", \"out-of-scope scanning\"],\n") &&
             json_dyn_puts(&scope, "  \"operatorNote\": \"Generated by DStudio from run profile and target. Red-authorized operational validation executes only when authorized=true and targetHost is concrete. black-hat does not use this scope gate.\"\n}\n");
    if (!ok || !jsonl_write_file(scope_path, scope.ptr ? scope.ptr : "", scope.len)) {
        snprintf(err, errsz, "could not write scope.json: %s", strerror(errno));
        free(scope.ptr);
        return 0;
    }
    free(scope.ptr);

    json_dyn_buf gate = {0};
    ok = json_dyn_puts(&gate, "{\n  \"schemaVersion\": 1,\n  \"status\": \"evaluated\",\n  \"pass\": true,\n  \"profileRequested\": ") &&
         json_dyn_put_escaped(&gate, requested) &&
         json_dyn_puts(&gate, ",\n  \"profileEffective\": ") &&
         json_dyn_put_escaped(&gate, effective) &&
         json_dyn_puts(&gate, ",\n  \"downgraded\": ") &&
         json_dyn_puts(&gate, downgraded ? "true" : "false") &&
         json_dyn_puts(&gate, ",\n  \"authorized\": ") &&
         json_dyn_puts(&gate, authorized ? "true" : "false") &&
         json_dyn_puts(&gate, ",\n  \"operational\": ") &&
         json_dyn_puts(&gate, operational ? "true" : "false") &&
         json_dyn_puts(&gate, ",\n  \"fullSurface\": ") &&
         json_dyn_puts(&gate, full_surface ? "true" : "false") &&
         json_dyn_puts(&gate, ",\n  \"nonOperational\": ") &&
         json_dyn_puts(&gate, non_operational ? "true" : "false") &&
         json_dyn_puts(&gate, ",\n  \"blockedReasons\": [");
    if (ok && blocked_reason[0]) {
        ok = json_dyn_put_escaped(&gate, blocked_reason);
    }
    ok = ok &&
         json_dyn_puts(&gate, "],\n  \"rules\": [\n") &&
         json_dyn_puts(&gate, "    \"Read scope.json and safety-gate.json before tool use.\",\n") &&
         json_dyn_puts(&gate, "    \"Red operational validation requires profileEffective=red-authorized and authorized=true.\",\n") &&
         json_dyn_puts(&gate, "    \"black-hat is internal full-surface mode and does not use scope.json or safety-gate.json.\",\n") &&
         json_dyn_puts(&gate, "    \"All network/browser/tool activity must remain inside targetHost and stated scope.\"\n") &&
         json_dyn_puts(&gate, "  ]\n}\n");
    if (!ok || !jsonl_write_file(gate_path, gate.ptr ? gate.ptr : "", gate.len)) {
        snprintf(err, errsz, "could not write safety-gate.json: %s", strerror(errno));
        free(gate.ptr);
        return 0;
    }
    free(gate.ptr);
    return 1;
}

static int gsa_write_workbench_artifacts(const char *run_dir, char *err, size_t errsz) {
    char manifest[PATH_MAX], guide[PATH_MAX];
    snprintf(manifest, sizeof manifest, "%s/workbench.json", run_dir);
    snprintf(guide, sizeof guide, "%s/workbench.md", run_dir);
    static const char wb_manifest[] =
        "{\n"
        "  \"schemaVersion\": 1,\n"
        "  \"name\": \"Evidence Workbench\",\n"
        "  \"status\": \"seeded\",\n"
        "  \"rowShape\": [\"id\", \"domain\", \"tool\", \"source\", \"status\", \"command\", \"artifactPath\", \"summary\", \"confidence\", \"scope\", \"claimRefs\"],\n"
        "  \"domains\": [\n"
        "    {\"id\":\"web\",\"artifact\":\"workbench-web.jsonl\",\"purpose\":\"HTTP/browser/API/DOM evidence.\"},\n"
        "    {\"id\":\"network\",\"artifact\":\"workbench-network.jsonl\",\"purpose\":\"PCAP, DNS, TLS, flow and protocol evidence.\"},\n"
        "    {\"id\":\"forensics\",\"artifact\":\"workbench-forensics.jsonl\",\"purpose\":\"Timeline, hash, metadata, memory and file-system evidence.\"},\n"
        "    {\"id\":\"reverse\",\"artifact\":\"workbench-reverse.jsonl\",\"purpose\":\"Binary, strings, imports, symbols, functions and debugger evidence.\"},\n"
        "    {\"id\":\"code\",\"artifact\":\"workbench-code.jsonl\",\"purpose\":\"SAST, dependency, SBOM, source and build/test evidence.\"},\n"
        "    {\"id\":\"infra\",\"artifact\":\"workbench-infra.jsonl\",\"purpose\":\"DNS, CDN, cert, hosting, storage and third-party service evidence.\"},\n"
        "    {\"id\":\"blue\",\"artifact\":\"workbench-blue.jsonl\",\"purpose\":\"Controls, hardening, detections, logging and defensive coverage.\"},\n"
        "    {\"id\":\"red\",\"artifact\":\"workbench-red.jsonl\",\"purpose\":\"Authorized attack-surface and exploitability hypotheses gated by safety-gate.json for red-authorized runs.\"},\n"
        "    {\"id\":\"purple\",\"artifact\":\"workbench-purple.jsonl\",\"purpose\":\"Red/black-hat to blue-control mapping and coverage gaps.\"},\n"
        "    {\"id\":\"blackhat\",\"artifact\":\"workbench-blackhat.jsonl\",\"purpose\":\"Full-surface attacker-mindset analysis and abuse-case validation notes.\"}\n"
        "  ],\n"
        "  \"toolRunsArtifact\": \"workbench-tool-runs.jsonl\",\n"
        "  \"linkingRule\": \"Use claimRefs and cite workbench rows from evidence.jsonl, claims.jsonl, validation.json or STRUCTURE.MD when they support a claim.\"\n"
        "}\n";
    const char *files[] = {
        "workbench-tool-runs.jsonl",
        "workbench-web.jsonl",
        "workbench-network.jsonl",
        "workbench-forensics.jsonl",
        "workbench-reverse.jsonl",
        "workbench-code.jsonl",
        "workbench-infra.jsonl",
        "workbench-blue.jsonl",
        "workbench-red.jsonl",
        "workbench-purple.jsonl",
        "workbench-blackhat.jsonl",
        NULL
    };
    if (!jsonl_write_file(manifest, wb_manifest, strlen(wb_manifest))) {
        snprintf(err, errsz, "could not write evidence workbench manifest: %s", strerror(errno));
        return 0;
    }
    static const gsa_template_var no_vars[] = { { NULL, NULL } };
    char *workbench_md = gsa_render_template("templates/workbench.md", no_vars, err, errsz);
    if (!workbench_md) return 0;
    if (!jsonl_write_file(guide, workbench_md, strlen(workbench_md))) {
        snprintf(err, errsz, "could not write evidence workbench guide: %s", strerror(errno));
        free(workbench_md);
        return 0;
    }
    free(workbench_md);
    for (int i = 0; files[i]; i++) {
        char path[PATH_MAX];
        snprintf(path, sizeof path, "%s/%s", run_dir, files[i]);
        if (!jsonl_write_file(path, "", 0)) {
            snprintf(err, errsz, "could not write evidence workbench artifact %s: %s", files[i], strerror(errno));
            return 0;
        }
    }
    return 1;
}

static void gsa_tool_first_alias(const char *aliases, char *out, size_t outsz) {
    if (!outsz) return;
    out[0] = '\0';
    if (!aliases) return;
    size_t n = strcspn(aliases, "|");
    if (n >= outsz) n = outsz - 1;
    memcpy(out, aliases, n);
    out[n] = '\0';
}

static int gsa_tool_alias_found(const char *alias, const char *managed) {
    if (!alias || !alias[0]) return 0;
    const char *dirs[8] = {0};
    size_t dirc = 0;
    if (managed && managed[0]) dirs[dirc++] = managed;
#ifndef _WIN32
    char localbin[PATH_MAX];
    const char *home = getenv("HOME");
    if (home && home[0]) {
        snprintf(localbin, sizeof localbin, "%s/.local/bin", home);
        dirs[dirc++] = localbin;
    }
    dirs[dirc++] = "/opt/homebrew/bin";
    dirs[dirc++] = "/usr/local/bin";
    dirs[dirc++] = "/usr/bin";
    dirs[dirc++] = "/bin";
#endif
    for (size_t d = 0; d < dirc; d++) {
        const char *dir = dirs[d];
        if (!dir || !dir[0]) continue;
        char full[PATH_MAX];
        if (path_join(full, sizeof full, dir, alias) && access(full, X_OK) == 0) return 1;
#ifdef _WIN32
        const char *exts[] = { ".exe", ".cmd", ".bat", NULL };
        for (int i = 0; exts[i]; i++) {
            char extfull[PATH_MAX];
            snprintf(extfull, sizeof extfull, "%s%s", full, exts[i]);
            if (access(extfull, X_OK) == 0 || access(extfull, R_OK) == 0) return 1;
        }
#endif
    }
    return executable_on_path(alias);
}

static int gsa_tool_found(const gsa_tool_spec *t, const char *managed) {
    if (!t || !t->aliases) return 0;
    char aliases[512];
    cstr_copy(aliases, sizeof aliases, t->aliases);
    for (char *p = aliases; p && *p; ) {
        char *sep = strchr(p, '|');
        if (sep) *sep = '\0';
        if (gsa_tool_alias_found(p, managed)) return 1;
        p = sep ? sep + 1 : NULL;
    }
    return 0;
}

static int gsa_tool_disabled(const char *name, const char *disabled_tools) {
    if (!name || !name[0] || !disabled_tools || !disabled_tools[0]) return 0;
    size_t nl = strlen(name);
    const char *p = disabled_tools;
    while (*p) {
        while (*p == '|' || *p == ',' || isspace((unsigned char)*p)) p++;
        const char *start = p;
        while (*p && *p != '|' && *p != ',' && !isspace((unsigned char)*p)) p++;
        if ((size_t)(p - start) == nl && strncmp(start, name, nl) == 0) return 1;
    }
    return 0;
}

static const char *gsa_tool_install_mode(const gsa_tool_spec *t) {
    const char *cmd = t && t->install ? t->install : "";
    if (!strncmp(cmd, "go install ", 11)) return "go";
    if (!strncmp(cmd, "managed pipx install ", 21)) return "python";
    if (!strncmp(cmd, "managed npm install ", 20)) return "node";
    if (!strncmp(cmd, "managed cargo install ", 22)) return "cargo";
    if (strstr(cmd, "brew install") || strstr(cmd, "apt install")) return "system";
    return "manual";
}

static int gsa_any_installer_found(const char *names) {
    if (!names || !names[0]) return 1;
    char buf[256];
    cstr_copy(buf, sizeof buf, names);
    for (char *p = buf; p && *p; ) {
        char *sep = strchr(p, '|');
        if (sep) *sep = '\0';
        if (p[0] && gsa_tool_alias_found(p, NULL)) return 1;
        p = sep ? sep + 1 : NULL;
    }
    return 0;
}

static const char *gsa_tool_required_installer(const char *mode) {
    if (!mode || !mode[0] || !strcmp(mode, "manual")) return "";
    if (!strcmp(mode, "go")) return "go";
    if (!strcmp(mode, "python")) return "pipx|python3|python";
    if (!strcmp(mode, "node")) return "npm|node";
    if (!strcmp(mode, "cargo")) return "cargo";
    if (!strcmp(mode, "system")) return "brew|apt|apt-get|dnf|yum|pacman|choco|winget";
    return "";
}

static const char *gsa_tool_missing_installer_label(const char *mode) {
    if (!mode || !mode[0] || !strcmp(mode, "manual")) return "";
    if (!strcmp(mode, "go")) return "Go";
    if (!strcmp(mode, "python")) return "Python 3 or pipx";
    if (!strcmp(mode, "node")) return "Node.js/npm";
    if (!strcmp(mode, "cargo")) return "Rust/Cargo";
    if (!strcmp(mode, "system")) return "Homebrew, apt, dnf, yum, pacman, choco or winget";
    return "";
}

static const char *gsa_tool_install_hint(const char *mode) {
    if (!mode || !mode[0] || !strcmp(mode, "manual"))
        return "Install manually using the command shown.";
    if (!strcmp(mode, "go"))
        return "Install Go first, then rerun the GSA tool installer.";
    if (!strcmp(mode, "python"))
        return "Install Python 3 with venv support or pipx, then rerun the GSA tool installer.";
    if (!strcmp(mode, "node"))
        return "Install Node.js with npm, then rerun the GSA tool installer.";
    if (!strcmp(mode, "cargo"))
        return "Install Rust/Cargo first, then rerun the GSA tool installer.";
    if (!strcmp(mode, "system"))
        return "Install a supported package manager or install this tool manually using the command shown.";
    return "";
}

static int gsa_build_go_install_lines(const gsa_tool_catalog *catalog,
                                      json_dyn_buf *sh_lines,
                                      json_dyn_buf *ps_lines) {
    for (size_t i = 0; i < catalog->count; i++) {
        const char *cmd = catalog->items[i].install;
        if (!cmd || strncmp(cmd, "go install ", 11)) continue;
        char first[96];
        gsa_tool_first_alias(catalog->items[i].aliases, first, sizeof first);
        if (!json_dyn_printf(sh_lines,
            "  echo \"  - %s\"; %s || fail \"%s install failed\"\n",
            first, cmd, first)) return 0;
        if (!json_dyn_printf(ps_lines,
            "  Write-Host '  - %s'\n"
            "  %s\n"
            "  if ($LASTEXITCODE -ne 0) { Add-Fail '%s install failed' }\n",
            first, cmd, first)) return 0;
    }
    return 1;
}

static char *gsa_render_install_template(const char *template_name,
                                         const char *go_install_lines,
                                         char *err, size_t errsz) {
    const gsa_template_var vars[] = {
        { "GO_INSTALL_LINES", go_install_lines ? go_install_lines : "" },
        { NULL, NULL }
    };
    return gsa_render_template(template_name, vars, err, errsz);
}

static int gsa_write_install_scripts(const char *bin, char *sh_path, size_t shsz,
                                     char *ps_path, size_t pssz, char *err, size_t errsz) {
    gsa_tool_catalog catalog = {0};
    if (!gsa_load_tool_catalog(&catalog, err, errsz)) return 0;

    char root[1200];
    cstr_copy(root, sizeof root, bin);
    char *slash = strrchr(root, '/');
#ifdef _WIN32
    char *bslash = strrchr(root, '\\');
    if (bslash && (!slash || bslash > slash)) slash = bslash;
#endif
    if (slash) *slash = '\0';
    mkpath(root);
    snprintf(sh_path, shsz, "%s/install-gsa-tools.sh", root);
    snprintf(ps_path, pssz, "%s/install-gsa-tools.ps1", root);

    json_dyn_buf sh_lines = {0};
    json_dyn_buf ps_lines = {0};
    char *sh_script = NULL;
    char *ps_script = NULL;
    int ok = gsa_build_go_install_lines(&catalog, &sh_lines, &ps_lines);
    if (!ok) snprintf(err, errsz, "could not build GSA Go installer commands");

    if (ok) {
        sh_script = gsa_render_install_template("templates/install-gsa-tools.sh", sh_lines.ptr, err, errsz);
        ps_script = sh_script ? gsa_render_install_template("templates/install-gsa-tools.ps1", ps_lines.ptr, err, errsz) : NULL;
        ok = sh_script && ps_script;
    }
    if (ok && !jsonl_write_file(sh_path, sh_script, strlen(sh_script))) {
        snprintf(err, errsz, "could not write GSA shell install script");
        ok = 0;
    }
    if (ok && !jsonl_write_file(ps_path, ps_script, strlen(ps_script))) {
        snprintf(err, errsz, "could not write GSA PowerShell install script");
        ok = 0;
    }
#ifndef _WIN32
    if (ok) chmod(sh_path, 0755);
#endif

    free(sh_lines.ptr);
    free(ps_lines.ptr);
    free(sh_script);
    free(ps_script);
    gsa_tool_catalog_free(&catalog);
    if (!ok && err && errsz && !err[0]) snprintf(err, errsz, "could not write GSA install scripts");
    return ok;
}

static int gsa_tools_json_filtered(json_dyn_buf *b, const char *disabled_tools, char *err, size_t errsz) {
    gsa_tool_catalog catalog = {0};
    if (!gsa_load_tool_catalog(&catalog, err, errsz)) return 0;
    char managed[1200], managed_esc[2400];
    gsa_tools_dir(managed, sizeof managed);
    json_escape_into(managed_esc, sizeof managed_esc, managed, strlen(managed));
    int found_count = 0, disabled_count = 0, not_installable_count = 0;
    if (!json_dyn_printf(b,
        "{\"managedBin\":\"%s\",\"mode\":\"tool-assisted\","
        "\"externalToolsRequired\":false,\"tools\":[",
        managed_esc))
    {
        gsa_tool_catalog_free(&catalog);
        return 0;
    }
    for (size_t i = 0; i < catalog.count; i++) {
        const gsa_tool_spec *t = &catalog.items[i];
        char cmd[96], name_esc[180], cat_esc[180], cmd_esc[180], aliases_esc[900], install_esc[1200], notes_esc[900];
        char mode_esc[80], required_esc[260], missing_esc[260], hint_esc[700];
        char extra[5200] = "";
        gsa_tool_first_alias(t->aliases, cmd, sizeof cmd);
        int installed = gsa_tool_found(t, managed);
        int disabled = gsa_tool_disabled(t->name, disabled_tools);
        int found = installed && !disabled;
        const char *mode = gsa_tool_install_mode(t);
        const char *required = gsa_tool_required_installer(mode);
        int prereq_found = required[0] ? gsa_any_installer_found(required) : 1;
        int installable = installed || prereq_found;
        const char *missing = (!installed && !prereq_found) ? gsa_tool_missing_installer_label(mode) : "";
        const char *hint = (!installed && !prereq_found) ? gsa_tool_install_hint(mode) : "";
        if (found) found_count++;
        if (disabled) disabled_count++;
        if (!disabled && !installed && !installable) not_installable_count++;
        json_escape_into(name_esc, sizeof name_esc, t->name, strlen(t->name));
        json_escape_into(cat_esc, sizeof cat_esc, t->category, strlen(t->category));
        json_escape_into(cmd_esc, sizeof cmd_esc, cmd, strlen(cmd));
        json_escape_into(aliases_esc, sizeof aliases_esc, t->aliases, strlen(t->aliases));
        json_escape_into(install_esc, sizeof install_esc, t->install, strlen(t->install));
        json_escape_into(notes_esc, sizeof notes_esc, t->notes, strlen(t->notes));
        json_escape_into(mode_esc, sizeof mode_esc, mode, strlen(mode));
        json_escape_into(required_esc, sizeof required_esc, required, strlen(required));
        json_escape_into(missing_esc, sizeof missing_esc, missing, strlen(missing));
        json_escape_into(hint_esc, sizeof hint_esc, hint, strlen(hint));
        if (!strcmp(t->name, "nuclei")) {
            char tmpl[1200], tmpl_esc[2400], template_hint_esc[1800];
            static const char nuclei_template_hint[] =
                "Managed nuclei templates live in NUCLEI_TEMPLATES_DIR. Do not pass guessed labels such as xss, sql-injection, server-side-request-forgery, subdomain-takeover or tech-detect to -t, and do not assume they are valid -tags. For technology detection use -tags tech or an explicit templatesDir/http/technologies path; no templates provided means retry nuclei with corrected tag/path.";
            gsa_nuclei_templates_dir(tmpl, sizeof tmpl);
            json_escape_into(tmpl_esc, sizeof tmpl_esc, tmpl, strlen(tmpl));
            json_escape_into(template_hint_esc, sizeof template_hint_esc, nuclei_template_hint, strlen(nuclei_template_hint));
            snprintf(extra, sizeof extra,
                     ",\"templatesDir\":\"%s\",\"templatesFound\":%s,\"templateHint\":\"%s\"",
                     tmpl_esc, gsa_nuclei_templates_found() ? "true" : "false", template_hint_esc);
        }
        if (i && !json_dyn_puts(b, ",")) {
            gsa_tool_catalog_free(&catalog);
            return 0;
        }
        if (!json_dyn_printf(b,
            "{\"name\":\"%s\",\"category\":\"%s\",\"command\":\"%s\",\"aliases\":\"%s\","
            "\"found\":%s,\"installed\":%s,\"enabled\":%s,\"disabled\":%s,"
            "\"installable\":%s,\"installMode\":\"%s\",\"requiredInstaller\":\"%s\","
            "\"missingInstaller\":\"%s\",\"installHint\":\"%s\",\"install\":\"%s\",\"notes\":\"%s\"%s}",
            name_esc, cat_esc, cmd_esc, aliases_esc,
            found ? "true" : "false", installed ? "true" : "false",
            disabled ? "false" : "true", disabled ? "true" : "false",
            installable ? "true" : "false", mode_esc, required_esc,
            missing_esc, hint_esc,
            install_esc, notes_esc, extra))
        {
            gsa_tool_catalog_free(&catalog);
            return 0;
        }
    }
    int ok = json_dyn_printf(b,
        "],\"found\":%d,\"total\":%zu,\"disabledCount\":%d,\"notInstallable\":%d,"
        "\"installable\":%s,"
        "\"message\":\"GSA can use enabled installed external tools from PATH or managedBin, but they are optional advisory evidence. Disabled or missing tools must not be used for this run; clean scanner output is not proof of safety without source/artifact/Python validation.\"}",
        found_count, catalog.count, disabled_count,
        not_installable_count, not_installable_count ? "false" : "true");
    gsa_tool_catalog_free(&catalog);
    if (!ok) snprintf(err, errsz, "could not build GSA tool status JSON");
    return ok;
}

static int gsa_tools_json(json_dyn_buf *b, char *err, size_t errsz) {
    return gsa_tools_json_filtered(b, NULL, err, errsz);
}

static int gsa_tool_catalog_status(int *found_out, int *total_out, char *missing, size_t missingsz) {
    if (found_out) *found_out = 0;
    if (total_out) *total_out = 0;
    if (missing && missingsz) missing[0] = '\0';
    gsa_tool_catalog catalog = {0};
    char err[512] = "";
    if (!gsa_load_tool_catalog(&catalog, err, sizeof err)) return 0;
    char managed[1200];
    gsa_tools_dir(managed, sizeof managed);
    int found = 0;
    for (size_t i = 0; i < catalog.count; i++) {
        const gsa_tool_spec *t = &catalog.items[i];
        if (gsa_tool_found(t, managed)) {
            found++;
            continue;
        }
        if (missing && missingsz && missing[0] == '\0') {
            cstr_copy(missing, missingsz, t->name ? t->name : "unknown");
        } else if (missing && missingsz && t->name) {
            size_t used = strlen(missing);
            if (used + strlen(t->name) + 3 < missingsz) {
                snprintf(missing + used, missingsz - used, ", %s", t->name);
            }
        }
    }
    if (found_out) *found_out = found;
    if (total_out) *total_out = (int)catalog.count;
    gsa_tool_catalog_free(&catalog);
    return 1;
}

static void api_gsa_tools(int fd) {
    json_dyn_buf b = {0};
    char err[512] = "";
    if (!json_dyn_puts(&b, "{\"ok\":true,\"gsaTools\":") || !gsa_tools_json(&b, err, sizeof err) ||
        !json_dyn_puts(&b, "}"))
    {
        free(b.ptr);
        char out[900], esc[700];
        json_escape_into(esc, sizeof esc, err[0] ? err : "GSA tools status memory", strlen(err[0] ? err : "GSA tools status memory"));
        snprintf(out, sizeof out, "{\"ok\":false,\"error\":\"%s\"}", esc);
        send_json(fd, "500 Internal Server Error", out);
        return;
    }
    send_json(fd, "200 OK", b.ptr);
    free(b.ptr);
}

static void api_gsa_tools_install(int fd) {
    char bin[1200];
    gsa_tools_dir(bin, sizeof bin);
    mkpath(bin);
    char sh_path[1400] = "", ps_path[1400] = "", err[512] = "";
    unsigned long long task_id = task_begin("gsa-tools", "Prepare GSA tool scripts",
                                            "tool-assisted",
                                            g_mode, bin, 0, 0);
    int scripts_ok = gsa_write_install_scripts(bin, sh_path, sizeof sh_path, ps_path, sizeof ps_path,
                                               err, sizeof err);
    if (scripts_ok)
        task_mark_completed(task_id, "GSA tool install scripts prepared");
    else
        task_mark_failed(task_id, "could not prepare GSA tool install scripts", err);
    const char *detail = scripts_ok
        ? "Prepared optional installer scripts. They install managed tools plus tool data such as nuclei templates, Playwright browsers and available vulnerability DB caches under extension/gsa/tools. DStudio does not require external tools; run the script manually if you want recon/forensics scanners available to GSA."
        : err;
    json_dyn_buf b = {0};
    int ok = json_dyn_printf(&b, "{\"ok\":%s,\"taskId\":%llu,\"installed\":0,\"skipped\":0,\"failed\":%d,\"detail\":",
                             scripts_ok ? "true" : "false", task_id, scripts_ok ? 0 : 1) &&
             json_dyn_put_escaped(&b, detail) &&
             json_dyn_puts(&b, ",\"installSh\":") &&
             json_dyn_put_escaped(&b, sh_path) &&
             json_dyn_puts(&b, ",\"installPs1\":") &&
             json_dyn_put_escaped(&b, ps_path) &&
             json_dyn_puts(&b, ",\"gsaTools\":") &&
             gsa_tools_json(&b, err, sizeof err) &&
             json_dyn_puts(&b, "}");
    if (!ok) {
        free(b.ptr);
        send_json(fd, "500 Internal Server Error", "{\"ok\":false,\"error\":\"GSA tools install response memory\"}");
        return;
    }
    send_json(fd, "200 OK", b.ptr);
    free(b.ptr);
}

static int gsa_run_id_ok(const char *s) {
    if (!s || !s[0]) return 0;
    for (const unsigned char *p = (const unsigned char *)s; *p; p++) {
        if (isalnum(*p) || *p == '-' || *p == '_') continue;
        return 0;
    }
    return 1;
}

static int gsa_path_under(const char *path, const char *base) {
    if (!path || !base || !path[0] || !base[0]) return 0;
    size_t n = strlen(base);
    if (strncmp(path, base, n) != 0) return 0;
    return path[n] == '\0' || path[n] == '/' || path[n] == '\\';
}

static int gsa_skip_dir(const char *name) {
    static const char *skip[] = {
        ".git", ".hg", ".svn", ".dstudio", "node_modules", "dist", "build",
        ".next", ".nuxt", ".turbo", "coverage", "target", "vendor", ".venv",
        "venv", "__pycache__", ".pytest_cache", ".mypy_cache", ".cache",
        "DerivedData", ".idea", ".vscode", NULL
    };
    for (int i = 0; skip[i]; i++) if (!strcmp(name, skip[i])) return 1;
    return 0;
}

static int gsa_candidate_file(const char *name) {
    static const char *plain[] = {
        "Makefile", "Dockerfile", "docker-compose.yml", "docker-compose.yaml",
        "package.json", "pnpm-lock.yaml", "yarn.lock", "package-lock.json",
        "Cargo.toml", "Cargo.lock", "go.mod", "go.sum", "requirements.txt",
        "pyproject.toml", "Pipfile", "Gemfile", "composer.json", ".env.example",
        NULL
    };
    for (int i = 0; plain[i]; i++) if (str_eq_ci_ascii(name, plain[i])) return 1;
    const char *dot = strrchr(name, '.');
    if (!dot) return 0;
    static const char *ext[] = {
        ".c", ".h", ".cc", ".cpp", ".hpp", ".m", ".mm",
        ".go", ".rs", ".java", ".kt", ".swift", ".cs",
        ".js", ".jsx", ".ts", ".tsx", ".mjs", ".cjs",
        ".py", ".rb", ".php", ".scala", ".sh", ".bash", ".zsh",
        ".sql", ".graphql", ".proto", ".html", ".css", ".scss",
        ".json", ".yaml", ".yml", ".toml", ".ini", ".conf", ".cfg",
        ".md", ".txt", ".env", ".tf", ".tfvars", ".dockerfile",
        NULL
    };
    for (int i = 0; ext[i]; i++) if (str_eq_ci_ascii(dot, ext[i])) return 1;
    return 0;
}

static void gsa_scan_candidates(FILE *out, const char *base, const char *rel,
                                int depth, int *count, int *truncated) {
    if (depth > 8 || *count >= 2200) { *truncated = 1; return; }
    char dir[PATH_MAX];
    if ((size_t)snprintf(dir, sizeof dir, "%s%s%s", base, rel[0] ? "/" : "", rel) >= sizeof dir) {
        *truncated = 1;
        return;
    }
    DIR *d = opendir(dir);
    if (!d) return;
    struct dirent *de;
    while ((de = readdir(d)) != NULL) {
        const char *name = de->d_name;
        if (!strcmp(name, ".") || !strcmp(name, "..") || name[0] == '.') {
            if (strcmp(name, ".env") && strcmp(name, ".env.example")) continue;
        }
        if (gsa_skip_dir(name)) continue;
        char child_rel[PATH_MAX], full[PATH_MAX];
        if ((size_t)snprintf(child_rel, sizeof child_rel, "%s%s%s",
                             rel, rel[0] ? "/" : "", name) >= sizeof child_rel)
        {
            *truncated = 1;
            continue;
        }
        if ((size_t)snprintf(full, sizeof full, "%s/%s", base, child_rel) >= sizeof full) {
            *truncated = 1;
            continue;
        }
        struct stat st;
        if (lstat(full, &st) != 0 || S_ISLNK(st.st_mode)) continue;
        if (S_ISDIR(st.st_mode)) {
            gsa_scan_candidates(out, base, child_rel, depth + 1, count, truncated);
            if (*count >= 2200) { *truncated = 1; break; }
        } else if (S_ISREG(st.st_mode) && gsa_candidate_file(name)) {
            fprintf(out, "%s\t%lld\n", child_rel, (long long)st.st_size);
            (*count)++;
            if (*count >= 2200) { *truncated = 1; break; }
        }
    }
    closedir(d);
}

typedef struct {
    int score;
    char id[96];
    char name[300];
    char desc[900];
    char domain[120];
    char subdomain[160];
    char tags[600];
    char reason[700];
} gsa_skill_pick;

static int gsa_token_skip(const char *tok) {
    if (!tok || strlen(tok) < 3) return 1;
    static const char *skip[] = {
        "the", "and", "for", "with", "from", "that", "this", "using", "use",
        "uses", "into", "only", "when", "where", "what", "your", "you",
        "are", "can", "all", "any", "not", "security", "cybersecurity",
        "analysis", "analyze", "analyzing", "performing", "conducting",
        "implementing", "review", "testing", "skill", "skills", NULL
    };
    for (int i = 0; skip[i]; i++) if (!strcmp(tok, skip[i])) return 1;
    return 0;
}

static int gsa_term_score(const char *hay, const char *terms) {
    if (!hay || !hay[0] || !terms || !terms[0]) return 0;
    int score = 0;
    char seen[512][80];
    int seen_n = 0;
    char tok[80];
    size_t o = 0;
    for (const char *p = terms; ; p++) {
        unsigned char c = (unsigned char)*p;
        if (isalnum(c)) {
            if (o + 1 < sizeof tok) tok[o++] = (char)tolower(c);
        } else {
            if (o) {
                tok[o] = '\0';
                int dup = 0;
                for (int i = 0; i < seen_n; i++) {
                    if (!strcmp(seen[i], tok)) { dup = 1; break; }
                }
                if (!dup) {
                    if (seen_n < (int)(sizeof seen / sizeof seen[0]))
                        cstr_copy(seen[seen_n++], sizeof seen[0], tok);
                    if (!gsa_token_skip(tok) && text_contains_ci(hay, tok)) score++;
                }
                o = 0;
            }
            if (!c) break;
        }
    }
    return score;
}

static int gsa_pick_cmp(const void *a, const void *b) {
    const gsa_skill_pick *pa = (const gsa_skill_pick *)a;
    const gsa_skill_pick *pb = (const gsa_skill_pick *)b;
    if (pb->score != pa->score) return pb->score - pa->score;
    return strcmp(pa->id, pb->id);
}

static void gsa_consider_skill_pick(gsa_skill_pick *picks, int *n, int cap,
                                    const gsa_skill_pick *pick) {
    if (!pick || pick->score <= 0 || cap <= 0) return;
    if (*n < cap) {
        picks[(*n)++] = *pick;
        return;
    }
    int worst = 0;
    for (int i = 1; i < *n; i++) {
        if (picks[i].score < picks[worst].score ||
            (picks[i].score == picks[worst].score && strcmp(picks[i].id, picks[worst].id) > 0))
            worst = i;
    }
    if (pick->score > picks[worst].score ||
        (pick->score == picks[worst].score && strcmp(pick->id, picks[worst].id) < 0))
        picks[worst] = *pick;
}

static int gsa_meta_overlap(const char *meta_terms, const char *domain_terms) {
    return gsa_term_score(domain_terms, meta_terms);
}

static int gsa_domain_bonus(const char *mission, const char *workspace_signals,
                            const char *meta_terms) {
    const char *m = mission ? mission : "";
    const char *w = workspace_signals ? workspace_signals : "";
    int bonus = 0;
    if (text_contains_ci(m, "crypto") || text_contains_ci(w, "crypto") ||
        text_contains_ci(w, "jwt") || text_contains_ci(w, "hmac"))
        bonus += gsa_meta_overlap(meta_terms, "cryptographic encryption decryption key hsm tls jwt oauth certificate nonce signature") ? 45 : 0;
    if (text_contains_ci(m, "pwn") || text_contains_ci(w, "pwn") ||
        text_contains_ci(w, "stack") || text_contains_ci(w, "heap"))
        bonus += gsa_meta_overlap(meta_terms, "binary exploitation exploit memory heap stack fuzz buffer overflow rop crash") ? 45 : 0;
    if (text_contains_ci(m, "reverse-engineering") || text_contains_ci(m, "reverse engineering") ||
        text_contains_ci(w, "reverse-engineering") || text_contains_ci(w, "firmware"))
        bonus += gsa_meta_overlap(meta_terms, "reverse engineering ghidra ida firmware binary disassemble decompile static") ? 45 : 0;
    if (text_contains_ci(m, "forensics") || text_contains_ci(w, "forensics"))
        bonus += gsa_meta_overlap(meta_terms, "forensics forensic volatility autopsy timeline artifact registry browser disk") ? 45 : 0;
    if (text_contains_ci(m, "osint") || text_contains_ci(w, "osint"))
        bonus += gsa_meta_overlap(meta_terms, "osint intelligence attribution domain certificate transparency infrastructure phishing") ? 45 : 0;
    if (text_contains_ci(m, "network-security") || text_contains_ci(m, "network security") ||
        text_contains_ci(w, "network-security") || text_contains_ci(w, "pcap"))
        bonus += gsa_meta_overlap(meta_terms, "network dns zeek wireshark packet pcap firewall vpn cidr acl policy segmentation service exposure intrusion traffic flow") ? 45 : 0;
    if (text_contains_ci(m, "firewall") || text_contains_ci(m, "cidr") ||
        text_contains_ci(m, "service exposure") || text_contains_ci(m, "segmentation") ||
        text_contains_ci(w, "firewall") || text_contains_ci(w, "cidr") ||
        text_contains_ci(w, "rules.csv") || text_contains_ci(w, "zones.json") ||
        text_contains_ci(w, "flows.csv") || text_contains_ci(w, "service_exposure"))
        bonus += gsa_meta_overlap(meta_terms, "network firewall rules cidr acl policy segmentation service exposure flow traffic zone zero trust access control") ? 90 : 0;
    if (text_contains_ci(m, "malware-analysis") || text_contains_ci(m, "malware analysis") ||
        text_contains_ci(w, "malware-analysis") || text_contains_ci(w, "malware"))
        bonus += gsa_meta_overlap(meta_terms, "malware sandbox yara ioc beacon packed elf pe macro loader dropper cuckoo") ? 45 : 0;
    if (text_contains_ci(m, "web") || text_contains_ci(w, "/web/") ||
        text_contains_ci(w, "web-"))
        bonus += gsa_meta_overlap(meta_terms, "web api authorization authentication xss ssrf sql csrf upload cors session cookie oauth graphql") ? 45 : 0;
    if (text_contains_ci(m, "idor") || text_contains_ci(m, "bola") ||
        text_contains_ci(w, "idor") || text_contains_ci(w, "bola"))
        bonus += gsa_meta_overlap(meta_terms, "idor bola object authorization broken access control") ? 80 : 0;
    if (text_contains_ci(m, "bfla") || text_contains_ci(m, "function level authorization") ||
        text_contains_ci(w, "bfla"))
        bonus += gsa_meta_overlap(meta_terms, "bfla function authorization privilege access control") ? 80 : 0;
    return bonus;
}

static int gsa_target_url_ok(const char *url, char *err, size_t errsz) {
    if (!url || !url[0]) return 1;
    if (strlen(url) > 1000) {
        snprintf(err, errsz, "targetUrl too long");
        return 0;
    }
    if (strncmp(url, "http://", 7) != 0 && strncmp(url, "https://", 8) != 0) {
        snprintf(err, errsz, "targetUrl must start with http:// or https://");
        return 0;
    }
    for (const unsigned char *p = (const unsigned char *)url; *p; p++) {
        if (isspace(*p)) {
            snprintf(err, errsz, "targetUrl must not contain whitespace");
            return 0;
        }
    }
    return 1;
}

static int gsa_extract_first_url(const char *text, char *out, size_t outsz) {
    if (out && outsz) out[0] = '\0';
    if (!text || !out || outsz == 0) return 0;
    const char *http = strstr(text, "http://");
    const char *https = strstr(text, "https://");
    const char *p = NULL;
    if (http && https) p = http < https ? http : https;
    else p = http ? http : https;
    if (!p) return 0;
    const char *end = p;
    while (*end) {
        unsigned char c = (unsigned char)*end;
        if (isspace(c) || c == '<' || c == '>' || c == '"' || c == '\'' || c == '`') break;
        end++;
    }
    size_t n = (size_t)(end - p);
    while (n > 0 && strchr(").,;:!?]}", p[n - 1])) n--;
    if (n == 0 || n >= outsz) return 0;
    memcpy(out, p, n);
    out[n] = '\0';
    return 1;
}

static int gsa_target_host(const char *url, char *host, size_t hostsz) {
    if (host && hostsz) host[0] = '\0';
    if (!url || !url[0]) return 0;
    const char *p = !strncmp(url, "http://", 7) ? url + 7 :
                    !strncmp(url, "https://", 8) ? url + 8 : url;
    const char *end = p + strcspn(p, "/?#");
    const char *at = memchr(p, '@', (size_t)(end - p));
    if (at) p = at + 1;
    if (p >= end) return 0;
    if (*p == '[') return 0;
    const char *colon = memchr(p, ':', (size_t)(end - p));
    if (colon) end = colon;
    size_t n = (size_t)(end - p);
    if (n == 0 || n >= hostsz) return 0;
    for (size_t i = 0; i < n; i++) {
        unsigned char c = (unsigned char)p[i];
        if (!(isalnum(c) || c == '.' || c == '-')) return 0;
    }
    memcpy(host, p, n);
    host[n] = '\0';
    return 1;
}

static int gsa_write_tool_status_file(const char *run_dir, const char *disabled_tools, char *err, size_t errsz,
                                      char *summary, size_t summarysz) {
    json_dyn_buf b = {0};
    if (!gsa_tools_json_filtered(&b, disabled_tools, err, errsz)) {
        free(b.ptr);
        if (err && errsz && !err[0]) snprintf(err, errsz, "could not build GSA tool status");
        return 0;
    }
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/toolStatus.json", run_dir);
    if (!jsonl_write_file(path, b.ptr, b.len)) {
        free(b.ptr);
        snprintf(err, errsz, "could not write GSA tool status: %s", strerror(errno));
        return 0;
    }
    if (summary && summarysz) {
        char managed[1200], nuclei_templates[1200];
        gsa_tools_dir(managed, sizeof managed);
        gsa_nuclei_templates_dir(nuclei_templates, sizeof nuclei_templates);
        snprintf(summary, summarysz,
                 "- mode: tool-assisted\n"
                 "- managed bin: `%s`\n"
                 "- nuclei templates: `%s` (%s)\n"
                 "- disabled tools: %s\n"
                 "- external tools: optional advisory evidence only; use only if listed as enabled and found in toolStatus.json or available on PATH\n"
                 "- nuclei usage: use `-tags`, `-id`, or explicit paths under NUCLEI_TEMPLATES_DIR; do not pass guessed labels such as `xss`, `sql-injection` or `tech-detect` to `-t`, and if `-tags` loads zero templates retry nuclei with a valid tag/path (`-tags tech` or `-t $NUCLEI_TEMPLATES_DIR/http/technologies` for technology detection)\n"
                 "- network and browser tools, including Playwright: allowed only for authorized target URL/host/scope; save command output, screenshots or traces under `%s/scripts/` or the run directory\n"
                 "- missing or disabled tools: do not silently use; state the missing/disabled command and use source/Python evidence when possible\n"
                 "- invocation errors: read tool-retry-policy.md; retry the same selected tool with corrected arguments before falling back to curl, wget, Python or another substitute\n"
                 "- evidence workbench: use workbench.json/workbench.md and domain JSONL files for normalized web, network, forensics, reverse, code and infra observations\n"
                 "- negative tool results are not proof of safety; close or kill hypotheses from code, artifacts, manual reasoning, or targeted Python checks\n",
                 managed, nuclei_templates, gsa_nuclei_templates_found() ? "found" : "missing",
                 (disabled_tools && disabled_tools[0]) ? disabled_tools : "(none)", run_dir);
    }
    free(b.ptr);
    return 1;
}

static int gsa_prepare_python_scripts_dir(const char *run_dir, char *err, size_t errsz) {
    char scripts[PATH_MAX], readme[PATH_MAX];
    snprintf(scripts, sizeof scripts, "%s/scripts", run_dir);
    mkpath(scripts);
    struct stat st;
    if (stat(scripts, &st) != 0 || !S_ISDIR(st.st_mode)) {
        snprintf(err, errsz, "could not create GSA scripts directory");
        return 0;
    }
    snprintf(readme, sizeof readme, "%s/README.md", scripts);
    static const char note[] =
        "# GSA local scripts\n\n"
        "This run is tool-assisted. Write small, bounded Python helpers here and save external-tool outputs here when automation is useful.\n"
        "Scripts and tool commands must save their inputs/outputs in this run directory and report failures explicitly.\n"
        "If an external tool fails because flags, parameters, input format, usage or timeout were wrong, update ../tool-retry-ledger.jsonl, inspect the same tool help when useful, and retry that same tool with corrected arguments or timeout budget before using a substitute.\n"
        "When a script or tool produces reusable evidence, append a normalized row to the matching ../workbench-*.jsonl file and link important rows from ../evidence.jsonl.\n"
        "External scanners are advisory only: a clean/empty result from sqlmap, nuclei, semgrep, trivy or similar must be cross-checked manually before a hypothesis is closed.\n";
    if (!jsonl_write_file(readme, note, strlen(note))) {
        snprintf(err, errsz, "could not write GSA scripts README: %s", strerror(errno));
        return 0;
    }
    return 1;
}

static int gsa_write_empty_artifacts(const char *run_dir, char *err, size_t errsz) {
    char scripts_manifest[PATH_MAX], evidence[PATH_MAX];
    snprintf(scripts_manifest, sizeof scripts_manifest, "%s/scripts_manifest.json", run_dir);
    snprintf(evidence, sizeof evidence, "%s/evidence.jsonl", run_dir);
    static const char manifest[] =
        "{\n"
        "  \"scripts\": [],\n"
        "  \"note\": \"GSA is tool-assisted. Update this file when scripts or external-tool commands are planned, written, run or fail. Tool output is advisory and must be cross-checked against code/artifact evidence. If a selected tool fails from bad flags, parameters, input shape or timeout, record it in tool-retry-ledger.jsonl and retry the same tool with corrected arguments or timeout budget before using any substitute. Reusable tool output should also be normalized into the matching workbench-*.jsonl artifact.\"\n"
        "}\n";
    if (!jsonl_write_file(scripts_manifest, manifest, strlen(manifest))) {
        snprintf(err, errsz, "could not write GSA scripts manifest: %s", strerror(errno));
        return 0;
    }
    if (!jsonl_write_file(evidence, "", 0)) {
        snprintf(err, errsz, "could not write GSA evidence log: %s", strerror(errno));
        return 0;
    }
    return 1;
}

typedef struct {
    char id[64];
    char adapter[48];
    char purpose[240];
    int timeout_sec;
    int max_retries;
} gsa_validation_plan_step;

typedef struct {
    char id[64];
    char adapter[48];
    char purpose[240];
    char status[32];
    char tool[96];
    char command[900];
    char artifact_path[PATH_MAX];
    char summary[700];
    int exit_status;
    int timeout_sec;
    int timed_out;
    long long elapsed_ms;
} gsa_validation_step_result;

static int gsa_append_file(const char *path, const char *data, size_t len) {
    FILE *f = fopen(path, "ab");
    if (!f) return 0;
    int ok = fwrite(data, 1, len, f) == len;
    fclose(f);
    return ok;
}

static int gsa_artifact_bool_field(const char *run_dir, const char *file, const char *field) {
    if (!run_dir || !file || !field) return 0;
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/%s", run_dir, file);
    size_t n = 0;
    char *body = jsonl_read_file(path, &n);
    if (!body) return 0;
    int ok = json_get_bool(body, field);
    free(body);
    return ok;
}

static const char *gsa_json_value_end_ptr(const char *p) {
    if (!p) return NULL;
    p += strspn(p, " \t\r\n");
    if (*p == '"') {
        for (p++; *p; p++) {
            if (*p == '\\' && p[1]) { p++; continue; }
            if (*p == '"') return p + 1;
        }
        return NULL;
    }
    if (*p == '{' || *p == '[') {
        char open = *p, close = open == '{' ? '}' : ']';
        int depth = 0, in_str = 0, esc = 0;
        (void)open;
        for (; *p; p++) {
            if (in_str) {
                if (esc) esc = 0;
                else if (*p == '\\') esc = 1;
                else if (*p == '"') in_str = 0;
                continue;
            }
            if (*p == '"') in_str = 1;
            else if (*p == open) depth++;
            else if (*p == close) {
                depth--;
                if (depth == 0) return p + 1;
            } else if ((*p == '{' || *p == '[') && *p != open) {
                depth++;
            } else if ((*p == '}' || *p == ']') && *p != close) {
                depth--;
                if (depth < 0) return NULL;
            }
        }
        return NULL;
    }
    while (*p && !strchr(",}\r\n\t ", *p)) p++;
    return p;
}

static int gsa_json_string_value_between(const char *start, const char *end,
                                         const char *key, char *out, size_t outsz,
                                         const char **after) {
    if (out && outsz) out[0] = '\0';
    if (after) *after = NULL;
    if (!start || !key || !out || !outsz) return 0;
    char pat[96];
    snprintf(pat, sizeof pat, "\"%s\"", key);
    const char *p = start;
    while ((p = strstr(p, pat)) && (!end || p < end)) {
        p += strlen(pat);
        while ((!end || p < end) && isspace((unsigned char)*p)) p++;
        if (end && p >= end) return 0;
        if (*p != ':') continue;
        p++;
        while ((!end || p < end) && isspace((unsigned char)*p)) p++;
        if (end && p >= end) return 0;
        if (*p != '"') continue;
        p++;
        size_t o = 0;
        while (*p && (!end || p < end) && *p != '"') {
            char c = *p++;
            if (c == '\\' && *p && (!end || p < end)) {
                char e = *p++;
                switch (e) {
                    case 'n': c = '\n'; break;
                    case 't': c = '\t'; break;
                    case 'r': c = '\r'; break;
                    case '"': c = '"'; break;
                    case '\\': c = '\\'; break;
                    case '/': c = '/'; break;
                    case 'u':
                        if ((!end || p + 4 <= end) && p[0] && p[1] && p[2] && p[3]) {
                            char hx[5] = { p[0], p[1], p[2], p[3], 0 };
                            long v = strtol(hx, NULL, 16);
                            p += 4;
                            c = (v > 0 && v < 0x80) ? (char)v : '?';
                        }
                        break;
                    default: c = e; break;
                }
            }
            if (o + 1 < outsz) out[o++] = c;
        }
        out[o] = '\0';
        if (after) *after = (*p == '"') ? p + 1 : p;
        return 1;
    }
    return 0;
}

static int gsa_validation_adapter_known(const char *adapter) {
    return adapter &&
           (!strcmp(adapter, "semgrep_scan") ||
            !strcmp(adapter, "http_probe") ||
            !strcmp(adapter, "playwright_flow"));
}

static int gsa_validation_plan_has_adapter(gsa_validation_plan_step *steps, int n,
                                           const char *adapter) {
    for (int i = 0; i < n; i++) {
        if (!strcmp(steps[i].adapter, adapter)) return 1;
    }
    return 0;
}

static int gsa_validation_plan_add_step(gsa_validation_plan_step *steps, int *n, int cap,
                                        const char *adapter, const char *purpose,
                                        int timeout_sec, int max_retries) {
    if (!steps || !n || *n >= cap || !adapter || !adapter[0]) return 0;
    if (gsa_validation_plan_has_adapter(steps, *n, adapter)) return 1;
    gsa_validation_plan_step *s = &steps[*n];
    memset(s, 0, sizeof *s);
    snprintf(s->id, sizeof s->id, "step-%d-%s", *n + 1, adapter);
    cstr_copy(s->adapter, sizeof s->adapter, adapter);
    cstr_copy(s->purpose, sizeof s->purpose, purpose ? purpose : "backend validation step");
    s->timeout_sec = timeout_sec > 0 ? timeout_sec : 20;
    s->max_retries = max_retries >= 0 ? max_retries : 0;
    (*n)++;
    return 1;
}

static int gsa_tool_alias_resolve(const char *alias, const char *managed, char *out, size_t outsz) {
    if (out && outsz) out[0] = '\0';
    if (!alias || !alias[0] || !out || !outsz) return 0;
    const char *dirs[8] = {0};
    size_t dirc = 0;
    if (managed && managed[0]) dirs[dirc++] = managed;
#ifndef _WIN32
    char localbin[PATH_MAX];
    const char *home = getenv("HOME");
    if (home && home[0]) {
        snprintf(localbin, sizeof localbin, "%s/.local/bin", home);
        dirs[dirc++] = localbin;
    }
    dirs[dirc++] = "/opt/homebrew/bin";
    dirs[dirc++] = "/usr/local/bin";
    dirs[dirc++] = "/usr/bin";
    dirs[dirc++] = "/bin";
#endif
    for (size_t d = 0; d < dirc; d++) {
        const char *dir = dirs[d];
        if (!dir || !dir[0]) continue;
        char full[PATH_MAX];
        if (path_join(full, sizeof full, dir, alias) && access(full, X_OK) == 0) {
            cstr_copy(out, outsz, full);
            return 1;
        }
#ifdef _WIN32
        const char *exts[] = { ".exe", ".cmd", ".bat", NULL };
        for (int i = 0; exts[i]; i++) {
            char extfull[PATH_MAX];
            snprintf(extfull, sizeof extfull, "%s%s", full, exts[i]);
            if (access(extfull, X_OK) == 0 || access(extfull, R_OK) == 0) {
                cstr_copy(out, outsz, extfull);
                return 1;
            }
        }
#endif
    }
    if (executable_on_path(alias)) {
        cstr_copy(out, outsz, alias);
        return 1;
    }
    return 0;
}

static int gsa_tool_resolve_name(const char *name, char *out, size_t outsz) {
    char managed[1200];
    gsa_tools_dir(managed, sizeof managed);
    gsa_tool_catalog catalog = {0};
    char err[512] = "";
    if (!gsa_load_tool_catalog(&catalog, err, sizeof err)) {
        return 0;
    }
    for (size_t i = 0; i < catalog.count; i++) {
        const gsa_tool_spec *t = &catalog.items[i];
        if (strcmp(t->name, name) != 0) continue;
        char aliases[512];
        cstr_copy(aliases, sizeof aliases, t->aliases);
        for (char *p = aliases; p && *p; ) {
            char *sep = strchr(p, '|');
            if (sep) *sep = '\0';
            if (gsa_tool_alias_resolve(p, managed, out, outsz)) {
                gsa_tool_catalog_free(&catalog);
                return 1;
            }
            p = sep ? sep + 1 : NULL;
        }
    }
    gsa_tool_catalog_free(&catalog);
    return 0;
}

static int gsa_run_cmd_capture_timeout(const char *cwd, char *const argv[],
                                       char *out, size_t outsz, int timeout_sec,
                                       long long *elapsed_ms, int *timed_out) {
    long long start = dstudio_now_ms();
    if (elapsed_ms) *elapsed_ms = 0;
    if (timed_out) *timed_out = 0;
    if (out && outsz) out[0] = '\0';
#ifdef _WIN32
    int rc = setup_run_cmd_capture(cwd, argv, out, outsz);
    if (elapsed_ms) *elapsed_ms = dstudio_now_ms() - start;
    return rc;
#else
    int pp[2];
    if (pipe(pp) != 0) {
        snprintf(out, outsz, "pipe failed: %s", strerror(errno));
        return 126;
    }
    pid_t pid = fork();
    if (pid < 0) {
        close(pp[0]);
        close(pp[1]);
        snprintf(out, outsz, "fork failed: %s", strerror(errno));
        return 126;
    }
    if (pid == 0) {
        if (cwd && cwd[0] && chdir(cwd) != 0) _exit(127);
        int dn = open("/dev/null", O_RDONLY);
        if (dn >= 0) { dup2(dn, STDIN_FILENO); close(dn); }
        dup2(pp[1], STDOUT_FILENO);
        dup2(pp[1], STDERR_FILENO);
        close(pp[0]);
        close(pp[1]);
        execvp(argv[0], argv);
        _exit(127);
    }
    close(pp[1]);
    int flags = fcntl(pp[0], F_GETFL, 0);
    if (flags >= 0) fcntl(pp[0], F_SETFL, flags | O_NONBLOCK);
    size_t used = 0;
    int status = 0, done = 0, rc = 126;
    int killed = 0;
    char buf[2048];
    while (!done) {
        for (;;) {
            ssize_t n = read(pp[0], buf, sizeof buf);
            if (n > 0) setup_capture_append(out, &used, outsz, buf, (size_t)n);
            else if (n == 0) break;
            else if (errno == EAGAIN || errno == EWOULDBLOCK) break;
            else if (errno != EINTR) break;
        }
        pid_t w = waitpid(pid, &status, WNOHANG);
        if (w == pid) {
            done = 1;
            break;
        }
        long long elapsed = dstudio_now_ms() - start;
        if (timeout_sec > 0 && elapsed > (long long)timeout_sec * 1000LL) {
            kill(pid, SIGKILL);
            killed = 1;
            if (timed_out) *timed_out = 1;
            waitpid(pid, &status, 0);
            done = 1;
            break;
        }
        usleep(20000);
    }
    for (;;) {
        ssize_t n = read(pp[0], buf, sizeof buf);
        if (n > 0) setup_capture_append(out, &used, outsz, buf, (size_t)n);
        else if (n == 0) break;
        else if (errno == EAGAIN || errno == EWOULDBLOCK || errno == EINTR) break;
        else break;
    }
    close(pp[0]);
    if (elapsed_ms) *elapsed_ms = dstudio_now_ms() - start;
    if (killed) return 124;
    if (WIFEXITED(status)) rc = WEXITSTATUS(status);
    else if (WIFSIGNALED(status)) rc = 128 + WTERMSIG(status);
    return rc;
#endif
}

static int gsa_validation_plan_from_preflight(const char *preflight_output,
                                              const char *profile_effective,
                                              const char *target_url,
                                              int operational,
                                              gsa_validation_plan_step *steps,
                                              int *step_count,
                                              char *source, size_t sourcesz) {
    if (step_count) *step_count = 0;
    if (source && sourcesz) source[0] = '\0';
    if (!steps || !step_count) return 0;
    const int blackhat = profile_effective && !strcmp(profile_effective, "black-hat");
    const int live_allowed = blackhat || operational;
    const char *plan_key = preflight_output ? strstr(preflight_output, "\"validationPlan\"") : NULL;
    const char *plan_start = NULL, *plan_end = NULL;
    if (plan_key) {
        plan_start = strchr(plan_key, ':');
        if (plan_start) {
            plan_start++;
            while (*plan_start && isspace((unsigned char)*plan_start)) plan_start++;
            plan_end = gsa_json_value_end_ptr(plan_start);
        }
    }
    if (plan_start && plan_end && plan_end > plan_start) {
        if (source && sourcesz) cstr_copy(source, sourcesz, "preflight.validationPlan");
        const char *p = plan_start;
        int unknown_seen = 0;
        while ((p = strstr(p, "\"adapter\"")) && p < plan_end) {
            char adapter[80] = "";
            const char *after = NULL;
            if (!gsa_json_string_value_between(p, plan_end, "adapter", adapter, sizeof adapter, &after)) {
                p += 9;
                continue;
            }
            if (gsa_validation_adapter_known(adapter)) {
                if (!strcmp(adapter, "semgrep_scan")) {
                    gsa_validation_plan_add_step(steps, step_count, 8, adapter,
                                                 "Run bounded Semgrep SAST over the workspace.", 30, 0);
                } else if (!strcmp(adapter, "http_probe")) {
                    if (live_allowed && target_url && target_url[0])
                        gsa_validation_plan_add_step(steps, step_count, 8, adapter,
                                                     "Probe the target URL for status, headers and redirect evidence.", 20, 0);
                } else if (!strcmp(adapter, "playwright_flow")) {
                    if (live_allowed && target_url && target_url[0])
                        gsa_validation_plan_add_step(steps, step_count, 8, adapter,
                                                     "Capture a bounded browser screenshot/flow against the target URL.", 35, 0);
                }
            } else {
                unknown_seen = 1;
                if (*step_count < 8) {
                    gsa_validation_plan_step *s = &steps[*step_count];
                    memset(s, 0, sizeof *s);
                    snprintf(s->id, sizeof s->id, "step-%d-invalid", *step_count + 1);
                    cstr_copy(s->adapter, sizeof s->adapter, adapter[0] ? adapter : "unknown");
                    cstr_copy(s->purpose, sizeof s->purpose, "Rejected validation-plan step with an unsupported adapter.");
                    s->timeout_sec = 0;
                    s->max_retries = 0;
                    (*step_count)++;
                }
            }
            p = after ? after : p + 9;
        }
        if (*step_count > 0 || unknown_seen) return 1;
    }

    if (source && sourcesz) cstr_copy(source, sourcesz, "fallback.generated-from-preflight");
    gsa_validation_plan_add_step(steps, step_count, 8, "semgrep_scan",
                                 "Run bounded Semgrep SAST over the workspace.", 30, 0);
    if (live_allowed && target_url && target_url[0]) {
        gsa_validation_plan_add_step(steps, step_count, 8, "http_probe",
                                     "Probe the target URL for status, headers and redirect evidence.", 20, 0);
        gsa_validation_plan_add_step(steps, step_count, 8, "playwright_flow",
                                     "Capture a bounded browser screenshot/flow against the target URL.", 35, 0);
    }
    return *step_count > 0;
}

static int gsa_write_validation_plan_artifact(const char *run_dir, const char *profile_effective,
                                              const char *target_url, const char *target_host,
                                              const char *source,
                                              const gsa_validation_plan_step *steps, int step_count,
                                              char *err, size_t errsz) {
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/validation-plan.json", run_dir);
    json_dyn_buf b = {0};
    int ok = json_dyn_puts(&b, "{\n  \"schemaVersion\": 1,\n  \"source\": ") &&
             json_dyn_put_escaped(&b, source ? source : "fallback.generated") &&
             json_dyn_puts(&b, ",\n  \"profile\": ") &&
             json_dyn_put_escaped(&b, profile_effective ? profile_effective : "passive") &&
             json_dyn_puts(&b, ",\n  \"targetUrl\": ") &&
             json_dyn_put_escaped(&b, target_url ? target_url : "") &&
             json_dyn_puts(&b, ",\n  \"targetHost\": ") &&
             json_dyn_put_escaped(&b, target_host ? target_host : "") &&
             json_dyn_puts(&b, ",\n  \"hypotheses\": [{\"source\":\"preflight.json\",\"note\":\"Executor links runtime evidence back through validation-results.json.\"}],\n") &&
             json_dyn_puts(&b, "  \"budgets\": {\"maxSteps\": 8, \"defaultTimeoutSec\": 30, \"networkTimeoutSec\": 20},\n") &&
             json_dyn_puts(&b, "  \"requestedArtifacts\": [\"validation-results.json\", \"evidence-graph.json\", \"workbench-tool-runs.jsonl\"],\n") &&
             json_dyn_puts(&b, "  \"steps\": [\n");
    for (int i = 0; ok && i < step_count; i++) {
        const gsa_validation_plan_step *s = &steps[i];
        ok = json_dyn_puts(&b, i ? ",\n    {" : "    {") &&
             json_dyn_puts(&b, "\"id\":") && json_dyn_put_escaped(&b, s->id) &&
             json_dyn_puts(&b, ",\"adapter\":") && json_dyn_put_escaped(&b, s->adapter) &&
             json_dyn_puts(&b, ",\"purpose\":") && json_dyn_put_escaped(&b, s->purpose) &&
             json_dyn_puts(&b, ",\"dependsOn\":[],\"timeoutSec\":") &&
             json_dyn_printf(&b, "%d", s->timeout_sec) &&
             json_dyn_puts(&b, ",\"maxRetries\":") &&
             json_dyn_printf(&b, "%d", s->max_retries) &&
             json_dyn_puts(&b, "}");
    }
    ok = ok && json_dyn_puts(&b, "\n  ]\n}\n");
    if (!ok || !jsonl_write_file(path, b.ptr ? b.ptr : "", b.len)) {
        snprintf(err, errsz, "could not write validation-plan.json: %s", strerror(errno));
        free(b.ptr);
        return 0;
    }
    free(b.ptr);
    return 1;
}

static void gsa_validation_command_string(char *out, size_t outsz, char *const argv[]) {
    if (!out || !outsz) return;
    out[0] = '\0';
    size_t used = 0;
    for (int i = 0; argv && argv[i]; i++) {
        const char *a = argv[i];
        int needs_quote = strpbrk(a, " \t\n\"'\\") != NULL;
        if (i && used + 1 < outsz) out[used++] = ' ';
        if (needs_quote && used + 1 < outsz) out[used++] = '"';
        for (const char *p = a; *p && used + 2 < outsz; p++) {
            if (*p == '"' || *p == '\\') out[used++] = '\\';
            out[used++] = *p;
        }
        if (needs_quote && used + 1 < outsz) out[used++] = '"';
    }
    out[used < outsz ? used : outsz - 1] = '\0';
}

static void gsa_validation_write_result_artifact(const char *path, const char *output) {
    json_dyn_buf b = {0};
    if (json_dyn_puts(&b, output ? output : "") &&
        (!b.len || b.ptr[b.len - 1] != '\n' ? json_dyn_puts(&b, "\n") : 1))
    {
        jsonl_write_file(path, b.ptr ? b.ptr : "", b.len);
    }
    free(b.ptr);
}

static int gsa_validation_test_mode(void) {
    const char *v = getenv("DS4UI_TEST_MODE");
    return v && v[0] && strcmp(v, "0") != 0;
}

static int gsa_validation_skip_for_test_mode(const char *adapter, const char *outpath,
                                             gsa_validation_step_result *r) {
    if (!gsa_validation_test_mode()) return 0;
    cstr_copy(r->tool, sizeof r->tool, adapter ? adapter : "validation-adapter");
    cstr_copy(r->status, sizeof r->status, "skipped");
    snprintf(r->summary, sizeof r->summary,
             "%s skipped because DS4UI_TEST_MODE is active; runtime artifacts were still produced.",
             adapter ? adapter : "validation adapter");
    gsa_validation_write_result_artifact(outpath, r->summary);
    return 1;
}

static void gsa_validation_record_jsonl(const char *run_dir,
                                        const gsa_validation_step_result *r,
                                        const char *domain) {
    char tool_runs[PATH_MAX], domain_path[PATH_MAX], evidence[PATH_MAX], ledger[PATH_MAX];
    snprintf(tool_runs, sizeof tool_runs, "%s/workbench-tool-runs.jsonl", run_dir);
    snprintf(domain_path, sizeof domain_path, "%s/workbench-%s.jsonl", run_dir, domain ? domain : "code");
    snprintf(evidence, sizeof evidence, "%s/evidence.jsonl", run_dir);
    snprintf(ledger, sizeof ledger, "%s/tool-retry-ledger.jsonl", run_dir);
    json_dyn_buf row = {0};
    int ok = json_dyn_puts(&row, "{\"id\":") && json_dyn_put_escaped(&row, r->id) &&
             json_dyn_puts(&row, ",\"domain\":\"tool-run\",\"tool\":") && json_dyn_put_escaped(&row, r->tool) &&
             json_dyn_puts(&row, ",\"source\":\"validation-executor\",\"status\":") && json_dyn_put_escaped(&row, r->status) &&
             json_dyn_puts(&row, ",\"command\":") && json_dyn_put_escaped(&row, r->command) &&
             json_dyn_puts(&row, ",\"artifactPath\":") && json_dyn_put_escaped(&row, r->artifact_path) &&
             json_dyn_puts(&row, ",\"summary\":") && json_dyn_put_escaped(&row, r->summary) &&
             json_dyn_printf(&row, ",\"exitStatus\":%d,\"elapsedMs\":%lld,\"timeoutSec\":%d,\"timedOut\":%s}\n",
                             r->exit_status, r->elapsed_ms, r->timeout_sec, r->timed_out ? "true" : "false");
    if (ok) gsa_append_file(tool_runs, row.ptr, row.len);
    free(row.ptr);

    row = (json_dyn_buf){0};
    ok = json_dyn_puts(&row, "{\"id\":") && json_dyn_put_escaped(&row, r->id) &&
         json_dyn_puts(&row, ",\"domain\":") && json_dyn_put_escaped(&row, domain ? domain : "code") &&
         json_dyn_puts(&row, ",\"tool\":") && json_dyn_put_escaped(&row, r->tool) &&
         json_dyn_puts(&row, ",\"source\":\"validation-executor\",\"status\":") && json_dyn_put_escaped(&row, r->status) &&
         json_dyn_puts(&row, ",\"command\":") && json_dyn_put_escaped(&row, r->command) &&
         json_dyn_puts(&row, ",\"artifactPath\":") && json_dyn_put_escaped(&row, r->artifact_path) &&
         json_dyn_puts(&row, ",\"summary\":") && json_dyn_put_escaped(&row, r->summary) &&
         json_dyn_puts(&row, ",\"confidence\":\"medium\",\"scope\":\"backend-executed validation\",\"claimRefs\":[]}\n");
    if (ok) gsa_append_file(domain_path, row.ptr, row.len);
    free(row.ptr);

    row = (json_dyn_buf){0};
    ok = json_dyn_puts(&row, "{\"finding\":\"validation-runtime-advisory\",\"source\":") &&
         json_dyn_put_escaped(&row, r->artifact_path) &&
         json_dyn_puts(&row, ",\"status\":") && json_dyn_put_escaped(&row, r->status) &&
         json_dyn_puts(&row, ",\"excerpt\":") && json_dyn_put_escaped(&row, r->summary) &&
         json_dyn_puts(&row, "}\n");
    if (ok) gsa_append_file(evidence, row.ptr, row.len);
    free(row.ptr);

    if (strcmp(r->status, "complete") != 0) {
        row = (json_dyn_buf){0};
        ok = json_dyn_puts(&row, "{\"tool\":") && json_dyn_put_escaped(&row, r->tool) &&
             json_dyn_puts(&row, ",\"attempt\":1,\"command\":") && json_dyn_put_escaped(&row, r->command) &&
             json_dyn_puts(&row, ",\"status\":") && json_dyn_put_escaped(&row, r->status) &&
             json_dyn_printf(&row, ",\"exitStatus\":%d,\"elapsedSec\":%lld,\"wrapperTimeoutSec\":%d,\"reason\":",
                             r->exit_status, r->elapsed_ms / 1000, r->timeout_sec) &&
             json_dyn_put_escaped(&row, r->summary) &&
             json_dyn_puts(&row, ",\"next\":\"validation_model_interprets_missing_or_failed_evidence\"}\n");
        if (ok) gsa_append_file(ledger, row.ptr, row.len);
        free(row.ptr);
    }
}

static void gsa_execute_semgrep_adapter(const char *run_dir, const char *workdir,
                                        const gsa_validation_plan_step *step,
                                        gsa_validation_step_result *r) {
    cstr_copy(r->tool, sizeof r->tool, "semgrep");
    char tool[PATH_MAX] = "";
    char outpath[PATH_MAX];
    snprintf(outpath, sizeof outpath, "%s/validation-runtime/%s.out.txt", run_dir, step->id);
    cstr_copy(r->artifact_path, sizeof r->artifact_path, outpath);
    r->timeout_sec = step->timeout_sec > 0 ? step->timeout_sec : 30;
    if (gsa_validation_skip_for_test_mode("semgrep_scan", outpath, r)) return;
    if (!gsa_tool_resolve_name("semgrep", tool, sizeof tool)) {
        cstr_copy(r->status, sizeof r->status, "skipped");
        cstr_copy(r->summary, sizeof r->summary, "semgrep not found; code validation remains model/manual evidence only.");
        gsa_validation_write_result_artifact(outpath, r->summary);
        return;
    }
    char *argv[] = { tool, "--config", "auto", "--json", "--no-git-ignore",
                     "--timeout", "10", "--max-target-bytes", "1000000", ".", NULL };
    gsa_validation_command_string(r->command, sizeof r->command, argv);
    char capture[32768] = "";
    int timed_out = 0;
    long long elapsed = 0;
    int rc = gsa_run_cmd_capture_timeout(workdir, argv, capture, sizeof capture, r->timeout_sec, &elapsed, &timed_out);
    r->exit_status = rc;
    r->elapsed_ms = elapsed;
    r->timed_out = timed_out;
    cstr_copy(r->status, sizeof r->status, timed_out ? "timed_out" : (rc == 0 ? "complete" : "failed"));
    snprintf(r->summary, sizeof r->summary, "semgrep_scan %s with exit status %d; output saved for advisory review.",
             r->status, rc);
    gsa_validation_write_result_artifact(outpath, capture[0] ? capture : r->summary);
}

static void gsa_execute_http_adapter(const char *run_dir, const char *target_url,
                                     const gsa_validation_plan_step *step,
                                     gsa_validation_step_result *r) {
    char outpath[PATH_MAX];
    snprintf(outpath, sizeof outpath, "%s/validation-runtime/%s.out.txt", run_dir, step->id);
    cstr_copy(r->artifact_path, sizeof r->artifact_path, outpath);
    r->timeout_sec = step->timeout_sec > 0 ? step->timeout_sec : 20;
    if (gsa_validation_skip_for_test_mode("http_probe", outpath, r)) return;
    if (!target_url || !target_url[0]) {
        cstr_copy(r->tool, sizeof r->tool, "http_probe");
        cstr_copy(r->status, sizeof r->status, "skipped");
        cstr_copy(r->summary, sizeof r->summary, "http_probe skipped because no target URL is present.");
        gsa_validation_write_result_artifact(outpath, r->summary);
        return;
    }
    char httpx[PATH_MAX] = "", curl[PATH_MAX] = "";
    char *argv_httpx[] = { httpx, "-silent", "-status-code", "-title", "-tech-detect", "-u", (char *)target_url, NULL };
    char *argv_curl[] = { curl, "-I", "-L", "--max-time", "10", (char *)target_url, NULL };
    char **argv = NULL;
    if (gsa_tool_resolve_name("httpx", httpx, sizeof httpx)) {
        cstr_copy(r->tool, sizeof r->tool, "httpx");
        argv = argv_httpx;
    } else if (gsa_tool_alias_resolve("curl", NULL, curl, sizeof curl)) {
        cstr_copy(r->tool, sizeof r->tool, "curl");
        argv = argv_curl;
    } else {
        cstr_copy(r->tool, sizeof r->tool, "http_probe");
        cstr_copy(r->status, sizeof r->status, "skipped");
        cstr_copy(r->summary, sizeof r->summary, "http_probe skipped because neither httpx nor curl is available.");
        gsa_validation_write_result_artifact(outpath, r->summary);
        return;
    }
    gsa_validation_command_string(r->command, sizeof r->command, argv);
    char capture[32768] = "";
    int timed_out = 0;
    long long elapsed = 0;
    int rc = gsa_run_cmd_capture_timeout(NULL, (char *const *)argv, capture, sizeof capture, r->timeout_sec, &elapsed, &timed_out);
    r->exit_status = rc;
    r->elapsed_ms = elapsed;
    r->timed_out = timed_out;
    cstr_copy(r->status, sizeof r->status, timed_out ? "timed_out" : (rc == 0 ? "complete" : "failed"));
    snprintf(r->summary, sizeof r->summary, "http_probe %s with %s exit status %d; output saved for advisory review.",
             r->status, r->tool, rc);
    gsa_validation_write_result_artifact(outpath, capture[0] ? capture : r->summary);
}

static void gsa_execute_playwright_adapter(const char *run_dir, const char *target_url,
                                           const gsa_validation_plan_step *step,
                                           gsa_validation_step_result *r) {
    cstr_copy(r->tool, sizeof r->tool, "playwright");
    char outpath[PATH_MAX], screenshot[PATH_MAX];
    snprintf(outpath, sizeof outpath, "%s/validation-runtime/%s.out.txt", run_dir, step->id);
    snprintf(screenshot, sizeof screenshot, "%s/validation-runtime/%s.png", run_dir, step->id);
    cstr_copy(r->artifact_path, sizeof r->artifact_path, screenshot);
    r->timeout_sec = step->timeout_sec > 0 ? step->timeout_sec : 35;
    if (gsa_validation_skip_for_test_mode("playwright_flow", outpath, r)) {
        cstr_copy(r->artifact_path, sizeof r->artifact_path, outpath);
        return;
    }
    if (!target_url || !target_url[0]) {
        cstr_copy(r->status, sizeof r->status, "skipped");
        cstr_copy(r->summary, sizeof r->summary, "playwright_flow skipped because no target URL is present.");
        gsa_validation_write_result_artifact(outpath, r->summary);
        return;
    }
    char tool[PATH_MAX] = "";
    if (!gsa_tool_resolve_name("playwright", tool, sizeof tool)) {
        cstr_copy(r->status, sizeof r->status, "skipped");
        cstr_copy(r->summary, sizeof r->summary, "playwright not found; browser validation remains model/manual evidence only.");
        gsa_validation_write_result_artifact(outpath, r->summary);
        return;
    }
    char *argv[] = { tool, "screenshot", "--timeout=10000", (char *)target_url, screenshot, NULL };
    gsa_validation_command_string(r->command, sizeof r->command, argv);
    char capture[32768] = "";
    int timed_out = 0;
    long long elapsed = 0;
    int rc = gsa_run_cmd_capture_timeout(NULL, argv, capture, sizeof capture, r->timeout_sec, &elapsed, &timed_out);
    r->exit_status = rc;
    r->elapsed_ms = elapsed;
    r->timed_out = timed_out;
    cstr_copy(r->status, sizeof r->status, timed_out ? "timed_out" : (rc == 0 ? "complete" : "failed"));
    snprintf(r->summary, sizeof r->summary, "playwright_flow %s with exit status %d; screenshot/output saved when available.",
             r->status, rc);
    gsa_validation_write_result_artifact(outpath, capture[0] ? capture : r->summary);
    if (rc != 0 && access(screenshot, R_OK) != 0) cstr_copy(r->artifact_path, sizeof r->artifact_path, outpath);
}

static void gsa_execute_invalid_adapter(const gsa_validation_plan_step *step,
                                        gsa_validation_step_result *r) {
    cstr_copy(r->tool, sizeof r->tool, step->adapter[0] ? step->adapter : "unknown");
    cstr_copy(r->status, sizeof r->status, "failed");
    r->exit_status = 127;
    snprintf(r->summary, sizeof r->summary, "unsupported validation adapter rejected: %s", r->tool);
}

static int gsa_write_validation_results_artifacts(const char *run_dir, const char *profile_effective,
                                                  const gsa_validation_step_result *results, int result_count,
                                                  char *err, size_t errsz) {
    char results_path[PATH_MAX], graph_path[PATH_MAX];
    snprintf(results_path, sizeof results_path, "%s/validation-results.json", run_dir);
    snprintf(graph_path, sizeof graph_path, "%s/evidence-graph.json", run_dir);
    int complete = 0, failed = 0, skipped = 0;
    for (int i = 0; i < result_count; i++) {
        if (!strcmp(results[i].status, "complete")) complete++;
        else if (!strcmp(results[i].status, "skipped")) skipped++;
        else failed++;
    }
    const char *overall = failed ? "partial" : (complete ? "complete" : "skipped");
    json_dyn_buf b = {0};
    int ok = json_dyn_puts(&b, "{\n  \"schemaVersion\": 1,\n  \"status\": ") &&
             json_dyn_put_escaped(&b, overall) &&
             json_dyn_puts(&b, ",\n  \"profile\": ") &&
             json_dyn_put_escaped(&b, profile_effective ? profile_effective : "passive") &&
             json_dyn_printf(&b, ",\n  \"summary\": {\"steps\": %d, \"complete\": %d, \"failed\": %d, \"skipped\": %d},\n  \"steps\": [\n",
                             result_count, complete, failed, skipped);
    for (int i = 0; ok && i < result_count; i++) {
        const gsa_validation_step_result *r = &results[i];
        ok = json_dyn_puts(&b, i ? ",\n    {" : "    {") &&
             json_dyn_puts(&b, "\"id\":") && json_dyn_put_escaped(&b, r->id) &&
             json_dyn_puts(&b, ",\"adapter\":") && json_dyn_put_escaped(&b, r->adapter) &&
             json_dyn_puts(&b, ",\"purpose\":") && json_dyn_put_escaped(&b, r->purpose) &&
             json_dyn_puts(&b, ",\"status\":") && json_dyn_put_escaped(&b, r->status) &&
             json_dyn_puts(&b, ",\"tool\":") && json_dyn_put_escaped(&b, r->tool) &&
             json_dyn_puts(&b, ",\"command\":") && json_dyn_put_escaped(&b, r->command) &&
             json_dyn_puts(&b, ",\"artifactPath\":") && json_dyn_put_escaped(&b, r->artifact_path) &&
             json_dyn_puts(&b, ",\"summary\":") && json_dyn_put_escaped(&b, r->summary) &&
             json_dyn_printf(&b, ",\"exitStatus\":%d,\"elapsedMs\":%lld,\"timedOut\":%s}",
                             r->exit_status, r->elapsed_ms, r->timed_out ? "true" : "false");
    }
    ok = ok && json_dyn_puts(&b, "\n  ],\n  \"artifacts\": [\"validation-plan.json\", \"validation-results.json\", \"evidence-graph.json\", \"workbench-tool-runs.jsonl\"],\n  \"findings\": [],\n  \"errors\": []\n}\n");
    if (!ok || !jsonl_write_file(results_path, b.ptr ? b.ptr : "", b.len)) {
        snprintf(err, errsz, "could not write validation-results.json: %s", strerror(errno));
        free(b.ptr);
        return 0;
    }
    free(b.ptr);

    b = (json_dyn_buf){0};
    ok = json_dyn_printf(&b,
                         "{\n  \"schemaVersion\": 1,\n  \"status\": \"built\",\n  \"nodes\": [\n"
                         "    {\"id\":\"validation-plan\",\"kind\":\"plan\",\"artifact\":\"validation-plan.json\"}");
    for (int i = 0; ok && i < result_count; i++) {
        ok = json_dyn_puts(&b, ",\n    {\"id\":") && json_dyn_put_escaped(&b, results[i].id) &&
             json_dyn_puts(&b, ",\"kind\":\"step\",\"adapter\":") && json_dyn_put_escaped(&b, results[i].adapter) &&
             json_dyn_puts(&b, ",\"status\":") && json_dyn_put_escaped(&b, results[i].status) &&
             json_dyn_puts(&b, ",\"artifact\":") && json_dyn_put_escaped(&b, results[i].artifact_path) &&
             json_dyn_puts(&b, "}");
    }
    ok = ok && json_dyn_puts(&b, "\n  ],\n  \"edges\": [");
    for (int i = 0; ok && i < result_count; i++) {
        ok = json_dyn_puts(&b, i ? ",\n    " : "\n    ") &&
             json_dyn_puts(&b, "{\"from\":\"validation-plan\",\"to\":") &&
             json_dyn_put_escaped(&b, results[i].id) &&
             json_dyn_puts(&b, ",\"type\":\"executes\"}");
    }
    ok = ok && json_dyn_puts(&b, "\n  ],\n  \"claims\": [],\n  \"missingLinks\": [");
    int first_missing = 1;
    for (int i = 0; ok && i < result_count; i++) {
        if (!strcmp(results[i].status, "complete")) continue;
        ok = json_dyn_puts(&b, first_missing ? "" : ",") &&
             json_dyn_puts(&b, "\n    {\"step\":") &&
             json_dyn_put_escaped(&b, results[i].id) &&
             json_dyn_puts(&b, ",\"reason\":") &&
             json_dyn_put_escaped(&b, results[i].summary) &&
             json_dyn_puts(&b, "}");
        first_missing = 0;
    }
    ok = ok && json_dyn_puts(&b, "\n  ]\n}\n");
    if (!ok || !jsonl_write_file(graph_path, b.ptr ? b.ptr : "", b.len)) {
        snprintf(err, errsz, "could not write evidence-graph.json: %s", strerror(errno));
        free(b.ptr);
        return 0;
    }
    free(b.ptr);
    return 1;
}

static int gsa_execute_validation_plan(const char *run_dir, const char *workdir,
                                       const char *preflight_output,
                                       char *err, size_t errsz) {
    char profile_effective[80] = "passive";
    char target_url[1024] = "", target_host[512] = "";
    gsa_state_string_field(run_dir, "profileEffective", profile_effective, sizeof profile_effective);
    gsa_state_string_field(run_dir, "targetUrl", target_url, sizeof target_url);
    gsa_state_string_field(run_dir, "targetHost", target_host, sizeof target_host);
    const int operational = gsa_artifact_bool_field(run_dir, "safety-gate.json", "operational");
    gsa_validation_plan_step steps[8];
    memset(steps, 0, sizeof steps);
    int step_count = 0;
    char source[96] = "";
    if (!gsa_validation_plan_from_preflight(preflight_output, profile_effective, target_url,
                                            operational, steps, &step_count, source, sizeof source))
    {
        snprintf(err, errsz, "could not build validation plan");
        return 0;
    }
    if (!gsa_write_validation_plan_artifact(run_dir, profile_effective, target_url, target_host,
                                            source, steps, step_count, err, errsz))
        return 0;
    char runtime_dir[PATH_MAX];
    snprintf(runtime_dir, sizeof runtime_dir, "%s/validation-runtime", run_dir);
    mkpath(runtime_dir);
    gsa_validation_step_result results[8];
    memset(results, 0, sizeof results);
    for (int i = 0; i < step_count; i++) {
        const gsa_validation_plan_step *s = &steps[i];
        gsa_validation_step_result *r = &results[i];
        cstr_copy(r->id, sizeof r->id, s->id);
        cstr_copy(r->adapter, sizeof r->adapter, s->adapter);
        cstr_copy(r->purpose, sizeof r->purpose, s->purpose);
        r->timeout_sec = s->timeout_sec;
        if (!strcmp(s->adapter, "semgrep_scan")) {
            gsa_execute_semgrep_adapter(run_dir, workdir, s, r);
            gsa_validation_record_jsonl(run_dir, r, "code");
        } else if (!strcmp(s->adapter, "http_probe")) {
            gsa_execute_http_adapter(run_dir, target_url, s, r);
            gsa_validation_record_jsonl(run_dir, r, "web");
        } else if (!strcmp(s->adapter, "playwright_flow")) {
            gsa_execute_playwright_adapter(run_dir, target_url, s, r);
            gsa_validation_record_jsonl(run_dir, r, "web");
        } else {
            char outpath[PATH_MAX];
            snprintf(outpath, sizeof outpath, "%s/validation-runtime/%s.out.txt", run_dir, s->id);
            cstr_copy(r->artifact_path, sizeof r->artifact_path, outpath);
            gsa_execute_invalid_adapter(s, r);
            gsa_validation_write_result_artifact(outpath, r->summary);
            gsa_validation_record_jsonl(run_dir, r, "code");
        }
    }
    return gsa_write_validation_results_artifacts(run_dir, profile_effective, results, step_count, err, errsz);
}

static long long gsa_state_long_field(const char *run_dir, const char *field, long long def) {
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/run_state.json", run_dir);
    size_t n = 0;
    char *body = jsonl_read_file(path, &n);
    if (!body) return def;
    char pat[96];
    snprintf(pat, sizeof pat, "\"%s\"", field);
    const char *p = strstr(body, pat);
    int ok = 0;
    long long v = def;
    if (p) {
        p += strlen(pat);
        while (*p == ' ' || *p == '\t') p++;
        if (*p == ':') {
            p++;
            while (*p == ' ' || *p == '\t') p++;
            char *end = NULL;
            v = strtoll(p, &end, 10);
            ok = end && end != p;
        }
    }
    free(body);
    return ok ? v : def;
}

static int gsa_state_string_field(const char *run_dir, const char *field, char *out, size_t outsz) {
    if (out && outsz) out[0] = '\0';
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/run_state.json", run_dir);
    size_t n = 0;
    char *body = jsonl_read_file(path, &n);
    if (!body) return 0;
    int ok = json_get_string(body, field, out, outsz);
    free(body);
    return ok;
}

static int gsa_write_run_state(const char *run_dir, const char *run_id,
                               const char *status, const char *phase,
                               int iteration, const char *parent_run_dir,
                               const char *target_url, const char *target_host,
                               const char *error, const char *profile_requested_override,
                               const char *profile_effective_override,
                               char *err, size_t errsz) {
    long long now = dstudio_now_ms();
    long long started = gsa_state_long_field(run_dir, "startedMs", now);
    if (iteration <= 0) iteration = (int)gsa_state_long_field(run_dir, "iteration", 1);
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/run_state.json", run_dir);
    char scope_path[PATH_MAX] = "", safety_path[PATH_MAX] = "";
    char profile_requested[80] = "", profile_effective[80] = "";
    snprintf(scope_path, sizeof scope_path, "%s/scope.json", run_dir);
    snprintf(safety_path, sizeof safety_path, "%s/safety-gate.json", run_dir);
    if (profile_requested_override && profile_requested_override[0]) {
        cstr_copy(profile_requested, sizeof profile_requested, gsa_security_profile_normalize(profile_requested_override));
    }
    if (profile_effective_override && profile_effective_override[0]) {
        cstr_copy(profile_effective, sizeof profile_effective, gsa_security_profile_normalize(profile_effective_override));
    }
    if (!profile_requested[0]) {
        gsa_artifact_string_field(run_dir, "scope.json", "profileRequested", profile_requested, sizeof profile_requested);
    }
    if (!profile_effective[0]) {
        gsa_artifact_string_field(run_dir, "safety-gate.json", "profileEffective", profile_effective, sizeof profile_effective);
    }
    if (!profile_requested[0]) {
        gsa_state_string_field(run_dir, "profileRequested", profile_requested, sizeof profile_requested);
    }
    if (!profile_effective[0]) {
        gsa_state_string_field(run_dir, "profileEffective", profile_effective, sizeof profile_effective);
    }
    if (!profile_requested[0]) cstr_copy(profile_requested, sizeof profile_requested, "passive");
    if (!profile_effective[0]) cstr_copy(profile_effective, sizeof profile_effective, profile_requested);
    if (!gsa_profile_uses_scope_gate(profile_effective)) {
        scope_path[0] = '\0';
        safety_path[0] = '\0';
    }
    json_dyn_buf b = {0};
    int ok = json_dyn_puts(&b, "{\n  \"runId\": ") &&
             json_dyn_put_escaped(&b, run_id ? run_id : "") &&
             json_dyn_puts(&b, ",\n  \"status\": ") &&
             json_dyn_put_escaped(&b, status ? status : "incomplete") &&
             json_dyn_puts(&b, ",\n  \"phase\": ") &&
             json_dyn_put_escaped(&b, phase ? phase : "start") &&
             json_dyn_printf(&b, ",\n  \"iteration\": %d,\n  \"startedMs\": %lld,\n  \"updatedMs\": %lld,\n  \"completedMs\": %lld,\n  \"parentRunDir\": ",
                             iteration, started, now, status && !strcmp(status, "complete") ? now : 0) &&
             json_dyn_put_escaped(&b, parent_run_dir ? parent_run_dir : "") &&
             json_dyn_puts(&b, ",\n  \"targetUrl\": ") &&
             json_dyn_put_escaped(&b, target_url ? target_url : "") &&
             json_dyn_puts(&b, ",\n  \"targetHost\": ") &&
             json_dyn_put_escaped(&b, target_host ? target_host : "") &&
             json_dyn_puts(&b, ",\n  \"profileRequested\": ") &&
             json_dyn_put_escaped(&b, profile_requested) &&
             json_dyn_puts(&b, ",\n  \"profileEffective\": ") &&
             json_dyn_put_escaped(&b, profile_effective) &&
             json_dyn_puts(&b, ",\n  \"scopePath\": ") &&
             json_dyn_put_escaped(&b, scope_path) &&
             json_dyn_puts(&b, ",\n  \"safetyGatePath\": ") &&
             json_dyn_put_escaped(&b, safety_path) &&
             json_dyn_puts(&b, ",\n  \"error\": ") &&
             json_dyn_put_escaped(&b, error ? error : "") &&
             json_dyn_puts(&b, "\n}\n");
    if (!ok || !jsonl_write_file(path, b.ptr ? b.ptr : "", b.len)) {
        snprintf(err, errsz, "could not write GSA run state: %s", strerror(errno));
        free(b.ptr);
        return 0;
    }
    free(b.ptr);
    return 1;
}

static int gsa_validate_parent_run_dir(const char *workdir_abs, const char *raw,
                                       char *out, size_t outsz,
                                       char *err, size_t errsz) {
    if (out && outsz) out[0] = '\0';
    if (!raw || !raw[0]) return 1;
    char runs[PATH_MAX], real_runs[PATH_MAX], real_parent[PATH_MAX];
    snprintf(runs, sizeof runs, "%s/.dstudio/gsa/runs", workdir_abs);
    if (!realpath(runs, real_runs)) {
        snprintf(err, errsz, "GSA runs directory does not exist for loop parent");
        return 0;
    }
    if (!realpath(raw, real_parent)) {
        snprintf(err, errsz, "parentRunDir not found");
        return 0;
    }
    if (!gsa_path_under(real_parent, real_runs)) {
        snprintf(err, errsz, "parentRunDir must be inside this workspace GSA runs directory");
        return 0;
    }
    const char *base = strrchr(real_parent, '/');
#ifdef _WIN32
    const char *b2 = strrchr(real_parent, '\\');
    if (!base || (b2 && b2 > base)) base = b2;
#endif
    base = base ? base + 1 : real_parent;
    if (!gsa_run_id_ok(base)) {
        snprintf(err, errsz, "parentRunDir has an invalid run id");
        return 0;
    }
    char status[64] = "";
    if (!gsa_state_string_field(real_parent, "status", status, sizeof status) ||
        strcmp(status, "complete") != 0)
    {
        snprintf(err, errsz, "previous GSA run is incomplete; loop stopped before starting another run");
        return 0;
    }
    if (out && outsz) cstr_copy(out, outsz, real_parent);
    return 1;
}

static void gsa_append_run_file_excerpt(json_dyn_buf *b, const char *run_dir,
                                        const char *name, const char *title,
                                        size_t max_bytes) {
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/%s", run_dir, name);
    size_t n = 0;
    char *body = jsonl_read_file(path, &n);
    if (!body) return;
    if (n > max_bytes) {
        n = max_bytes;
        body[n] = '\0';
    }
    json_dyn_printf(b, "\n## %s\n\nSource: `%s`\n\n```text\n", title, path);
    json_dyn_putn(b, body, n);
    if (n == max_bytes) json_dyn_puts(b, "\n... truncated ...");
    json_dyn_puts(b, "\n```\n");
    free(body);
}

static int gsa_write_loop_context(const char *run_dir, const char *parent_run_dir,
                                  char *err, size_t errsz) {
    if (!parent_run_dir || !parent_run_dir[0]) return 1;
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/loop_context.md", run_dir);
    json_dyn_buf b = {0};
    int ok = json_dyn_printf(&b,
        "# GSA loop context\n\n"
        "Previous run: `%s`\n\n"
        "Read this before selecting scope. Try a different plausible path unless the previous run added concrete new evidence. "
        "Also look for attack chains: multiple individually weak findings, leaks, auth gaps, parser behavior, config drift, exposed artifacts, or operational evidence may combine into a stronger exploit path. "
        "Do not repeat the same single-vulnerability hypothesis unless new evidence changes it; prefer validating or killing a concrete chain that uses previous evidence plus one or two new links. "
        "If this iteration cannot add new evidence or a plausible new chain, say so clearly and stop with `inconclusive` instead of inflating severity.\n",
        parent_run_dir);
    if (ok) gsa_append_run_file_excerpt(&b, parent_run_dir, "run_state.json", "Previous run state", 4096);
    if (ok) gsa_append_run_file_excerpt(&b, parent_run_dir, "validation.json", "Previous validation", 8192);
    if (ok) gsa_append_run_file_excerpt(&b, parent_run_dir, "report.md", "Previous report", 8192);
    if (ok) gsa_append_run_file_excerpt(&b, parent_run_dir, "selection.json", "Previous selection", 8192);
    if (!ok || !jsonl_write_file(path, b.ptr ? b.ptr : "", b.len)) {
        snprintf(err, errsz, "could not write GSA loop context: %s", strerror(errno));
        free(b.ptr);
        return 0;
    }
    free(b.ptr);
    return 1;
}

static int gsa_json_object_valid(const char *s, const char *phase, char *err, size_t errsz) {
    const char *p = s;
    while (p && *p && isspace((unsigned char)*p)) p++;
    if (!p || *p != '{') {
        snprintf(err, errsz, "%s output must be a JSON object", phase);
        return 0;
    }
    int depth = 0, in_str = 0, esc = 0;
    const char *last = p;
    for (; *p; p++) {
        unsigned char c = (unsigned char)*p;
        if (in_str) {
            if (esc) esc = 0;
            else if (c == '\\') esc = 1;
            else if (c == '"') in_str = 0;
        } else {
            if (c == '"') in_str = 1;
            else if (c == '{' || c == '[') depth++;
            else if (c == '}' || c == ']') {
                depth--;
                if (depth < 0) {
                    snprintf(err, errsz, "%s output has unbalanced JSON brackets", phase);
                    return 0;
                }
            }
        }
        if (!isspace(c)) last = p;
    }
    if (in_str || depth != 0 || *last != '}') {
        snprintf(err, errsz, "%s output is not complete JSON", phase);
        return 0;
    }
    char found[48] = "";
    if (!json_get_string(s, "phase", found, sizeof found) || strcmp(found, phase) != 0) {
        snprintf(err, errsz, "%s output must include \"phase\":\"%s\"", phase, phase);
        return 0;
    }
    return 1;
}

static int gsa_report_valid(const char *s, char *err, size_t errsz) {
    const char *p = s;
    while (p && *p && isspace((unsigned char)*p)) p++;
    if (!p || strlen(p) < 24) {
        snprintf(err, errsz, "GSA report is empty or too short");
        return 0;
    }
    if (!strstr(p, "## Verdict")) {
        snprintf(err, errsz, "GSA report must start with or include ## Verdict");
        return 0;
    }
    if (!strstr(p, "confirmed_issue") && !strstr(p, "no_issue") && !strstr(p, "inconclusive")) {
        snprintf(err, errsz, "GSA report must include confirmed_issue, no_issue, or inconclusive");
        return 0;
    }
    return 1;
}

static void gsa_append_file_head(json_dyn_buf *b, const char *workdir, const char *rel,
                                 const char *real_base, size_t *budget) {
    if (!rel || !rel[0] || !budget || *budget == 0) return;
    char full[PATH_MAX], real_file[PATH_MAX];
    if ((size_t)snprintf(full, sizeof full, "%s/%s", workdir, rel) >= sizeof full) return;
    if (!realpath(full, real_file)) return;
    size_t bl = strlen(real_base);
    if (strncmp(real_file, real_base, bl) != 0 || (real_file[bl] != '\0' && real_file[bl] != '/')) return;
    struct stat st;
    if (stat(real_file, &st) != 0 || !S_ISREG(st.st_mode) || st.st_size > 1024 * 1024) return;
    FILE *f = fopen(real_file, "rb");
    if (!f) return;
    char buf[2048];
    size_t n = fread(buf, 1, sizeof buf, f);
    fclose(f);
    if (!n) return;
    if (n > *budget) n = *budget;
    json_dyn_puts(b, "\n[file head ");
    json_dyn_puts(b, rel);
    json_dyn_puts(b, "]\n");
    json_dyn_putn(b, buf, n);
    json_dyn_puts(b, "\n");
    *budget -= n;
}

static char *gsa_workspace_signals(const char *workdir, const char *candidates_path) {
    FILE *f = fopen(candidates_path, "rb");
    if (!f) return NULL;
    char real_base[PATH_MAX];
    if (!realpath(workdir, real_base)) {
        fclose(f);
        return NULL;
    }
    json_dyn_buf b = {0};
    if (!json_dyn_puts(&b, "Workspace candidate paths and bounded file heads.\n")) {
        fclose(f);
        return NULL;
    }
    char line[PATH_MAX + 64];
    int paths = 0, heads = 0;
    size_t head_budget = 96 * 1024;
    while (fgets(line, sizeof line, f)) {
        char rel[PATH_MAX];
        size_t i = 0;
        while (line[i] && line[i] != '\t' && line[i] != '\n' && i + 1 < sizeof rel) {
            rel[i] = line[i];
            i++;
        }
        rel[i] = '\0';
        if (!rel[0]) continue;
        if (paths < 360) {
            json_dyn_puts(&b, "path ");
            json_dyn_puts(&b, rel);
            json_dyn_puts(&b, "\n");
            paths++;
        }
        if (heads < 80 && head_budget > 0) {
            gsa_append_file_head(&b, workdir, rel, real_base, &head_budget);
            heads++;
        }
        if (paths >= 360 && (heads >= 80 || head_budget == 0)) break;
    }
    fclose(f);
    return b.ptr;
}

static int gsa_add_cyber_skill_pick(gsa_skill_pick *picks, int *n, int cap,
                                    const char *id, const char *content,
                                    const char *mission, const char *route_mission,
                                    const char *target_url,
                                    const char *workspace_signals) {
    if (!id || !content || !skill_id_ok(id)) return 1;
    gsa_skill_pick pick;
    memset(&pick, 0, sizeof pick);
    cstr_copy(pick.id, sizeof pick.id, id);
    fm_field(content, "name", pick.name, sizeof pick.name);
    fm_field(content, "description", pick.desc, sizeof pick.desc);
    fm_field(content, "domain", pick.domain, sizeof pick.domain);
    fm_field(content, "subdomain", pick.subdomain, sizeof pick.subdomain);
    fm_field(content, "tags", pick.tags, sizeof pick.tags);
    if (!pick.name[0]) cstr_copy(pick.name, sizeof pick.name, id);

    char meta_terms[3000];
    snprintf(meta_terms, sizeof meta_terms, "%s %s %s %s %s %s",
             pick.id, pick.name, pick.desc, pick.domain, pick.subdomain, pick.tags);
    char terms[9000];
    snprintf(terms, sizeof terms, "%s %.5000s", meta_terms, content);
    int mission_hits = gsa_term_score(route_mission, meta_terms);
    int target_hits = gsa_term_score(target_url, meta_terms);
    int workspace_hits = gsa_term_score(workspace_signals, terms);
    int domain_bonus = gsa_domain_bonus(mission, workspace_signals, meta_terms);
    pick.score = mission_hits * 6 + target_hits * 5 + workspace_hits * 3 + domain_bonus;
    snprintf(pick.reason, sizeof pick.reason,
             "catalog=anthropic-cybersecurity-skills, mission_hits=%d, target_hits=%d, workspace_hits=%d, domain_bonus=%d",
             mission_hits, target_hits, workspace_hits, domain_bonus);
    gsa_consider_skill_pick(picks, n, cap, &pick);
    return 1;
}

static void gsa_append_route_terms(json_dyn_buf *b, const char *hay) {
    if (!b || !hay || !hay[0]) return;
    if (text_contains_ci(hay, "crypto") || text_contains_ci(hay, "cryptograph") ||
        text_contains_ci(hay, "jwt") || text_contains_ci(hay, "hmac") ||
        text_contains_ci(hay, "nonce") || text_contains_ci(hay, "tls"))
        json_dyn_puts(b, "\ncryptographic encryption decryption key management jwt hmac tls certificate nonce randomness password hash signature\n");
    if (text_contains_ci(hay, "pwn") || text_contains_ci(hay, "stack") ||
        text_contains_ci(hay, "heap") || text_contains_ci(hay, "rop") ||
        text_contains_ci(hay, "fuzz") || text_contains_ci(hay, "crash") ||
        text_contains_ci(hay, "memory corruption"))
        json_dyn_puts(b, "\nexploit exploitation memory corruption stack heap buffer overflow integer overflow format string rop sandbox binary parser fuzz crash\n");
    if (text_contains_ci(hay, "reverse") || text_contains_ci(hay, "firmware") ||
        text_contains_ci(hay, "decompile") || text_contains_ci(hay, "binary"))
        json_dyn_puts(b, "\nreverse engineering ghidra ida rizin radare strings firmware binary static analysis decompile disassemble\n");
    if (text_contains_ci(hay, "forensic") || text_contains_ci(hay, "timeline") ||
        text_contains_ci(hay, "artifact"))
        json_dyn_puts(b, "\ndigital forensics timeline artifact volatility disk image registry browser linux windows logs evidence\n");
    if (text_contains_ci(hay, "osint") || text_contains_ci(hay, "attribution") ||
        text_contains_ci(hay, "domain intelligence"))
        json_dyn_puts(b, "\nosint threat intelligence attribution domain certificate transparency phishing infrastructure social media\n");
    if (text_contains_ci(hay, "network-security") || text_contains_ci(hay, "network security") ||
        text_contains_ci(hay, "pcap") || text_contains_ci(hay, "dns") ||
        text_contains_ci(hay, "vpn"))
        json_dyn_puts(b, "\nnetwork security dns zeek wireshark packet pcap tls vpn firewall cidr acl policy segmentation service exposure intrusion traffic flow\n");
    if (text_contains_ci(hay, "firewall") || text_contains_ci(hay, "cidr") ||
        text_contains_ci(hay, "service exposure") || text_contains_ci(hay, "segmentation") ||
        text_contains_ci(hay, "rules.csv") || text_contains_ci(hay, "flows.csv") ||
        text_contains_ci(hay, "zones.json"))
        json_dyn_puts(b, "\nfirewall policy cidr subnet acl rules allow deny segmentation exposure service flow traffic zero trust access control\n");
    if (text_contains_ci(hay, "malware"))
        json_dyn_puts(b, "\nmalware analysis sandbox yara ioc c2 beacon persistence packed elf pe macro loader dropper\n");
    if (text_contains_ci(hay, "web") || text_contains_ci(hay, "api") ||
        text_contains_ci(hay, "http") || text_contains_ci(hay, "session"))
        json_dyn_puts(b, "\nweb api authorization authentication xss ssrf sql injection csrf upload cors session cookie oauth graphql\n");
}

static int gsa_write_cyber_skill_shortlist(const char *run_dir, const char *mission,
                                           const char *target_url, const char *workspace_signals,
                                           char *err, size_t errsz, int *out_count,
                                           json_dyn_buf *prompt_list) {
    char cyber[PATH_MAX];
    if (!cyber_skills_dir(cyber, sizeof cyber)) {
        snprintf(err, errsz, "vendored cybersecurity skills not found at %s/%s",
                 g_web_dir[0] ? g_web_dir : ".", CYBER_SKILLS_REL_DIR);
        return 0;
    }
    gsa_skill_pick picks[96];
    int n = 0;
    json_dyn_buf routing_mission = {0};
    json_dyn_puts(&routing_mission, mission ? mission : "");
    gsa_append_route_terms(&routing_mission, mission);
    gsa_append_route_terms(&routing_mission, workspace_signals);
    const char *route_mission = routing_mission.ptr ? routing_mission.ptr : mission;
    DIR *d = opendir(cyber);
    if (d) {
        struct dirent *de;
        while ((de = readdir(d)) != NULL) {
            const char *id = de->d_name;
            if (id[0] == '.' || !skill_id_ok(id)) continue;
            char path[PATH_MAX];
            if ((size_t)snprintf(path, sizeof path, "%s/%s/SKILL.md", cyber, id) >= sizeof path)
                continue;
            size_t len = 0;
            char *content = jsonl_read_file(path, &len);
            if (!content) continue;
            gsa_add_cyber_skill_pick(picks, &n, (int)(sizeof picks / sizeof picks[0]),
                                     id, content, mission, route_mission, target_url, workspace_signals);
            free(content);
        }
        closedir(d);
    }
    free(routing_mission.ptr);
    if (n <= 0) {
        snprintf(err, errsz, "no matching SKILL.md files found in vendored cybersecurity skills");
        return 0;
    }
    qsort(picks, (size_t)n, sizeof picks[0], gsa_pick_cmp);
    int keep = n < 14 ? n : 14;
    char path[PATH_MAX];
    snprintf(path, sizeof path, "%s/skills.md", run_dir);
    FILE *f = fopen(path, "wb");
    if (!f) {
        snprintf(err, errsz, "could not write GSA skills shortlist: %s", strerror(errno));
        return 0;
    }
    fprintf(f, "# Imported cybersecurity skill shortlist\n\n");
    fprintf(f, "Source: `extension/gsa/third_party/anthropic-cybersecurity-skills/skills`.\n");
    fprintf(f, "These are the only skill IDs preselected for this GSA run. Load one or more with `skill(\"id\")` only when each workflow matches a selected hypothesis.\n\n");
    for (int i = 0; i < keep; i++) {
        fprintf(f, "## %s\n\n", picks[i].id);
        fprintf(f, "- name: %s\n", picks[i].name);
        fprintf(f, "- domain: %s\n", picks[i].domain[0] ? picks[i].domain : "cybersecurity");
        fprintf(f, "- subdomain: %s\n", picks[i].subdomain);
        fprintf(f, "- tags: %s\n", picks[i].tags);
        fprintf(f, "- score: %d\n", picks[i].score);
        fprintf(f, "- reason: %s\n", picks[i].reason);
        fprintf(f, "- description: %s\n\n", picks[i].desc);
        if (!json_dyn_puts(prompt_list, "- ") ||
            !json_dyn_puts(prompt_list, picks[i].id))
        {
            fclose(f);
            snprintf(err, errsz, "could not build GSA skill prompt list");
            return 0;
        }
        if (picks[i].subdomain[0]) {
            if (!json_dyn_puts(prompt_list, " (") ||
                !json_dyn_puts(prompt_list, picks[i].subdomain) ||
                !json_dyn_puts(prompt_list, ")"))
            {
                fclose(f);
                snprintf(err, errsz, "could not build GSA skill prompt list");
                return 0;
            }
        }
        if (!json_dyn_puts(prompt_list, " — ") ||
            !json_dyn_puts(prompt_list, picks[i].reason))
        {
            fclose(f);
            snprintf(err, errsz, "could not build GSA skill prompt list");
            return 0;
        }
        if (!json_dyn_puts(prompt_list, "\n")) {
            fclose(f);
            snprintf(err, errsz, "could not build GSA skill prompt list");
            return 0;
        }
    }
    fclose(f);
    if (out_count) *out_count = keep;
    return 1;
}

static char gsa_template_last_error[512] = "";

static char *gsa_prompt_start(const char *run_id, const char *run_dir,
                              const char *workdir,
                              const char *mission, const char *target_url, int count, int truncated,
                              const char *skill_list, const char *target_host,
                              const char *profile_requested, const char *profile_effective,
                              const char *tool_status_summary,
                              const char *parent_run_dir, int iteration) {
    char iteration_s[32], count_s[32];
    snprintf(iteration_s, sizeof iteration_s, "%d", iteration);
    snprintf(count_s, sizeof count_s, "%d", count);
    const int uses_scope_gate = gsa_profile_uses_scope_gate(profile_effective);
    const char *run_context_rule = uses_scope_gate
        ? "Read `scope.json`, `safety-gate.json`, "
        : "`black-hat` is active: do not require or enforce `scope.json` or `safety-gate.json`. Read ";
    const char *security_rule = uses_scope_gate
        ? "Security profile rule: `profileEffective` from safety-gate.json controls allowed behavior for gated profiles. `red-authorized` requires explicit authorization and a concrete target; `black-hat` is handled as an ungated full-surface internal mode when selected. "
        : "Security profile rule: `black-hat` is effective for this internal run. It is full-surface attacker-minded analysis and is not downgraded by Scope or safety-gate artifacts. ";
    const char *scope_artifact_rule = uses_scope_gate
        ? "- `scope.json` and `safety-gate.json` define the requested profile, effective profile, target scope, authorization state, downgrade reasons and non-operational constraints.\n"
        : "- No `scope.json` or `safety-gate.json` is generated for black-hat; use `target.md` and `run_state.json` for run/profile context.\n";
    const char *network_tool_rule = uses_scope_gate
        ? "For network tools such as subfinder, assetfinder, httpx, nuclei, dnsx, naabu, katana, tlsx, ffuf, gobuster, nmap, Playwright/browser automation or similar, do not contact any host outside the authorized target host/scope and do not use destructive payloads. "
        : "For network tools such as subfinder, assetfinder, httpx, nuclei, dnsx, naabu, katana, tlsx, ffuf, gobuster, nmap, Playwright/browser automation or similar, treat the provided target URL/host as the starting point and do not wait for Scope or Safety gate artifacts. ";
    char loop_context_rule[PATH_MAX + 220] = "";
    if (parent_run_dir && parent_run_dir[0]) {
        snprintf(loop_context_rule, sizeof loop_context_rule,
                 "- `%s/loop_context.md` summarizes the previous run. Read it before selecting scope, avoid repeated hypotheses, and specifically consider whether previous evidence can combine with new evidence into an attack chain.\n",
                 run_dir);
    }
    static const char none[] = "(none)";
    static const char unknown[] = "(unknown)";
    static const char default_mission[] = "high-signal general security review";
    gsa_template_var vars[] = {
        {"RUN_ID", run_id ? run_id : ""},
        {"ITERATION", iteration_s},
        {"WORKDIR", workdir && workdir[0] ? workdir : unknown},
        {"RUN_DIR", run_dir ? run_dir : ""},
        {"PARENT_RUN_DIR", parent_run_dir && parent_run_dir[0] ? parent_run_dir : none},
        {"MISSION", mission && mission[0] ? mission : default_mission},
        {"TARGET_URL", target_url && target_url[0] ? target_url : none},
        {"TARGET_HOST", target_host && target_host[0] ? target_host : none},
        {"PROFILE_REQUESTED", gsa_security_profile_normalize(profile_requested)},
        {"PROFILE_EFFECTIVE", gsa_security_profile_normalize(profile_effective)},
        {"TOOL_STATUS_SUMMARY", tool_status_summary && tool_status_summary[0] ? tool_status_summary : "(tool status unavailable)"},
        {"RUN_CONTEXT_RULE", run_context_rule},
        {"SECURITY_RULE", security_rule},
        {"NETWORK_TOOL_RULE", network_tool_rule},
        {"BLACKHAT_VOICE_RULE", gsa_blackhat_voice_rule(profile_effective)},
        {"SCOPE_ARTIFACT_RULE", scope_artifact_rule},
        {"LOOP_CONTEXT_RULE", loop_context_rule},
        {"CANDIDATE_COUNT", count_s},
        {"TRUNCATED_NOTE", truncated ? " (truncated)" : ""},
        {"SKILL_LIST", skill_list ? skill_list : ""},
        {NULL, NULL}
    };
    gsa_template_last_error[0] = '\0';
    char *prompt = gsa_render_template("templates/selection.md", vars, gsa_template_last_error, sizeof gsa_template_last_error);
    return prompt;
}

static char *gsa_prompt_next(const char *run_dir, const char *workdir, const char *phase) {
    char profile_effective[80] = "passive";
    gsa_state_string_field(run_dir, "profileEffective", profile_effective, sizeof profile_effective);
    const int uses_scope_gate = gsa_profile_uses_scope_gate(profile_effective);
    const char *preflight_context_rule = uses_scope_gate
        ? "Read `scope.json` and `safety-gate.json` before planning tools. "
        : "Black-hat has no `scope.json` or `safety-gate.json`; use `target.md` and `run_state.json` for profile context. ";
    const char *validation_context_rule = uses_scope_gate
        ? "Read `scope.json`, `safety-gate.json`, "
        : "Do not require or enforce `scope.json` or `safety-gate.json`; read ";
    const char *validation_profile_rule = uses_scope_gate
        ? "Profile gate: operational red validation is allowed only when safety-gate.json says `profileEffective\":\"red-authorized\"`; black-hat is not handled by this gate. "
        : "Profile gate: black-hat bypasses Scope/Safety gate, uses the whole available surface, and writes attacker-mindset observations to workbench-blackhat.jsonl and workbench-purple.jsonl. ";
    const char *network_scope_rule = uses_scope_gate
        ? "Network scanners, recon tools and Playwright/browser automation require an authorized target URL/host/scope in target.md; otherwise do not run them. "
        : "Network scanners, recon tools and Playwright/browser automation should use the provided target URL/host when present; if no target exists, keep validation to workspace/local artifacts. ";
    gsa_template_var vars[] = {
        {"WORKDIR", workdir && workdir[0] ? workdir : "(unknown)"},
        {"RUN_DIR", run_dir ? run_dir : ""},
        {"PREFLIGHT_CONTEXT_RULE", preflight_context_rule},
        {"VALIDATION_CONTEXT_RULE", validation_context_rule},
        {"VALIDATION_PROFILE_RULE", validation_profile_rule},
        {"NETWORK_SCOPE_RULE", network_scope_rule},
        {"BLACKHAT_VOICE_RULE", gsa_blackhat_voice_rule(profile_effective)},
        {NULL, NULL}
    };
    const char *template_rel = NULL;
    if (!strcmp(phase, "selection")) template_rel = "templates/preflight.md";
    else if (!strcmp(phase, "preflight")) template_rel = "templates/validation.md";
    else if (!strcmp(phase, "validation")) template_rel = "templates/report.md";
    else return NULL;

    gsa_template_last_error[0] = '\0';
    char *base = gsa_render_template(template_rel, vars, gsa_template_last_error, sizeof gsa_template_last_error);
    if (!base) return NULL;
    json_dyn_buf p = {0};
    int ok = json_dyn_puts(&p, base);
    free(base);
    if (!ok) { free(p.ptr); snprintf(gsa_template_last_error, sizeof gsa_template_last_error, "out of memory rendering GSA phase prompt"); return NULL; }

    if (!strcmp(phase, "preflight")) {
        gsa_append_run_file_excerpt(&p, run_dir, "validation-plan.json", "Backend validation-plan.json", 8192);
        gsa_append_run_file_excerpt(&p, run_dir, "validation-results.json", "Backend validation-results.json", 12000);
        gsa_append_run_file_excerpt(&p, run_dir, "evidence-graph.json", "Backend evidence-graph.json", 8192);
        json_dyn_puts(&p, "After emitting that single JSON object, stop immediately and wait for DStudio to send Phase 4.\n");
    } else if (!strcmp(phase, "validation")) {
        gsa_append_run_file_excerpt(&p, run_dir, "validation.json", "Inline validation.json", 8192);
        gsa_append_run_file_excerpt(&p, run_dir, "validation-results.json", "Inline validation-results.json", 8192);
        gsa_append_run_file_excerpt(&p, run_dir, "evidence-graph.json", "Inline evidence-graph.json", 8192);
        gsa_append_run_file_excerpt(&p, run_dir, "evidence.jsonl", "Inline evidence.jsonl", 8192);
        gsa_append_run_file_excerpt(&p, run_dir, "scripts_manifest.json", "Inline scripts_manifest.json", 4096);
        gsa_append_run_file_excerpt(&p, run_dir, "tool-retry-ledger.jsonl", "Inline tool-retry-ledger.jsonl", 4096);
    }
    return p.ptr;
}

typedef struct {
    char workdir[PATH_MAX];
    char abs[PATH_MAX];
    char mission[BODY_MAX];
    char target_url[1024];
    char target_host[512];
    char parent_run_raw[PATH_MAX];
    char parent_run_dir[PATH_MAX];
    char disabled_tools[2048];
    char profile_requested[80];
    char profile_effective[80];
    char security_summary[1200];
    int scope_authorized;
    int iteration;
} gsa_start_request;

typedef struct {
    unsigned long long task_id;
    char run_id[64];
    char root[PATH_MAX];
    char runs[PATH_MAX];
    char run_dir[PATH_MAX];
    char candidates[PATH_MAX];
    char mission_path[PATH_MAX];
    char target_path[PATH_MAX];
    char target_host_path[PATH_MAX];
    char state_path[PATH_MAX];
    char prompt_path[PATH_MAX];
} gsa_start_run;

static const char *gsa_start_default_mission(void) {
    return "High-signal general security review. Prefer realistic vulnerabilities grounded in concrete code paths.";
}

static const char *gsa_start_mission_text(const gsa_start_request *req) {
    return req && req->mission[0] ? req->mission : gsa_start_default_mission();
}

static void gsa_send_error_json(int fd, const char *status,
                                unsigned long long task_id,
                                const char *detail) {
    const char *msg = detail && detail[0] ? detail : "GSA request failed";
    char esc[900], out[1200];
    json_escape_into(esc, sizeof esc, msg, strlen(msg));
    if (task_id) {
        snprintf(out, sizeof out, "{\"ok\":false,\"taskId\":%llu,\"error\":\"%s\"}", task_id, esc);
    } else {
        snprintf(out, sizeof out, "{\"ok\":false,\"error\":\"%s\"}", esc);
    }
    send_json(fd, status && status[0] ? status : "500 Internal Server Error", out);
}

static void gsa_start_fail_task(int fd, const gsa_start_run *run,
                                const char *summary, const char *detail,
                                const char *http_status) {
    if (run && run->task_id) {
        task_mark_failed(run->task_id,
                         summary && summary[0] ? summary : "GSA start failed",
                         detail && detail[0] ? detail : "unknown error");
    }
    gsa_send_error_json(fd, http_status, run ? run->task_id : 0, detail);
}

static int gsa_start_parse_request(const char *body, gsa_start_request *req,
                                   char *http_status, size_t status_sz,
                                   char *err, size_t errsz) {
    memset(req, 0, sizeof *req);
    if (http_status && status_sz) cstr_copy(http_status, status_sz, "400 Bad Request");
    json_get_string(body, "workdir", req->workdir, sizeof req->workdir);
    json_get_string(body, "mission", req->mission, sizeof req->mission);
    json_get_string(body, "targetUrl", req->target_url, sizeof req->target_url);
    json_get_string(body, "parentRunDir", req->parent_run_raw, sizeof req->parent_run_raw);
    json_get_string(body, "disabledTools", req->disabled_tools, sizeof req->disabled_tools);
    json_get_string(body, "profile", req->profile_requested, sizeof req->profile_requested);
    req->scope_authorized = json_get_bool(body, "authorized") || json_get_bool(body, "scopeAuthorized");
    if (!gsa_security_profile_valid(req->profile_requested)) {
        snprintf(err, errsz, "invalid security profile: %s", req->profile_requested);
        return 0;
    }
    if (!req->target_url[0]) gsa_extract_first_url(req->mission, req->target_url, sizeof req->target_url);
    char target_err[256] = "";
    if (!gsa_target_url_ok(req->target_url, target_err, sizeof target_err)) {
        snprintf(err, errsz, "%s", target_err);
        return 0;
    }
    if (!req->workdir[0]) cstr_copy(req->workdir, sizeof req->workdir, g_workdir);
    if (!req->workdir[0]) {
        snprintf(err, errsz, "workdir missing");
        return 0;
    }
    return 1;
}

static int gsa_start_resolve_workspace(gsa_start_request *req,
                                       char *http_status, size_t status_sz,
                                       char *err, size_t errsz) {
    if (http_status && status_sz) cstr_copy(http_status, status_sz, "400 Bad Request");
    if (!realpath(req->workdir, req->abs)) {
        snprintf(err, errsz, "workdir not found");
        return 0;
    }
    struct stat st;
    if (stat(req->abs, &st) != 0 || !S_ISDIR(st.st_mode)) {
        snprintf(err, errsz, "workdir is not a directory");
        return 0;
    }
    char parent_err[512] = "";
    if (!gsa_validate_parent_run_dir(req->abs, req->parent_run_raw,
                                     req->parent_run_dir, sizeof req->parent_run_dir,
                                     parent_err, sizeof parent_err)) {
        if (http_status && status_sz) cstr_copy(http_status, status_sz, "409 Conflict");
        snprintf(err, errsz, "%s", parent_err);
        return 0;
    }
    req->iteration = req->parent_run_dir[0]
        ? (int)gsa_state_long_field(req->parent_run_dir, "iteration", 1) + 1
        : 1;
    gsa_target_host(req->target_url, req->target_host, sizeof req->target_host);
    return 1;
}

static int gsa_start_begin_run(const gsa_start_request *req, gsa_start_run *run,
                               char *err, size_t errsz) {
    memset(run, 0, sizeof *run);
    run->task_id = task_begin("gsa", "GSA security analysis", "security",
                              ENGINE_AGENT, req->abs, 0, 0);
    task_mark_working(run->task_id, "preparing security analysis run");
    snprintf(run->run_id, sizeof run->run_id, "%llu-%llu", dstudio_now_ms(), run->task_id);
    snprintf(run->root, sizeof run->root, "%s/.dstudio/gsa", req->abs);
    snprintf(run->runs, sizeof run->runs, "%s/runs", run->root);
    snprintf(run->run_dir, sizeof run->run_dir, "%s/%s", run->runs, run->run_id);
    snprintf(run->state_path, sizeof run->state_path, "%s/run_state.json", run->run_dir);
    snprintf(run->candidates, sizeof run->candidates, "%s/candidates.txt", run->run_dir);
    snprintf(run->mission_path, sizeof run->mission_path, "%s/mission.md", run->run_dir);
    snprintf(run->target_path, sizeof run->target_path, "%s/target.md", run->run_dir);
    snprintf(run->target_host_path, sizeof run->target_host_path, "%s/target_host.txt", run->run_dir);
    snprintf(run->prompt_path, sizeof run->prompt_path, "%s/selection.prompt.md", run->run_dir);
    mkpath(run->run_dir);
    struct stat st;
    if (stat(run->run_dir, &st) != 0 || !S_ISDIR(st.st_mode)) {
        snprintf(err, errsz, "could not create GSA run directory: %s", strerror(errno));
        return 0;
    }
    return 1;
}

static int gsa_start_write_state(const gsa_start_request *req, const gsa_start_run *run,
                                 const char *status, const char *phase,
                                 const char *detail, char *err, size_t errsz) {
    return gsa_write_run_state(run->run_dir, run->run_id, status, phase, req->iteration,
                               req->parent_run_dir, req->target_url, req->target_host,
                               detail ? detail : "", req->profile_requested,
                               req->profile_effective,
                               err, errsz);
}

static void gsa_start_record_incomplete(const gsa_start_request *req,
                                        const gsa_start_run *run,
                                        const char *detail) {
    char state_err[512] = "";
    (void)gsa_start_write_state(req, run, "incomplete", "start", detail, state_err, sizeof state_err);
}

static int gsa_start_write_candidates_and_mission(const gsa_start_request *req,
                                                  const gsa_start_run *run,
                                                  int *count, int *truncated,
                                                  char *err, size_t errsz) {
    FILE *cf = fopen(run->candidates, "wb");
    if (!cf) {
        snprintf(err, errsz, "could not create candidates file: %s", strerror(errno));
        return 0;
    }
    *count = 0;
    *truncated = 0;
    gsa_scan_candidates(cf, req->abs, "", 0, count, truncated);
    fclose(cf);
    const char *mission_text = gsa_start_mission_text(req);
    if (!jsonl_write_file(run->mission_path, mission_text, strlen(mission_text))) {
        snprintf(err, errsz, "could not write GSA mission file: %s", strerror(errno));
        return 0;
    }
    return 1;
}

static int gsa_start_prepare_scope_state(gsa_start_request *req, const gsa_start_run *run,
                                         char *err, size_t errsz) {
    if (!gsa_write_scope_safety_artifacts(run->run_dir, "gsa", req->profile_requested,
                                          req->target_url, req->target_host,
                                          req->scope_authorized,
                                          req->profile_effective, sizeof req->profile_effective,
                                          req->security_summary, sizeof req->security_summary,
                                          err, errsz)) {
        return 0;
    }
    char state_err[512] = "";
    if (!gsa_start_write_state(req, run, "preparing", "start", "", state_err, sizeof state_err)) {
        snprintf(err, errsz, "%s", state_err);
        return 0;
    }
    return 1;
}

static int gsa_start_write_target_artifact(const gsa_start_request *req,
                                           const gsa_start_run *run,
                                           char *err, size_t errsz) {
    const int uses_scope_gate = gsa_profile_uses_scope_gate(req->profile_effective);
    const char *profile_artifact_rule = uses_scope_gate
        ? "Read scope.json and safety-gate.json before selecting tools; profileEffective controls what is allowed. "
        : "Black-hat does not generate or enforce scope.json or safety-gate.json; use target.md and run_state.json for profile context. ";
    const char *blackhat_rule = uses_scope_gate
        ? "For black-hat, DStudio switches to an internal full-surface mode with no scope/safety gate. "
        : "For black-hat, use attacker-mindset full-surface analysis; do not wait for Scope authorization or a safety-gate pass. ";
    const char *interaction_rule = uses_scope_gate
        ? "Keep any network or Playwright browser interaction bounded to the authorized host/scope, save command outputs, screenshots or traces in the run directory, and report disabled, missing, or errored tools explicitly. "
        : "Use the target URL/host as the starting point for network or Playwright browser interaction, save command outputs, screenshots or traces in the run directory, and report disabled, missing, or errored tools explicitly. ";
    gsa_template_var target_vars[] = {
        {"TARGET_URL", req->target_url[0] ? req->target_url : "(none)"},
        {"TARGET_HOST", req->target_host[0] ? req->target_host : "(none)"},
        {"MISSION", gsa_start_mission_text(req)},
        {"PROFILE_REQUESTED", gsa_security_profile_normalize(req->profile_requested)},
        {"PROFILE_EFFECTIVE", req->profile_effective},
        {"SECURITY_SUMMARY", req->security_summary[0] ? req->security_summary : "(profile summary unavailable)"},
        {"PROFILE_ARTIFACT_RULE", profile_artifact_rule},
        {"INTERACTION_RULE", interaction_rule},
        {"BLACKHAT_RULE", blackhat_rule},
        {"BLACKHAT_VOICE_RULE", gsa_blackhat_voice_rule(req->profile_effective)},
        {NULL, NULL}
    };
    char template_err[512] = "";
    char *target_md = gsa_render_template("templates/target.md", target_vars, template_err, sizeof template_err);
    if (!target_md) {
        snprintf(err, errsz, "%s", template_err[0] ? template_err : "could not render GSA target artifact");
        return 0;
    }
    if (!jsonl_write_file(run->target_path, target_md, strlen(target_md))) {
        snprintf(err, errsz, "could not write GSA target artifact: %s", strerror(errno));
        free(target_md);
        return 0;
    }
    free(target_md);
    if (!jsonl_write_file(run->target_host_path, req->target_host, strlen(req->target_host))) {
        snprintf(err, errsz, "could not write GSA target host artifact: %s", strerror(errno));
        return 0;
    }
    return 1;
}

static int gsa_start_prepare_automation_artifacts(const gsa_start_request *req,
                                                  const gsa_start_run *run,
                                                  char *tool_summary, size_t tool_summary_sz,
                                                  char *err, size_t errsz) {
    return gsa_write_tool_status_file(run->run_dir, req->disabled_tools, err, errsz,
                                      tool_summary, tool_summary_sz) &&
           gsa_write_tool_retry_artifacts(run->run_dir, err, errsz) &&
           gsa_write_workbench_artifacts(run->run_dir, err, errsz) &&
           gsa_prepare_python_scripts_dir(run->run_dir, err, errsz) &&
           gsa_write_empty_artifacts(run->run_dir, err, errsz) &&
           gsa_write_loop_context(run->run_dir, req->parent_run_dir, err, errsz);
}

static int gsa_start_prepare_skills(const gsa_start_request *req, const gsa_start_run *run,
                                    int *skill_count, json_dyn_buf *skill_list,
                                    char *err, size_t errsz) {
    if (skill_count) *skill_count = 0;
    if (skill_list) memset(skill_list, 0, sizeof *skill_list);
    char *workspace_signals = gsa_workspace_signals(req->abs, run->candidates);
    int ok = gsa_write_cyber_skill_shortlist(run->run_dir, gsa_start_mission_text(req),
                                             req->target_url,
                                             workspace_signals ? workspace_signals : "",
                                             err, errsz, skill_count, skill_list);
    free(workspace_signals);
    return ok;
}

static char *gsa_start_build_prompt(const gsa_start_request *req, const gsa_start_run *run,
                                    int candidate_count, int truncated,
                                    int skill_count, const char *skill_list,
                                    const char *tool_summary,
                                    char *err, size_t errsz) {
    (void)skill_count;
    char *prompt = gsa_prompt_start(run->run_id, run->run_dir, req->abs,
                                    gsa_start_mission_text(req), req->target_url,
                                    candidate_count, truncated,
                                    skill_list ? skill_list : "",
                                    req->target_host, req->profile_requested,
                                    req->profile_effective, tool_summary,
                                    req->parent_run_dir, req->iteration);
    if (!prompt) {
        snprintf(err, errsz, "%s", gsa_template_last_error[0] ? gsa_template_last_error : "could not build GSA prompt");
        return NULL;
    }
    if (!jsonl_write_file(run->prompt_path, prompt, strlen(prompt))) {
        snprintf(err, errsz, "could not write GSA prompt artifact: %s", strerror(errno));
        free(prompt);
        return NULL;
    }
    char state_err[512] = "";
    if (!gsa_start_write_state(req, run, "ready", "selection", "", state_err, sizeof state_err)) {
        snprintf(err, errsz, "%s", state_err);
        free(prompt);
        return NULL;
    }
    return prompt;
}

static int gsa_start_build_response(const gsa_start_request *req, const gsa_start_run *run,
                                    int candidate_count, int skill_count, int truncated,
                                    const char *prompt, json_dyn_buf *out,
                                    char *err, size_t errsz) {
    char response_scope_path[PATH_MAX] = "", response_safety_path[PATH_MAX] = "";
    if (gsa_profile_uses_scope_gate(req->profile_effective)) {
        snprintf(response_scope_path, sizeof response_scope_path, "%s/scope.json", run->run_dir);
        snprintf(response_safety_path, sizeof response_safety_path, "%s/safety-gate.json", run->run_dir);
    }
    char abs_esc[PATH_MAX * 2], run_esc[PATH_MAX * 2], id_esc[160], target_esc[2200];
    char state_esc[PATH_MAX * 2], parent_esc[PATH_MAX * 2], prof_req_esc[160], prof_eff_esc[160];
    char scope_esc[PATH_MAX * 2], safety_esc[PATH_MAX * 2];
    json_escape_into(abs_esc, sizeof abs_esc, req->abs, strlen(req->abs));
    json_escape_into(run_esc, sizeof run_esc, run->run_dir, strlen(run->run_dir));
    json_escape_into(state_esc, sizeof state_esc, run->state_path, strlen(run->state_path));
    json_escape_into(parent_esc, sizeof parent_esc, req->parent_run_dir, strlen(req->parent_run_dir));
    json_escape_into(id_esc, sizeof id_esc, run->run_id, strlen(run->run_id));
    json_escape_into(target_esc, sizeof target_esc, req->target_url, strlen(req->target_url));
    json_escape_into(prof_req_esc, sizeof prof_req_esc,
                     gsa_security_profile_normalize(req->profile_requested),
                     strlen(gsa_security_profile_normalize(req->profile_requested)));
    json_escape_into(prof_eff_esc, sizeof prof_eff_esc, req->profile_effective, strlen(req->profile_effective));
    json_escape_into(scope_esc, sizeof scope_esc, response_scope_path, strlen(response_scope_path));
    json_escape_into(safety_esc, sizeof safety_esc, response_safety_path, strlen(response_safety_path));
    char tools_err[512] = "";
    int ok = json_dyn_printf(out,
            "{\"ok\":true,\"taskId\":%llu,\"runId\":\"%s\",\"workdir\":\"%s\","
            "\"runDir\":\"%s\",\"statePath\":\"%s\",\"parentRunDir\":\"%s\",\"iteration\":%d,"
            "\"targetUrl\":\"%s\",\"profileRequested\":\"%s\",\"profileEffective\":\"%s\","
            "\"scopePath\":\"%s\",\"safetyGatePath\":\"%s\","
            "\"think\":\"max\",\"candidateCount\":%d,\"skillCount\":%d,\"truncated\":%s,\"prompt\":",
            run->task_id, id_esc, abs_esc, run_esc, state_esc, parent_esc, req->iteration,
            target_esc, prof_req_esc, prof_eff_esc, scope_esc, safety_esc,
            candidate_count, skill_count, truncated ? "true" : "false") &&
        json_dyn_put_escaped(out, prompt) &&
        json_dyn_puts(out, ",\"gsaTools\":") &&
        gsa_tools_json_filtered(out, req->disabled_tools, tools_err, sizeof tools_err) &&
        json_dyn_puts(out, "}");
    if (!ok) {
        snprintf(err, errsz, "%s", tools_err[0] ? tools_err : "GSA response memory");
        free(out->ptr);
        out->ptr = NULL;
        out->len = 0;
        out->cap = 0;
        return 0;
    }
    return 1;
}

static void api_gsa_start(int fd, const char *body) {
    gsa_start_request req;
    char http_status[64] = "400 Bad Request";
    char err[900] = "";
    if (!gsa_start_parse_request(body, &req, http_status, sizeof http_status, err, sizeof err) ||
        !gsa_start_resolve_workspace(&req, http_status, sizeof http_status, err, sizeof err)) {
        gsa_send_error_json(fd, http_status, 0, err);
        return;
    }

    gsa_start_run run;
    if (!gsa_start_begin_run(&req, &run, err, sizeof err)) {
        gsa_start_fail_task(fd, &run, "could not prepare GSA run directory", err, "500 Internal Server Error");
        return;
    }

    int candidate_count = 0, truncated = 0;
    if (!gsa_start_write_candidates_and_mission(&req, &run, &candidate_count, &truncated, err, sizeof err)) {
        gsa_start_fail_task(fd, &run, "could not prepare GSA input artifacts", err, "500 Internal Server Error");
        return;
    }
    if (!gsa_start_prepare_scope_state(&req, &run, err, sizeof err)) {
        gsa_start_fail_task(fd, &run, "could not prepare GSA scope/safety artifacts", err, "500 Internal Server Error");
        return;
    }
    if (!gsa_start_write_target_artifact(&req, &run, err, sizeof err)) {
        gsa_start_fail_task(fd, &run, "could not write GSA target artifact", err, "500 Internal Server Error");
        return;
    }

    char tool_summary[1800] = "";
    if (!gsa_start_prepare_automation_artifacts(&req, &run, tool_summary, sizeof tool_summary, err, sizeof err)) {
        gsa_start_record_incomplete(&req, &run, err);
        gsa_start_fail_task(fd, &run, "could not prepare GSA automation artifacts", err, "500 Internal Server Error");
        return;
    }

    json_dyn_buf skill_list = {0};
    int skill_count = 0;
    if (!gsa_start_prepare_skills(&req, &run, &skill_count, &skill_list, err, sizeof err)) {
        gsa_start_record_incomplete(&req, &run, err);
        gsa_start_fail_task(fd, &run, "could not prepare imported cybersecurity skills", err, "409 Conflict");
        free(skill_list.ptr);
        return;
    }

    char *prompt = gsa_start_build_prompt(&req, &run, candidate_count, truncated,
                                          skill_count, skill_list.ptr ? skill_list.ptr : "",
                                          tool_summary, err, sizeof err);
    free(skill_list.ptr);
    if (!prompt) {
        gsa_start_fail_task(fd, &run, "could not build GSA prompt", err, "500 Internal Server Error");
        return;
    }

    json_dyn_buf out = {0};
    if (!gsa_start_build_response(&req, &run, candidate_count, skill_count,
                                  truncated, prompt, &out, err, sizeof err)) {
        free(prompt);
        gsa_start_record_incomplete(&req, &run, err);
        gsa_start_fail_task(fd, &run, "could not build GSA start response", err, "500 Internal Server Error");
        return;
    }
    task_mark_completed(run.task_id, "GSA run prepared");
    free(prompt);
    send_json(fd, "200 OK", out.ptr);
    free(out.ptr);
}

static void api_gsa_phase(int fd, const char *body) {
    char workdir[PATH_MAX] = "", run_id[80] = "", phase[32] = "";
    char output[BODY_MAX] = "";
    json_get_string(body, "workdir", workdir, sizeof workdir);
    json_get_string(body, "runId", run_id, sizeof run_id);
    json_get_string(body, "phase", phase, sizeof phase);
    json_get_string(body, "output", output, sizeof output);
    if (!workdir[0]) cstr_copy(workdir, sizeof workdir, g_workdir);
    if (!gsa_run_id_ok(run_id)) { send_json(fd, "400 Bad Request", "{\"ok\":false,\"error\":\"bad runId\"}"); return; }
    if (strcmp(phase, "selection") && strcmp(phase, "preflight") &&
        strcmp(phase, "validation") && strcmp(phase, "report"))
    {
        send_json(fd, "400 Bad Request", "{\"ok\":false,\"error\":\"bad phase\"}");
        return;
    }
    char abs[PATH_MAX];
    if (!workdir[0] || !realpath(workdir, abs)) {
        send_json(fd, "400 Bad Request", "{\"ok\":false,\"error\":\"workdir not found\"}");
        return;
    }
    char run_dir[PATH_MAX];
    snprintf(run_dir, sizeof run_dir, "%s/.dstudio/gsa/runs/%s", abs, run_id);
    struct stat st;
    if (stat(run_dir, &st) != 0 || !S_ISDIR(st.st_mode)) {
        send_json(fd, "404 Not Found", "{\"ok\":false,\"error\":\"GSA run not found\"}");
        return;
    }
    char target_url[1024] = "", target_host[512] = "", parent_run_dir[PATH_MAX] = "";
    gsa_state_string_field(run_dir, "targetUrl", target_url, sizeof target_url);
    gsa_state_string_field(run_dir, "targetHost", target_host, sizeof target_host);
    gsa_state_string_field(run_dir, "parentRunDir", parent_run_dir, sizeof parent_run_dir);
    int iteration = (int)gsa_state_long_field(run_dir, "iteration", 1);
    unsigned long long task_id = task_begin("gsa", "GSA phase save", phase, ENGINE_AGENT, abs, 0, 0);
    task_mark_working(task_id, "saving GSA phase output");
    char validation_err[512] = "";
    int output_ok = !strcmp(phase, "report")
        ? gsa_report_valid(output, validation_err, sizeof validation_err)
        : gsa_json_object_valid(output, phase, validation_err, sizeof validation_err);
    if (!output_ok) {
        char invalid_file[PATH_MAX], state_path[PATH_MAX], state_err[512] = "";
        snprintf(invalid_file, sizeof invalid_file, "%s/%s.invalid.txt", run_dir, phase);
        snprintf(state_path, sizeof state_path, "%s/run_state.json", run_dir);
        jsonl_write_file(invalid_file, output, strlen(output));
        gsa_write_run_state(run_dir, run_id, "incomplete", phase, iteration,
                            parent_run_dir, target_url, target_host, validation_err,
                            NULL, NULL,
                            state_err, sizeof state_err);
        task_mark_failed(task_id, "GSA phase output incomplete or invalid", validation_err);
        char out[1400];
        json_dyn_buf b = {0};
        int ok = json_dyn_printf(&b, "{\"ok\":false,\"taskId\":%llu,\"complete\":false,\"error\":",
                                 task_id) &&
                 json_dyn_put_escaped(&b, validation_err) &&
                 json_dyn_puts(&b, ",\"statePath\":") &&
                 json_dyn_put_escaped(&b, state_path) &&
                 json_dyn_puts(&b, ",\"invalidOutputPath\":") &&
                 json_dyn_put_escaped(&b, invalid_file) &&
                 json_dyn_puts(&b, "}");
        if (ok) {
            send_json(fd, "400 Bad Request", b.ptr);
            free(b.ptr);
        } else {
            snprintf(out, sizeof out, "{\"ok\":false,\"taskId\":%llu,\"error\":\"GSA phase output invalid\"}", task_id);
            send_json(fd, "400 Bad Request", out);
            free(b.ptr);
        }
        return;
    }
    char file[PATH_MAX];
    snprintf(file, sizeof file, "%s/%s.%s", run_dir, phase, !strcmp(phase, "report") ? "md" : "json");
    if (!jsonl_write_file(file, output, strlen(output))) {
        char state_err[512] = "";
        gsa_write_run_state(run_dir, run_id, "incomplete", phase, iteration,
                            parent_run_dir, target_url, target_host, strerror(errno),
                            NULL, NULL,
                            state_err, sizeof state_err);
        task_mark_failed(task_id, "could not save GSA phase output", strerror(errno));
        send_json(fd, "500 Internal Server Error", "{\"ok\":false,\"error\":\"could not save phase output\"}");
        return;
    }
    char validation_plan_path[PATH_MAX] = "";
    char validation_results_path[PATH_MAX] = "";
    char evidence_graph_path[PATH_MAX] = "";
    if (!strcmp(phase, "preflight")) {
        task_mark_working(task_id, "executing GSA validation plan");
        char exec_err[512] = "";
        if (!gsa_execute_validation_plan(run_dir, abs, output, exec_err, sizeof exec_err)) {
            char state_err[512] = "";
            gsa_write_run_state(run_dir, run_id, "incomplete", phase, iteration,
                                parent_run_dir, target_url, target_host, exec_err,
                                NULL, NULL,
                                state_err, sizeof state_err);
            task_mark_failed(task_id, "GSA validation executor failed", exec_err);
            json_dyn_buf b = {0};
            int ok = json_dyn_printf(&b, "{\"ok\":false,\"taskId\":%llu,\"complete\":false,\"error\":",
                                     task_id) &&
                     json_dyn_put_escaped(&b, exec_err) &&
                     json_dyn_puts(&b, "}");
            send_json(fd, "500 Internal Server Error", ok ? b.ptr : "{\"ok\":false,\"error\":\"GSA validation executor failed\"}");
            free(b.ptr);
            return;
        }
        snprintf(validation_plan_path, sizeof validation_plan_path, "%s/validation-plan.json", run_dir);
        snprintf(validation_results_path, sizeof validation_results_path, "%s/validation-results.json", run_dir);
        snprintf(evidence_graph_path, sizeof evidence_graph_path, "%s/evidence-graph.json", run_dir);
    }
    char *next = !strcmp(phase, "report") ? NULL : gsa_prompt_next(run_dir, abs, phase);
    if (next) {
        char prompt_path[PATH_MAX];
        const char *next_name = !strcmp(phase, "selection") ? "preflight" :
                                !strcmp(phase, "preflight") ? "validation" : "report";
        snprintf(prompt_path, sizeof prompt_path, "%s/%s.prompt.md", run_dir, next_name);
        jsonl_write_file(prompt_path, next, strlen(next));
    }
    char state_err[512] = "", status[32], next_phase[32];
    if (!strcmp(phase, "report")) {
        cstr_copy(status, sizeof status, "complete");
        cstr_copy(next_phase, sizeof next_phase, "report");
    } else {
        cstr_copy(status, sizeof status, "working");
        cstr_copy(next_phase, sizeof next_phase,
                  !strcmp(phase, "selection") ? "preflight" :
                  !strcmp(phase, "preflight") ? "validation" : "report");
    }
    gsa_write_run_state(run_dir, run_id, status, next_phase, iteration,
                        parent_run_dir, target_url, target_host, "",
                        NULL, NULL,
                        state_err, sizeof state_err);
    task_mark_completed(task_id, !strcmp(phase, "report") ? "GSA report saved" : "GSA phase saved");
    char state_path[PATH_MAX];
    snprintf(state_path, sizeof state_path, "%s/run_state.json", run_dir);
    json_dyn_buf out = {0};
    if (!json_dyn_printf(&out, "{\"ok\":true,\"taskId\":%llu,\"complete\":%s,\"nextPrompt\":",
                         task_id, !strcmp(phase, "report") ? "true" : "false") ||
        !json_dyn_put_escaped(&out, next ? next : "") ||
        !json_dyn_puts(&out, ",\"statePath\":") ||
        !json_dyn_put_escaped(&out, state_path))
    {
        free(next); free(out.ptr);
        send_json(fd, "500 Internal Server Error", "{\"ok\":false,\"error\":\"GSA response memory\"}");
        return;
    }
    if (validation_plan_path[0]) {
        if (!json_dyn_puts(&out, ",\"validationPlanPath\":") ||
            !json_dyn_put_escaped(&out, validation_plan_path) ||
            !json_dyn_puts(&out, ",\"validationResultsPath\":") ||
            !json_dyn_put_escaped(&out, validation_results_path) ||
            !json_dyn_puts(&out, ",\"evidenceGraphPath\":") ||
            !json_dyn_put_escaped(&out, evidence_graph_path))
        {
            free(next); free(out.ptr);
            send_json(fd, "500 Internal Server Error", "{\"ok\":false,\"error\":\"GSA response memory\"}");
            return;
        }
    }
    if (!json_dyn_puts(&out, "}")) {
        free(next); free(out.ptr);
        send_json(fd, "500 Internal Server Error", "{\"ok\":false,\"error\":\"GSA response memory\"}");
        return;
    }
    free(next);
    send_json(fd, "200 OK", out.ptr);
    free(out.ptr);
}
