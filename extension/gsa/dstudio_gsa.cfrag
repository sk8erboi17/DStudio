static void gsa_tools_dir(char *out, size_t outsz) {
#ifdef _WIN32
    snprintf(out, outsz, "%s\\extension\\gsa\\tools\\bin", g_web_dir[0] ? g_web_dir : ".");
#else
    snprintf(out, outsz, "%s/extension/gsa/tools/bin", g_web_dir[0] ? g_web_dir : ".");
#endif
}

static void child_setenv_gsa_tools(void);

/* ---- GSA: guided security analysis pipeline ----------------------------------
 * GSA is intentionally file-backed and task-tracked. The API prepares bounded,
 * deterministic inputs and phase prompts; the Agent still performs the analysis
 * in the chosen workspace. That keeps failures visible and resumable. */

static int setup_run_cmd_capture(const char *cwd, char *const argv[], char *out, size_t outsz);

static int str_eq_ci_ascii(const char *a, const char *b) {
    if (!a || !b) return 0;
    while (*a && *b) {
        if (!ascii_eq_ci(*a, *b)) return 0;
        a++; b++;
    }
    return *a == '\0' && *b == '\0';
}

typedef struct {
    const char *name;
    const char *category;
    const char *aliases;   /* pipe-separated commands; first is preferred */
    const char *install;
    const char *notes;
} gsa_tool_spec;

static const gsa_tool_spec GSA_TOOL_SPECS[] = {
    { "subfinder", "recon/subdomains", "subfinder", "go install github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest", "Passive subdomain enumeration." },
    { "assetfinder", "recon/subdomains", "assetfinder", "go install github.com/tomnomnom/assetfinder@latest", "Passive subdomain enumeration." },
    { "httpx", "recon/http", "httpx", "go install github.com/projectdiscovery/httpx/cmd/httpx@latest", "HTTP probing, titles, status, TLS and CDN signals." },
    { "nuclei", "scan/templates", "nuclei", "go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest", "Template-based vulnerability checks; use only against authorized targets." },
    { "dnsx", "recon/dns", "dnsx", "go install github.com/projectdiscovery/dnsx/cmd/dnsx@latest", "DNS resolution and filtering." },
    { "naabu", "recon/ports", "naabu", "go install github.com/projectdiscovery/naabu/v2/cmd/naabu@latest", "Fast port discovery; authorized targets only." },
    { "katana", "recon/crawl", "katana", "go install github.com/projectdiscovery/katana/cmd/katana@latest", "Web crawling and endpoint discovery." },
    { "tlsx", "recon/tls", "tlsx", "go install github.com/projectdiscovery/tlsx/cmd/tlsx@latest", "TLS certificate and protocol probing." },
    { "mapcidr", "recon/network", "mapcidr", "go install github.com/projectdiscovery/mapcidr/cmd/mapcidr@latest", "CIDR expansion and filtering." },
    { "alterx", "recon/permutation", "alterx", "go install github.com/projectdiscovery/alterx/cmd/alterx@latest", "Subdomain permutation generation." },
    { "ffuf", "web/content", "ffuf", "go install github.com/ffuf/ffuf/v2@latest", "Web fuzzing/content discovery; authorized targets only." },
    { "gobuster", "web/content", "gobuster", "go install github.com/OJ/gobuster/v3@latest", "Directory, DNS and vhost discovery." },
    { "gau", "web/archive", "gau", "go install github.com/lc/gau/v2/cmd/gau@latest", "Known URL collection from public archives; use bounded provider-specific runs such as urlscan with short timeouts." },
    { "hakrawler", "web/crawl", "hakrawler", "go install github.com/hakluke/hakrawler@latest", "Lightweight web crawler." },
    { "dalfox", "web/xss", "dalfox", "go install github.com/hahwul/dalfox/v2@latest", "XSS scanning; authorized targets only." },
    { "sqlmap", "web/sqli", "sqlmap", "managed pipx install sqlmap", "SQL injection testing; authorized targets only." },
    { "arjun", "web/params", "arjun", "managed pipx install arjun", "HTTP parameter discovery." },
    { "uro", "web/urls", "uro", "managed pipx install uro", "URL deduplication/normalization." },
    { "semgrep", "code/sast", "semgrep", "managed pipx install semgrep", "Static code analysis." },
    { "trivy", "code/deps", "trivy", "brew install trivy | see https://aquasecurity.github.io/trivy", "Dependency/container/IaC scanning." },
    { "syft", "code/sbom", "syft", "brew install syft | see https://github.com/anchore/syft", "SBOM generation." },
    { "grype", "code/deps", "grype", "brew install grype | see https://github.com/anchore/grype", "Dependency vulnerability scanning." },
    { "plaso", "forensics/timeline", "log2timeline|log2timeline.py|psort|psort.py|pinfo|pinfo.py", "managed pipx install plaso", "Timeline generation and analysis from disk/artifact images." },
    { "volatility3", "forensics/memory", "vol|vol.py", "managed pipx install volatility3", "Memory forensics." },
    { "yara", "forensics/malware", "yara", "brew install yara | apt install yara", "Rule-based malware/artifact matching." },
    { "binwalk", "forensics/firmware", "binwalk", "managed cargo install binwalk", "Firmware and binary extraction." },
    { "tshark", "network/pcap", "tshark", "brew install wireshark | apt install tshark", "Packet capture analysis." },
    { "zeek", "network/pcap", "zeek", "brew install zeek | apt install zeek", "Network security monitoring/log extraction." },
    { "nmap", "network/ports", "nmap", "brew install nmap | apt install nmap", "Port/service enumeration; authorized targets only." },
    { "rizin", "reverse", "rizin|rz-bin|rz-find", "brew install rizin | see https://rizin.re", "Reverse engineering/disassembly." },
    { "radare2", "reverse", "radare2|r2", "brew install radare2 | see https://radare.org", "Reverse engineering/disassembly." },
    { "gdb", "pwn/debug", "gdb", "brew install gdb | apt install gdb", "Native debugging." },
    { "pwntools", "pwn/exploit-dev", "pwn", "managed pipx install pwntools", "Exploit development helpers." },
