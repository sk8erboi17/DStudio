# Compiled launcher binary + objects
dstudio
*.o
tests/.build/
tests/.artifacts/

# Generated headers: index.html in base64 and the logo PNG, embedded in the binary
page_data.h
loading_data.h
logo_data.h

# Icon generated by the build (logo.png → .icns) and temp files
ds4.icns
ds4.iconset/
.icontmp.*
dev.ds4.DStudio.desktop

# Engine log (generated at runtime in the ds4 dir, but ignored just in case)
ds4-server.log
linux-smoke.log
*.log.gz
Worker_*_log2timeline-*.log.gz
log2timeline-*.log.gz
core
core.*

# Managed upstream engine checkout. DStudio can clone antirez/ds4 here and
# apply its reversible patch sets without vendoring upstream source.
/ds4/

# macOS
.DS_Store

# Design agent workspace/mockup (not source)
ds4-design/
*.app/

# Local package/test caches and generated scratch state
node_modules/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dstudio/
MEMORY.MD

# Generated benchmark runs and local evaluation output
benchmark/
extension/gsa/benchmark/
